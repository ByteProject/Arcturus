{
  "name": "arcturus",
  "displayName": "Arcturus",
  "description": "The official syntax highlighter for the Arcturus programming language for Infocom's Z-machine.",
  "version": "0.12.2",
  "publisher": "ByteProject",
  "icon": "icon.png",
  "author": {
    "name": "Stefan Vogt"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteProject/Arcturus"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "arcturus",
    "interactive fiction",
    "z-machine",
    "infocom",
    "storyarc"
  ],
  "contributes": {
    "languages": [
      {
        "id": "storyarc",
        "aliases": [
          "Arcturus",
          "storyarc"
        ],
        "extensions": [
          ".storyarc",
          ".prelude",
          ".granule"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "storyarc",
        "scopeName": "source.storyarc",
        "path": "./syntaxes/storyarc.tmLanguage.json"
      }
    ]
  }
}