{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Arcturus",
  "scopeName": "source.storyarc",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#uuid"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#kinds"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#services"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.storyarc",
          "match": "//.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "Declaration heads that introduce a named entity.",
          "match": "^\\s*(kind|room|thing)\\s+([A-Za-z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.storyarc"
            },
            "2": {
              "name": "entity.name.type.storyarc"
            }
          }
        },
        {
          "match": "^\\s*(block)\\s+([A-Za-z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.storyarc"
            },
            "2": {
              "name": "entity.name.function.storyarc"
            }
          }
        },
        {
          "comment": "A topic declaration on a person: topic <id> \"label\" ...",
          "match": "^\\s*(topic)\\s+([A-Za-z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.storyarc"
            },
            "2": {
              "name": "entity.name.function.storyarc"
            }
          }
        },
        {
          "match": "^\\s*(global|constant|flag|counter)\\s+([A-Za-z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.storyarc"
            },
            "2": {
              "name": "variable.other.storyarc"
            }
          }
        },
        {
          "match": "^\\s*(game|verb|grains|ranks|ambience)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.storyarc"
            }
          }
        },
        {
          "comment": "Language-layer declarations: words the parser reads (docs/02 8, 8a, 8b, 14a).",
          "match": "^\\s*(direction|particle|pronoun|chain|noise|all|language)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.storyarc"
            }
          }
        },
        {
          "comment": "player.words / player.desc: augmenting the seeded player (docs/01 5a).",
          "match": "^\\s*(player)(\\.)([a-z_][a-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.language.storyarc"
            },
            "3": {
              "name": "support.type.property.storyarc"
            }
          }
        },
        {
          "comment": "A German gender line: a bare der/die/das in an object body (docs/02 14a).",
          "match": "^\\s*(der|die|das)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.other.gender.storyarc"
            }
          }
        },
        {
          "comment": "The three summon forms: summon.feature (bundled), summon name.granule (searched), summon \"path\" (a file, highlighted as a string).",
          "match": "^\\s*(summon)(?:(\\.[A-Za-z][A-Za-z0-9_]*)|\\s+([A-Za-z][A-Za-z0-9_]*\\.granule))?",
          "captures": {
            "1": {
              "name": "keyword.control.import.storyarc"
            },
            "2": {
              "name": "storage.modifier.storyarc"
            },
            "3": {
              "name": "storage.modifier.storyarc"
            }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.storyarc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.storyarc",
          "match": "\\\\([\"\\\\$n])"
        },
        {
          "name": "meta.interpolation.storyarc",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.interpolation.begin.storyarc"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.interpolation.end.storyarc"
            }
          },
          "patterns": [
            {
              "include": "#numbers"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#builtins"
            },
            {
              "include": "#operators"
            },
            {
              "comment": "The leading article of an interpolation: the/The/a/an.",
              "match": "\\b(the|The|a|an)\\b",
              "name": "keyword.other.article.storyarc"
            },
            {
              "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b",
              "name": "variable.other.interpolated.storyarc"
            }
          ]
        }
      ]
    },
    "uuid": {
      "name": "constant.other.uuid.storyarc",
      "match": "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b"
    },
    "numbers": {
      "name": "constant.numeric.storyarc",
      "match": "\\b-?[0-9]+\\b"
    },
    "constants": {
      "name": "constant.language.storyarc",
      "match": "\\b(true|false|nothing)\\b"
    },
    "builtins": {
      "name": "variable.language.storyarc",
      "match": "\\b(self|player|here|noun|second|turns|score|max_score|way|grain|refused|ambience_rate)\\b"
    },
    "kinds": {
      "patterns": [
        {
          "comment": "Standard Cosmos kinds, highlighted only in kind position (after `of`).",
          "match": "\\b(of)\\s+(thing|room|container|supporter|door|character)\\b",
          "captures": {
            "1": {
              "name": "keyword.operator.word.storyarc"
            },
            "2": {
              "name": "support.class.kind.storyarc"
            }
          }
        },
        {
          "comment": "The backstage scope room: `in scope` places an object always in scope (docs/01 section 5).",
          "match": "\\b(in|to)\\s+(scope)\\b",
          "captures": {
            "1": {
              "name": "keyword.operator.word.storyarc"
            },
            "2": {
              "name": "support.class.kind.storyarc"
            }
          }
        }
      ]
    },
    "attributes": {
      "comment": "Standard Cosmos boolean attributes (docs/02).",
      "name": "support.type.attribute.storyarc",
      "match": "\\b(fixed|scenery|hidden|concealed|wearable|worn|lit|edible|named|switchable|openable|open|lockable|locked|visited|clear|seen|moved|animate|an|feminine|neutral|pluribus|scored|component)\\b"
    },
    "properties": {
      "comment": "Standard Cosmos value properties and the topic modifiers.",
      "patterns": [
        {
          "name": "support.type.property.storyarc",
          "match": "\\b(name|desc|intro|appearance|words|capacity|spans|unseal_with|article|indefinite|tag|plural|arc_image)\\b"
        },
        {
          "comment": "Topic, ambience, and rank header modifiers (docs/01 sections 6a and 15; docs/05 ambience).",
          "name": "keyword.other.modifier.storyarc",
          "match": "\\b(once|hidden|about|order|at|percent|points|turns)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.storyarc",
          "match": "\\b(if|else|while|for|each|switch|case|when|return|stop|continue|finish|death|do|on|after|every)\\b"
        },
        {
          "name": "keyword.other.statement.storyarc",
          "match": "\\b(let|change|now|move|add|remove|say|zcolor|to|from|start)\\b"
        },
        {
          "comment": "The award statement: score enters the game only through it (docs/01 6a).",
          "match": "\\b(award)\\s+([0-9]+)(?:\\s+(for)\\s+([A-Za-z][A-Za-z0-9_]*))?",
          "captures": {
            "1": {
              "name": "keyword.other.statement.storyarc"
            },
            "2": {
              "name": "constant.numeric.storyarc"
            },
            "3": {
              "name": "keyword.operator.word.storyarc"
            },
            "4": {
              "name": "entity.name.tag.pool.storyarc"
            }
          }
        },
        {
          "comment": "Dot-modifier chains, three scopes (Stefan's policy, 2026-07-04): the KEYWORD (say, zcolor, par), the MODIFIER chain (.par, .yellow, .font - one scope, dots included), and the trailing VALUE (the colour word of a zcolor line). say.yellow.par, par.say, zcolor.font white all show three colours.",
          "match": "\\b(zcolor|say|par)((?:\\.(?:font|background|statusline|input|default|black|red|green|yellow|blue|magenta|cyan|white|par|say))+)\\b(?:[ \\t]+(default|black|red|green|yellow|blue|magenta|cyan|white)\\b)?",
          "captures": {
            "1": {
              "name": "keyword.other.statement.storyarc"
            },
            "2": {
              "name": "storage.modifier.storyarc"
            },
            "3": {
              "name": "support.constant.colour.storyarc"
            }
          }
        },
        {
          "comment": "Conversation sugar in a topic body: the player's line, the NPC reply, and the reveal/hide toggles (docs/02 section 14).",
          "name": "keyword.other.conversation.storyarc",
          "match": "\\b(you|reply|reveal|hide)\\b"
        },
        {
          "name": "storage.type.storyarc",
          "match": "\\b(list|block|topic)\\b"
        },
        {
          "name": "support.type.metadata.storyarc",
          "match": "\\b(title|headline|author|release|serial|UUID|scoring|banner)\\b"
        }
      ]
    },
    "calls": {
      "comment": "A block or intrinsic call with arguments: the callee in its own scope, the arguments left to the value scopes (Stefan's policy, 2026-07-04). Bare zero-argument calls are lexically plain names and stay unscoped.",
      "match": "\\b([a-z_][a-z0-9_]*)(?=\\()",
      "name": "entity.name.function.call.storyarc"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.storyarc",
          "match": "\\b(is|not|and|or|holds|in|within|of|mod)\\b"
        },
        {
          "name": "keyword.operator.storyarc",
          "match": "(\\+\\+|--|<=|>=|<|>|\\+|-|\\*|/|=|\\.)"
        }
      ]
    },
    "services": {
      "comment": "The library services an author calls bare or tests with `is`: the cutscene trio (teleport/gain/convey), perform, the worn list, the sight-and-touch predicates. Curated, not exhaustive: the documented author surface only.",
      "name": "support.function.library.storyarc",
      "match": "\\b(teleport|gain|convey|perform|worn_count|list_worn|visible|reachable)\\b"
    }
  }
}
