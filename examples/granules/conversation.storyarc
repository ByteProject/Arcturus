// conversation.storyarc
// part of Arcturus, a programming language and compiler for the Infocom Z-machine.
// Copyright (c) 2026, Stefan Vogt.
// https://github.com/ByteProject/Arcturus
//
// A showcase for the Infocom-style conversation path of summon.extendedverbs:
// ASK and TELL a person ABOUT a subject. This is the topic-driven approach,
// where the NPC answers by inspecting the subject (the second noun) in its own
// `on ask` / `on tell` handler and falling through to the granule's polite
// default with `continue`. Compile and run:
//
//   arcc examples/granules/conversation.storyarc -o conversation.z5
//   frotz conversation.z5
//
// Try: ASK VLAD ABOUT CLOAK, TELL VLAD ABOUT CLOAK, ASK VLAD ABOUT COIN, and
// ASK VLAD ABOUT GLASS (a subject he has nothing to say about, so the default
// speaks). The forthcoming summon.conversations granule offers the same content
// as a point-and-click menu instead; this is the verb-driven path.

game
    title "Conversation Demo"
    headline "The ask/tell path of summon.extendedverbs"
    author "Stefan Vogt"
    start tavern

summon.extendedverbs

room tavern
    name "The Tavern"
    desc "A smoky tavern. Vlad the barman polishes a glass behind the bar. A black cloak hangs by the door, and a gold coin glints on the counter."

thing vlad of person in tavern
    name "Vlad"
    words vlad, barman
    named

    // The NPC answers ASK and TELL by checking the subject (the second noun).
    // Each branch handles one topic and consumes the action with `stop`; an
    // unhandled subject falls through with `continue` to the extendedverbs
    // default ("Vlad stays mum on the subject.").
    on ask
        if second is cloak
            say "\"That cloak? Trouble follows whoever wears it,\" Vlad mutters."
            stop
        if second is coin
            say "\"Keep your coin. I want no part of your business,\" he says."
            stop
        continue

    on tell
        if second is cloak
            say "Vlad's eyes narrow. \"I would burn that thing, were it mine.\""
            stop
        continue

thing cloak in tavern
    name "black cloak"
    words black, cloak

thing coin in tavern
    name "gold coin"
    words gold, coin

thing glass in tavern
    name "polished glass"
    words polished, glass
