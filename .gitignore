# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.eggs/
dist/

# The build directory is scratch, EXCEPT the shipped standalones: the
# amalgamated compiler (build/arcc), interpreter (build/actaea), and arc_image
# tool (build/arcimg). We track those so adopters can download and run them
# straight from the repo, no install. Compiled stories stay out via the
# *.z5/*.z8 rule below.
build/*
!build/arcc
!build/actaea
!build/arcimg

# The arc_image working directory: the Rabenstein port and its Director's Cut
# across platforms, worked on locally and not part of the repo. The committed
# arc_image example lives under examples/arc_image instead. The leading slash
# anchors this to the repo root, so examples/arc_image is NOT matched.
/arc_image/

# Editor and OS
.DS_Store
*.swp

# Build output
*.z5
*.z8
!tests/golden/**/*.z5

# The Hibernated 2 source and walkthrough (the B8 port's working material) are
# NOT released; this repository is public. Never commit this directory.
hibernated2/

# VS Code extension build artifacts
editors/vscode/node_modules/
# The packaged .vsix is committed as the easy-install artifact; rebuild it with
# tools/build_vsix.py.

# Third-party conformance stories and transcripts (local only)
actaea/conformance/
