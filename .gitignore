# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.eggs/
dist/

# The build directory is scratch, EXCEPT the shipped standalones: the
# amalgamated compiler (build/arcc), interpreter (build/actaea), and arc_image
# tool (build/arcimg). We track those so adopters can download and run them
# straight from the repo, no install. Compiled stories stay out via the
# *.z5/*.z8 rule below.
build/*
!build/arcc
!build/actaea
!build/arcimg

# The arc_image directory is the B12 playground (docs/08): the masters are
# the tracked truth; the per-target conversions and previews are derived
# artifacts, regenerated in seconds with `arcimg convert`, so they stay
# untracked. Compiled stories inside it stay out via the *.z5/*.z8 rules
# below. The small teaching example remains at examples/arc_image.
/arc_image/ami/
/arc_image/ast/
/arc_image/dos/
/arc_image/previews/
/arc_image/stress-out/

# Editor and OS
.DS_Store
*.swp

# Build output
*.z5
*.z8
!tests/golden/**/*.z5

# The Hibernated 2 source and walkthrough (the B8 port's working material) are
# NOT released; this repository is public. Never commit this directory.
hibernated2/

# VS Code extension build artifacts
editors/vscode/node_modules/
# The packaged .vsix is committed as the easy-install artifact; rebuild it with
# tools/build_vsix.py.

# Third-party conformance stories and transcripts (local only)
actaea/conformance/
