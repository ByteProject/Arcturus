# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.eggs/
dist/

# The build directory is scratch, EXCEPT the two shipped standalones: the
# amalgamated compiler (build/arcc) and interpreter (build/actaea). We track
# those so adopters can download and run them straight from the repo, no
# install. Compiled stories stay out via the *.z5/*.z8 rule below.
build/*
!build/arcc
!build/actaea

# Editor and OS
.DS_Store
*.swp

# Build output
*.z5
*.z8
!tests/golden/**/*.z5

# The Hibernated 2 source and walkthrough (the B8 port's working material) are
# NOT released; this repository is public. Never commit this directory.
hibernated2/

# VS Code extension build artifacts
editors/vscode/node_modules/
# The packaged .vsix is committed as the easy-install artifact; rebuild it with
# tools/build_vsix.py.

# Third-party conformance stories and transcripts (local only)
actaea/conformance/
