            row = []
            for i in range(span):
                byte = bm[y * span + i]
                row += [(byte >> 6) & 3, (byte >> 4) & 3, (byte >> 2) & 3,
                        byte & 3]
            pixels.append(row)
        return {"w": w, "h": h, "pixels": pixels,
                "lines": list(s[SEC_LINETABLE])}

