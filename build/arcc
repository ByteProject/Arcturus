change refused to 1\n    msg_eat\n\non drink\n    change refused to 1\n    msg_drink\n\non attack\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    msg_attack\n\non kiss\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    change refused to 1\n    msg_kiss\n\non push\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    msg_no_effect\n\non pull\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    msg_no_effect\n\non turn\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    msg_no_effect\n\non climb\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    // Climbing something you can stand on IS boarding it: CLIMB STOOL\n    // lands you on the stool through the full enter pipeline, the stool\'s\n    // own handlers included. Folds away with nothing to stand on.\n    if any_enterable is 1\n        if noun is supporter\n            perform("enter", noun)\n            stop\n    change refused to 1\n    msg_cant_climb\n\non talk\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if noun is animate\n        talk_to(noun)\n        stop\n    change refused to 1\n    msg_only_animate\n\n// ASK, TELL, and ANSWER are standard, as in PunyInform. Elevated\n// conversation belongs to the granules alone: with neither summoned, the\n// base seams simply hand over to talk_to, so asking IS talking and every\n// conversation verb shares the one brush-off. summon.conversations makes\n// ASK open the menu and TELL hint at TALK TO; summon.infocom_talking\n// dispatches the person\'s topics (and only there do the richer flat\n// defaults msg_ask/msg_tell/msg_answer exist, so they cost every other\n// game nothing). The two presentations are mutually exclusive (docs/05).\non ask\n    if convo_guard is 1\n        ask_to(noun)\n\non tell\n    if convo_guard is 1\n        tell_to(noun)\n\n// The shared guard: conversation needs a visible, living someone.\nblock convo_guard()\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        return 0\n    if noun is not animate\n        change refused to 1\n        msg_only_animate\n        return 0\n    return 1\n\non answer\n    if convo_guard is 1\n        answer_to(noun)\n\nblock ask_to(person)\n    talk_to(person)\n\nblock tell_to(person)\n    talk_to(person)\n\nblock answer_to(person)\n    talk_to(person)\n\n// What happens when you talk to a living thing. The default is a flat brush-off;\n// the conversations granule overrides this block to open the topic menu instead.\n// (A person can still override `on talk` itself for a one-off custom exchange.)\nblock talk_to(person)\n    change refused to 1\n    msg_no_talk\n\non jump\n    msg_jump\n\non wait\n    msg_wait\n\non sing\n    msg_sing\n',
    'ambience.granule': "// ambience.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// AMBIENCE (summon.ambience, docs/05): rooms and things murmur over time.\n// An `ambience` block on a room plays while the player is there; on a thing,\n// while the thing is in scope (a companion, a muttering radio). The header\n// sets the shape: `about N turns` breathes (each silent turn shortens the\n// odds, a fired line resets them), `every N turns` is a strict clock,\n// `in order` plays the lines as written and cycles, `in order once` falls\n// silent after the last line, and a `when` guards the whole block live. A\n// line is a string, or `do <block>` for a computed one, each with its own\n// optional trailing `when`.\n//\n// THE DIAL: ambience_rate is the default cadence for blocks that declare\n// none, and 0 mutes everything, so a handler can hush the stage for a tense\n// scene (`change ambience_rate to 0`) and bring it back after.\n//\n// KNOW WHEN NOT TO USE IT: one line that fires until a condition flips is a\n// plain daemon (`every 3 turns do drip` and a two-line block), no granule\n// needed. Ambience is for shuffled, breathing texture: NPC behavior and\n// layered room mood.\n//\n// At most one ambient line plays per turn, whichever eligible block rolls\n// first, so a busy room never floods the transcript.\n\nglobal ambience_rate = 8\n\non each_turn\n    ambience_pulse\n\n// The per-turn sweep over the compiler's ambience table (one record per\n// block: owner, room flag, mode, rate, line count, the guard / play / line\n// guard routines, and two words of live state). First block to fire wins\n// the turn.\nblock ambience_pulse()\n    let base = ambience_table\n    if base is 0\n        return 0\n    if ambience_rate is 0\n        return 0\n    let n = peek_word(base, 0)\n    let b = 0\n    while b < n\n        if amb_try(base + 2 + b * 20) is 1\n            return 0\n        change b to b + 1\n    return 0\n\nblock amb_try(rec)\n    // In play? A room block needs the player there; a thing block needs the\n    // thing in scope.\n    if peek_word(rec, 1) is 1\n        if here is not peek_word(rec, 0)\n            return 0\n    else\n        if in_scope(peek_word(rec, 0)) is 0\n            return 0\n    // The header guard, if any.\n    let g = peek_word(rec, 5)\n    if g is not 0\n        if call_handler(g, 0) is 0\n            return 0\n    // The cadence. Mode 1 is the strict clock; everything else breathes:\n    // the odds start at the rate and shorten by one for every silent turn,\n    // so a quiet room grows restless, and a fired line resets the calm.\n    let mode = peek_word(rec, 2)\n    let rate = peek_word(rec, 3)\n    if rate is 0\n        change rate to ambience_rate\n    let odds = peek_word(rec, 8)\n    if odds is 0\n        change odds to rate\n    if mode is 1\n        change odds to odds - 1\n        if odds > 0\n            poke_word(rec, 8, odds)\n            return 0\n        poke_word(rec, 8, rate)\n    else\n        if random(odds) > 1\n            if odds > 1\n                change odds to odds - 1\n            poke_word(rec, 8, odds)\n            return 0\n        poke_word(rec, 8, rate)\n    // Pick the line. In order (modes 2 and 3): the next written line whose\n    // guard holds; mode 3 falls silent past the last. Otherwise: a random\n    // line, never the same one twice running, guards respected; a turn that\n    // finds nothing eligible stays quiet.\n    let count = peek_word(rec, 4)\n    let lg = peek_word(rec, 7)\n    let last = peek_word(rec, 9)\n    let k = 0\n    let tries = 0\n    if mode > 1\n        change k to last\n        while tries < count\n            if k >= count\n                if mode is 3\n                    return 0\n                change k to 0\n            if lg is 0\n                change tries to 99\n            else\n                if call_handler(lg, k) is 1\n                    change tries to 99\n                else\n                    change k to k + 1\n                    change tries to tries + 1\n        if tries is not 99\n            return 0\n    else\n        change k to random(count) - 1\n        while tries < 6\n            let bad = 0\n            // Prefer a fresh line, but after a few draws accept a repeat:\n            // when guards leave only the last-told line eligible, a repeat\n            // beats falling silent for good.\n            if count > 1\n                if tries < 3\n                    if k + 1 is last\n                        change bad to 1\n            if bad is 0\n                if lg is not 0\n                    if call_handler(lg, k) is 0\n                        change bad to 1\n            if bad is 0\n                change tries to 99\n            else\n                change k to random(count) - 1\n                change tries to tries + 1\n        if tries is not 99\n            return 0\n    call_handler(peek_word(rec, 6), k)\n    poke_word(rec, 9, k + 1)\n    return 1\n",
    'conversations.granule': '// conversations.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// summon.conversations: the menu presentation of the `topic` model, after the\n// look of PunyInform\'s talk menu (which is the right idea) but on Arcturus\'s\n// topic sugar instead of its hand-managed talk arrays. TALK TO a person and a\n// numbered menu of their topics in view is painted in the upper window, held\n// STATIC while the conversation scrolls in the main window below. Press a number\n// to ask that topic; the exchange prints below and the topic drops off the menu\n// (you have discussed it), which redraws with any topics the exchange revealed.\n// 0 or ENTER ends it and the menu folds away.\n//\n// This is the same `topic` model the extendedverbs ask/tell path walks; the two\n// are mutually exclusive views of one thing (the menu wins). To change the menu\n// wording or layout, override the blocks from the story or fork the granule.\n// (The conversation line framing - line_you,\n// line_reply, line_end - lives in the prelude, not here, so that part stays\n// overridable from a story and translatable by a language pack.)\n\n// Override the base talk_to seam: talking to a person opens the topic menu.\nblock talk_to(person)\n    run_talk(person)\n\n// ASK (and a stray ANSWER) land in the menu through the base seams, which\n// hand over to talk_to; overriding talk_to above was enough, so ASK VLAD\n// opens Vlad\'s menu and the subject words of "ask vlad about the vines"\n// ride along harmlessly. TELL is not asking: it answers with the gentle\n// use-TALK hint (msg_use_talk, in the language layer). The words and\n// grammar are the standard ask/tell from the language pack; this granule\n// holds no words and no strings.\nblock tell_to(person)\n    change refused to 1\n    msg_use_talk\n\nblock run_talk(person)\n    if count_visible(person) is 0\n        msg_no_topics\n        return 0\n    let going = 1\n    while going is 1\n        let count = count_visible(person)\n        if count > 9\n            change count to 9\n        if count is 0\n            close_menu\n            msg_talk_over\n            change going to 0\n        else\n            draw_menu(person, count)\n            let pick = menu_choice(count)\n            if pick is 0\n                close_menu\n                msg_talk_over\n                change going to 0\n            else\n                set_window(0)\n                run_pick(person, pick)\n\n// Paint the numbered menu in the upper window and hold it static there, sized to\n// the topics in view rather than reserving a fixed slice of the screen the way\n// PunyInform\'s talk menu does - a small dynamic refinement on the same idea.\n// Layout, top to bottom with no gaps: the status bar (only when statusline is\n// summoned), the header, the topics, the prompt, and a divider rule at the bottom\n// border. status_lines tells us whether a bar row is present, so without\n// statusline the menu reclaims row 1 and uses the full window. The double erase,\n// around the resize, keeps a shrinking menu from leaving a stale line behind: the\n// first clears the old (possibly taller) window, the second the new one. Single\n// keypress selection caps the list at nine, so a tenth topic waits for a discard.\nblock draw_menu(person, count)\n    // HOLD the pending paragraph break across the menu draw: it belongs to the\n    // lower window\'s next text, and the menu\'s prints must not consume it.\n    let held = par_pending\n    change par_pending to 0\n    // Unbuffered while the menu paints (restored at set_window(0) below), or\n    // buffering interpreters reorder the writes around set_cursor.\n    buffer_mode(0)\n    let w = screen_width\n    if w is 0\n        change w to 40\n    let top = status_lines\n    let h = top + count + 3\n    set_window(1)\n    erase_window(1)\n    split_window(h)\n    erase_window(1)\n    if top is 1\n        status_bar\n    set_cursor(top + 1, 1)\n    line_talk_header(person)\n    let i = 0\n    let n = 0\n    while i < topics_count(person)\n        if topic_visible(person, i)\n            if n < count\n                change n to n + 1\n                set_cursor(top + 1 + n, 2)\n                show(n)\n                show(". ")\n                topic_label(person, i)\n        change i to i + 1\n    set_cursor(h - 1, 1)\n    line_talk_prompt\n    set_cursor(h, 1)\n    let d = 1\n    while d < w\n        show("-")\n        change d to d + 1\n    set_window(0)\n    buffer_mode(1)\n    change par_pending to held\n\n// Read keypresses until a valid one: a digit 1..count returns it; 0, ENTER, or Q\n// ends the conversation (returns 0). Other keys are ignored and read again, so a\n// stray key neither redraws nor exits.\nblock menu_choice(count)\n    while true\n        let key = read_key\n        if key is 13\n            return 0\n        if key is 48\n            return 0\n        if key is 81\n            return 0\n        if key is 113\n            return 0\n        let pick = key - 48\n        if pick >= 1\n            if pick <= count\n                return pick\n\n// Fold the menu away and return the whole screen to the conversation.\nblock close_menu()\n    erase_window(1)\n    split_window(0)\n    set_window(0)\n\nblock count_visible(person)\n    let i = 0\n    let n = 0\n    while i < topics_count(person)\n        if topic_visible(person, i)\n            change n to n + 1\n        change i to i + 1\n    return n\n\n// Run the pick-th visible topic (counting from 1, in declaration order, as\n// draw_menu numbered them), then retire it so it leaves the menu.\nblock run_pick(person, pick)\n    let i = 0\n    let n = 0\n    while i < topics_count(person)\n        if topic_visible(person, i)\n            change n to n + 1\n            if n is pick\n                topic_run(person, i)\n                topic_retire(person, i)\n                return 0\n        change i to i + 1\n\n// The conversation wording (line_talk_header, line_talk_prompt, msg_no_topics,\n// msg_talk_over) lives in the language layer so a pack translates it.\n',
    'core.prelude': '// core.prelude\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// The core of Cosmos, the Arcturus standard library, written in Arcturus and\n// compiled together with the author\'s game. This file is intentionally minimal\n// for now (milestone B4.5b); the parser, scope, action pipeline, turn loop, and\n// standard verbs are added file by file through B4.5c to B4.5e. Until then the\n// compiler still seeds the standard kinds and properties from its provisional\n// table (prelude.py); those move into Cosmos source as the runtime grows.\n\n// A marker block, proving Cosmos compiles together with the game. It will be\n// replaced by real library code as Cosmos is built out.\nblock cosmos_ready()\n    return 1\n\n// Transitive containment (docs/01 section 9): is obj anywhere inside\n// outer\'s tree, however nested? The coin in a purse in a bucket the\n// player holds answers `coin within player`. The `within` operator\n// desugars to this walk; a game that never asks pays nothing (DCE).\n// Total, like the direct tests: `nothing within x` is false.\nblock within(obj, outer)\n    if obj is nothing\n        return 0\n    if outer is nothing\n        return 0\n    let p = parent_of(obj)\n    while p is not nothing\n        if p is outer\n            return 1\n        change p to parent_of(p)\n    return 0\n\n// Swap one object out of the world for another IN PLACE (docs/01 section 9):\n// `swap(bob, unconscious_bob)` moves the replacement into bob\'s exact spot,\n// removes bob, and HANDS OFF every live reference so the command bindings\n// follow the change. Without this, an author who moves an object away mid-\n// action leaves `noun`/`second` (and so AGAIN, which replays them) pointing\n// at the object that just left, and the pronouns (IT, HIM, HER, THEM) too:\n// AGAIN then answers "you see nothing of the sort here" and IT dangles (a\n// field report). The engine re-derives nothing; the author models the change\n// and swap re-points what the turn is holding. Compute the destination before\n// removing old, so the replacement lands where old actually was. DCE\'d in a\n// game that never swaps.\nblock swap(old, new)\n    if old is new\n        return 0\n    move new to parent_of(old)\n    move old to nothing\n    if noun is old\n        change noun to new\n    if second is old\n        change second to new\n    if pron_it is old\n        change pron_it to new\n    if pron_him is old\n        change pron_him to new\n    if pron_her is old\n        change pron_her to new\n    if pron_them is old\n        change pron_them to new\n\n// The catalog scan (docs/01, catalogs): the 1-based number of the first\n// entry equal to val, or 0 when absent. `position(suspects, butler)` is\n// the author call; `butler in suspects` branches on the same block, so\n// membership and position share one routine, present only when some game\n// asks (DCE). The region layout is [count, widest, e1..eN] per catalog,\n// reached through the __catalogs__ base; l is the catalog\'s word offset.\nblock position(l, val)\n    let n = peek_word(catalogs_base, l)\n    let i = 1\n    while i <= n\n        if peek_word(catalogs_base, l + 1 + i) is val\n            return i\n        change i to i + 1\n    return 0\n',
    'debug.granule': '// debug.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// summon.debug: developer testing verbs. There is no separate release build to\n// strip them from; summoning the granule is the opt-in, and leaving it unsummoned\n// leaves them out entirely. The primaries are Arcturus-named, with the familiar\n// Inform synonyms (purloin, gonear, showobj) alongside.\n//\n// fetch, warp, and inspect reach ANY object, in scope or not - that is the whole\n// point of a debug verb. They get there through the reach_unscoped parser seam:\n// when ordinary scope matching fails, the parser asks this granule to try, and it\n// matches the typed word against every object in the game rather than aborting.\n//\n// Looking for Inform\'s RECORDING / REPLAY to step through a walkthrough? That is\n// not a verb here: it lives in the interpreter, so it costs the story nothing.\n// Actaea records, replays, and checks a session with `actaea --record`,\n// `--replay`, and `--check` (docs/06 section 3).\n\n// The parser seam (library default: nothing). For a debug verb only, match the\n// typed word against every object so the verb can reach out of scope; other verbs\n// fall through and still answer "you can\'t see that".\nblock reach_unscoped()\n    let d = word_dict(0)\n    if d is nothing\n        return nothing\n    let act = peek_byte(d + 7)\n    if act is action_id("fetch")\n        return match_any\n    if act is action_id("warp")\n        return match_any\n    if act is action_id("inspect")\n        return match_any\n    return nothing\n\n// The first typed word (after the verb) that names any object at all.\nblock match_any()\n    let n = word_count\n    let i = 1\n    while i < n\n        let target = word_dict(i)\n        if target is not nothing\n            let found = find_any(target)\n            if found is not nothing\n                return found\n        change i to i + 1\n    return nothing\n\n// Scan every object by number for one whose words include this dictionary word.\n// The parser reaches only objects in scope; debug reaches all of them.\nblock find_any(target)\n    let i = 1\n    while i <= object_count\n        if has_word(i, target)\n            return i\n        change i to i + 1\n    return nothing\n\n// The room an object ultimately sits in: walk up the tree to the top parent.\nblock room_of(obj)\n    let r = obj\n    while r is not in nothing\n        change r to parent_of(r)\n    return r\n\n// Indent helper for the tree and scope listings.\nblock indent(depth)\n    let i = 0\n    while i < depth\n        show("  ")\n        change i to i + 1\n\n// ---------------------------------------------------------------------------\n// tree: the whole object tree, each top-level object (rooms, and anything\n// detached) and its contents below it, indented.\n\nverb "tree", "objects" meta\n    tree\n\non tree\n    let i = 1\n    while i <= object_count\n        if i is in nothing\n            tree_from(i, 0)\n        change i to i + 1\n\nblock tree_from(obj, depth)\n    indent(depth)\n    print_name(obj)\n    say ""\n    for each x in obj\n        tree_from(x, depth + 1)\n\n// ---------------------------------------------------------------------------\n// scope: what is reachable from here - the room and what you carry, on into open\n// or clear containers and onto supporters, the way the noun matcher sees it.\n\nverb "scope" meta\n    scope\n\non scope\n    say "In scope:"\n    scope_from(here, 1)\n    scope_from(player, 1)\n\nblock scope_from(holder, depth)\n    for each x in holder\n        indent(depth)\n        print_name(x)\n        say ""\n        if see_into(x)\n            scope_from(x, depth + 1)\n\n// ---------------------------------------------------------------------------\n// fetch (Inform purloin): pull any object into your hands.\n\nverb "fetch", "purloin" meta\n    fetch noun\n\non fetch\n    if noun is nothing\n        say "Fetch what?"\n        stop\n    // Purloin pulls the object plainly into your hands, bypassing every\n    // rule. Detach it first: a component moved while still marked stays\n    // "part of" its new holder (part of the player) and vanishes from the\n    // inventory listing (a field report: purloining a component of a\n    // character seemed to do nothing). Clear the mark so it lands as an\n    // ordinary carried thing; the guard folds away without components.\n    if any_components is 1\n        now noun is not component\n    move noun to player\n    show("Fetched ")\n    print_name(noun)\n    say "."\n\n// warp (Inform gonear): teleport to wherever an object is.\n\nverb "warp", "gonear" meta\n    warp noun\n\non warp\n    if noun is nothing\n        say "Warp where?"\n        stop\n    let dest = room_of(noun)\n    set_here(dest)\n    move player to dest\n    describe_room\n\n// inspect (Inform showobj): an object\'s location and the attributes it has set.\n\nverb "inspect", "showobj" meta\n    inspect noun\n\non inspect\n    if noun is nothing\n        say "Inspect what?"\n        stop\n    print_name(noun)\n    say ""\n    show("  in: ")\n    let p = parent_of(noun)\n    if p is nothing\n        say "nowhere"\n    else\n        print_name(p)\n        say ""\n    inspect_attrs(noun)\n\n// The standard attributes that are set on the object, one per line.\nblock inspect_attrs(obj)\n    if obj is container\n        say "  container"\n    if obj is supporter\n        say "  supporter"\n    if obj is open\n        say "  open"\n    if obj is locked\n        say "  locked"\n    if obj is switchable\n        say "  switchable"\n    if obj is lit\n        say "  lit"\n    if obj is worn\n        say "  worn"\n    if obj is animate\n        say "  animate"\n    if obj is fixed\n        say "  fixed"\n    if obj is scenery\n        say "  scenery"\n    if obj is hidden\n        say "  hidden"\n    if obj is moved\n        say "  moved"\n    if obj is seen\n        say "  seen"\n',
    'dispatch.prelude': '// dispatch.prelude\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// The action pipeline (docs/02 section 9), written in Arcturus. Given an action,\n// it walks the chain most-specific first - the noun, then the room - calling each\n// object\'s react routine (wired by the compiler) and stopping at the first that\n// consumes the action (returns 1). A react routine runs the object\'s own\n// handlers and its kind chain.\n//\n// The chain is most-specific first: the noun, then the room, then the\n// free-standing rules and the Cosmos default verbs (react_free). Each link may\n// consume the action (return 1); the first that does ends the walk.\n\nblock dispatch(action)\n    // A handler that alters speaks the report; the mark lives for one\n    // action. Folds away in a game that never alters.\n    if any_alter is 1\n        change altered to 0\n    if grain is not 0\n        run_grain(grain, action)\n        return\n    // Out-of-world actions (score, save, restore, restart, quit) never touch\n    // the world: no object, recipient, or room handler sees them, exactly as\n    // Inform and PunyInform mark their meta verbs. The compiler numbers them\n    // past meta_floor, so one compare routes them straight to the free\n    // rules (a story still overrides them there, with a free `on score`).\n    if action >= meta_floor\n        run_free(action)\n        return\n    if noun is not nothing\n        let r = handler_of(noun)\n        if r is not nothing\n            if call_handler(r, action) is 1\n                return\n    // The second noun\'s handlers come next: the RECIPIENT of a give or show,\n    // the container of a put, may answer for itself ("give chip to vlad"\n    // runs Vlad\'s own `on give`), the way Inform consults the second\'s life.\n    // Only when there IS a first noun to act on, though: an incomplete "give to\n    // vlad" has nothing being given, so the recipient has nothing to react to\n    // and the action runs its own "give what" default instead of Vlad\'s handler\n    // seeing a nothing noun.\n    if second is not nothing\n        if second is not noun\n            if noun is not nothing\n                let s2 = handler_of(second)\n                if s2 is not nothing\n                    if call_handler(s2, action) is 1\n                        return\n    if here is not nothing\n        let s = handler_of(here)\n        if s is not nothing\n            if call_handler(s, action) is 1\n                return\n    run_free(action)\n\n// The after phase (docs/02 section 9 step 6) lives at dispatch\'s call sites\n// in the loop, not in a helper block, so that games without a single\n// `on after` fold it to NOTHING (a wrapper block would cost its call layer\n// even unused; the doctrine is pay-for-use). The loop runs, after a\n// dispatch that nothing refused, the same chain again under the action\'s\n// synthetic after number: dispatch itself is re-entered with it, the after\n// number passes the meta compare (afters sort below the metas), and react\n// routines answer it only with their `on after` handlers. Grain quips are\n// flavor, not world actions, so a grain turn takes no after pass.\n',
    'english.prelude': '// english.prelude\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// THE ENGLISH LANGUAGE LAYER. Everything about Arcturus that is specific to the\n// English language lives in this one file, so a translation is a fork of this\n// file alone (arcc --eject-language writes it out; docs/02 section 8, docs/05\n// section 6). It has three parts, in order:\n//\n//   1. THE PARSER - the blocks that teach the parser how to read English: which\n//      word is the verb, how a noun phrase is matched, how directions, particles\n//      ("switch OFF"), and two-noun prepositions ("put X ON Y") are recognized,\n//      and the oops correction. The language-agnostic skeleton that drives these\n//      lives in parser.prelude; these are the hooks it calls (the language seam).\n//   2. THE STANDARD VERBS - the vocabulary: every standard verb word and its\n//      grammar (its synonyms, whether it takes a noun or two, its prepositions).\n//      The behaviour behind each action is agnostic and lives in actions.prelude,\n//      keyed by action name; only the words are here.\n//   3. THE MESSAGES - every line the library prints to the player, each an\n//      overridable block, plus the room and content listing that frames them.\n//\n// A verb\'s WORDS are English and live here; a verb\'s LOGIC is not and lives in\n// actions.prelude. Redefine any message block in a story to reskin a line.\n\n// ==========================================================================\n// 1. THE PARSER\n// How English input becomes a verb, its nouns, and a direction.\n// ==========================================================================\n\n// Resolve the verb: the first word, if its dictionary entry is flagged a verb.\n// Returns the action number, or 0 if the first word is not a known verb.\nblock resolve_verb()\n    let d = word_dict(0)\n    if d is nothing\n        return 0\n    let flags = peek_byte(d + 6)\n    if any_tables is 1\n        // A tabled verb (docs/02 section 8c): the data bytes hold its grammar\n        // table\'s address, and the table\'s first byte is the first line\'s\n        // action, the base until the matcher picks the real line (line_act).\n        if flags is 144 or flags is 152\n            let tbl = peek_word(d + 7, 0)\n            return peek_byte(tbl)\n    if flags is 128 or flags is 136\n        let base = peek_byte(d + 7)\n        let p = find_particle\n        if p is not nothing\n            let c = compound(base, p)\n            if c is not nothing\n                return c\n        return base\n    if flags is 64\n        return peek_byte(d + 7)\n    return 0\n\n// A verb particle after the verb (the "off" in "switch off"), as its id.\nblock find_particle()\n    let n = word_count\n    let i = 1\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 32\n                return peek_byte(d + 7)\n        change i to i + 1\n    return nothing\n\n// Combine a base verb with a particle into a multi-word action, only for the\n// verbs that take one: switch and turn with on/off become switch_on/switch_off,\n// take with off becomes take_off, and take with on becomes enter (GET ON THE\n// HORSE, the boarding idiom; remap_action holds the rest of the GET family).\n// Any other base ignores the particle (so "put X on Y" stays a put).\n// Particle ids: on is 1, off is 2.\nblock compound(base, particle)\n    if base is action_id("switch_on")\n        if particle is 1\n            return action_id("switch_on")\n        if particle is 2\n            return action_id("switch_off")\n    if base is action_id("turn")\n        if particle is 1\n            return action_id("switch_on")\n        if particle is 2\n            return action_id("switch_off")\n    if base is action_id("take")\n        if particle is 2\n            return action_id("take_off")\n        if particle is 1\n            return action_id("enter")\n    if base is action_id("transcript")\n        if particle is 1\n            return action_id("transcript")\n        if particle is 2\n            return action_id("transcript_off")\n    if base is action_id("go")\n        // GO ON THE STOOL boards it, like GET ON: the enter action with\n        // the noun the phrase resolves (go carries a noun slot for this).\n        if particle is 1\n            return action_id("enter")\n    return nothing\n\n// The chosen direction\'s property number, from the first direction word typed\n// (a direction word\'s dictionary entry is flagged with bit 6, and byte 2 holds\n// the direction property). Returns nothing if no direction was named.\nblock find_direction()\n    let n = word_count\n    let i = 0\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 64\n                return peek_byte(d + 8)\n        change i to i + 1\n    return nothing\n\n// English reads LOOK <noun> and LOOK AT <noun> as EXAMINE, the usual synonyms:\n// a bare LOOK describes the room, while LOOK CLOAK (or LOOK AT CLOAK) inspects the\n// cloak. parser.prelude calls this once the objects are known; here it remaps the\n// look action to examine when a noun or a scenery grain was named. A language pack\n// may override it for its own conventions.\n//\n// The GET idioms live here too. "get" is a take synonym, but with a direction\n// word it is movement or boarding, the way every classic library reads it:\n// GET IN HAYSTACK and GET INTO the same are an enter; GET OUT OF BED and GET\n// DOWN FROM the table leave (exit); a bare GET IN / GET OUT / GET UP / GET\n// DOWN is a walk (go, the way handles it). GET ON X arrives here already as\n// an enter (the take+on particle, compound below), and GET OFF X arrives as\n// a take_off, which flips to exit when the player is actually in or on X\n// (otherwise it stays the wearing verb: GET OFF HAT). Idioms are language,\n// so each pack writes its own; these are English\'s.\nblock remap_action(act)\n    if act is action_id("look")\n        if noun is not nothing\n            return action_id("examine")\n        if grain is not 0\n            return action_id("examine")\n    if act is action_id("take")\n        if way is not nothing\n            if noun is nothing\n                // A bare GET OUT / GET UP / GET DOWN while inside or on\n                // something means getting off it (exit), not a walk: GET\n                // OUT in a crate must not answer "no exit that way".\n                // Folds away with nothing to be inside (any_enterable).\n                if any_enterable is 1\n                    if parent_of(player) is not here\n                        return action_id("exit")\n                return action_id("go")\n            if way is out\n                return action_id("exit")\n            if way is down\n                return action_id("exit")\n            return action_id("enter")\n    if act is action_id("take_off")\n        if noun is not nothing\n            if player in noun\n                return action_id("exit")\n    if act is action_id("go")\n        // GO IN THE CRATE, GO INTO: the in-direction plus a named thing is\n        // boarding, the same reading the GET family gets above.\n        if way is in\n            if noun is not nothing\n                return action_id("enter")\n    return act\n\n// Does the object\'s vocabulary include this dictionary word?\nblock has_word(obj, target)\n    let addr = words_addr(obj)\n    if addr is nothing\n        return 0\n    let count = words_count(obj)\n    let i = 0\n    while i < count\n        if peek_word(addr, i) is target\n            return 1\n        change i to i + 1\n    return 0\n\n// Can the player see and reach what is inside this object? A supporter\'s\n// contents are always in view. A container\'s are in view when it is open, when\n// it is `clear` (see-through), or when it is not `openable` at all: a bowl or a\n// basket has no lid to shut, so its contents are always reachable. This is the\n// scope rule the noun matcher follows.\nblock see_into(obj)\n    if obj is supporter\n        return 1\n    if obj is container\n        if obj is open\n            return 1\n        if obj is clear\n            return 1\n        if obj is not openable\n            return 1\n    return 0\n\n// A closed opaque container: we cannot see into it. The inverse of see_into for\n// a container: open, clear, or lidless (not openable) all mean it is not shut.\nblock shut_holds(obj)\n    if obj is open\n        return 0\n    if obj is clear\n        return 0\n    if obj is not openable\n        return 0\n    return 1\n\n// Among the closed opaque containers directly within `where`, a known (seen)\n// content matching the word. Records the blocking container in shut_in.\nblock shut_search(where, target)\n    for each obj in where\n        if obj is not hidden\n            if obj is container\n                if shut_holds(obj)\n                    let known = shut_match(obj, target)\n                    if known is not nothing\n                        change shut_in to obj\n                        return known\n    return nothing\n\nblock shut_match(holder, target)\n    for each x in holder\n        if x is not hidden\n            if x is seen\n                if has_word(x, target)\n                    return x\n    return nothing\n\n// Match a noun: the typed words after the verb, as one phrase, through the\n// scoring matcher (parser.prelude match_phrase): the in-scope object matching\n// the most typed words wins, a tie is a genuine ambiguity (parse_fault 3).\nblock match_noun()\n    return match_first_phrase\n\n// Resolve the command\'s objects into the noun (and, for a two-noun verb like\n// "put noun on noun", the second). The verb\'s dictionary entry carries its noun\n// arity in data byte 2: 0 intransitive, 1 one noun, 2 two nouns. An intransitive\n// verb handed extra words (jump n, look cloak) is a command the grammar cannot\n// account for, so it sets parse_fault 2 and the loop answers msg_extra_words\n// rather than silently dropping the words.\nblock resolve_objects()\n    change noun to nothing\n    change second to nothing\n    change grain to 0\n    change parse_fault to 0\n    change two_reverse to 0\n    if any_tables is 1\n        change line_act to 0\n    let d = word_dict(0)\n    if d is not nothing\n        if any_tables is 1\n            // A tabled verb: the positional matcher owns the whole command,\n            // slots, faults, scenery fallback and all (docs/02 section 8c).\n            if peek_byte(d + 6) is 144 or peek_byte(d + 6) is 152\n                let tbl = peek_word(d + 7, 0)\n                grammar_match(tbl)\n                return 1\n        if peek_byte(d + 6) is 128 or peek_byte(d + 6) is 136\n            let arity = peek_byte(d + 8)\n            let va = peek_byte(d + 7)\n            // A reverse-capable two-noun verb (give/show) is encoded as 6 (2 plus\n            // bit 2): the same two-noun path, but resolve_two_nouns may split two\n            // adjacent nouns and swap them (GIVE BOB COIN) when no preposition\n            // separates them.\n            if arity is 6\n                change two_reverse to 1\n                change arity to 2\n            if arity is 2\n                resolve_two_nouns\n                return 1\n            if arity is 0\n                // oops takes a trailing correction word, not a noun; never an error.\n                if va is not action_id("oops")\n                    if has_extra_words(va) is 1\n                        change parse_fault to 2\n                return 1\n    change noun to match_noun\n    // An ambiguity fault (3) stands: falling through to the grain and\n    // unseen checks would overwrite the honest "which do you mean".\n    if parse_fault is not 0\n        return 1\n    // A pending plural sweep ("take coins", THEM) binds per object later.\n    if any_plurals is 1\n        if plural_go is not 0\n            return 1\n    if noun is nothing\n        change noun to reach_unscoped\n    if noun is nothing\n        change grain to find_scenery\n        if grain is 0\n            change parse_fault to named_unseen\n            if parse_fault is 0\n                change unknown_at to first_unknown(1, word_count)\n                if unknown_at is not 0\n                    change parse_fault to 4\n    return 1\n\n// A hook for reaching an object ordinary scope could not: nothing by default, so\n// a word that names something out of view stays unresolved (and the turn answers\n// "you can\'t see that"). The debug granule overrides this to match the word\n// against every object, so its fetch/warp/inspect verbs reach anything.\nblock reach_unscoped()\n    return nothing\n\n// Did the player name an object word that nothing in scope answered to? Every\n// unflagged dictionary word is object vocabulary (verbs, directions, particles,\n// prepositions, and grain words all carry a flag byte), so an unflagged word that\n// the noun match did not consume names a thing that simply is not here.\nblock named_unseen()\n    return phrase_named(1, word_count)\n\n// For an intransitive verb (no noun slot), is there a word after it the grammar\n// cannot use? Returns 1 the moment it finds one. A direction after `go` is the\n// exception: movement consumes it through `way`, so "go north" is whole, while\n// "jump north" or "look cloak" carries a word too many.\nblock has_extra_words(act)\n    let n = word_count\n    let i = 1\n    while i < n\n        let keep = 0\n        let d = word_dict(i)\n        if act is action_id("go")\n            if d is not nothing\n                if peek_byte(d + 6) is 64\n                    change keep to 1\n        // A particle that compounds with this verb is part of the verb, not\n        // an extra word (TRANSCRIPT ON has no noun slot to carry the "on");\n        // a particle no compound claims still refuses ("jump on").\n        if keep is 0\n            if d is not nothing\n                if peek_byte(d + 6) is 32\n                    if compound(act, peek_byte(d + 7)) is not nothing\n                        change keep to 1\n        if keep is 0\n            return 1\n        change i to i + 1\n    return 0\n\n// A scenery grain word (flagged bit 4) whose owner is in scope; returns the\n// grain id (so dispatch can route to its response or the scenery default).\nblock find_scenery()\n    // The walker folds away entirely (any_grains is a compile-time flag) in a\n    // game that declares no grains, so unused scenery costs nothing.\n    if any_grains is 1\n        let n = word_count\n        let i = 1\n        while i < n\n            let d = word_dict(i)\n            if d is not nothing\n                if peek_byte(d + 6) is 16\n                    // The word\'s grain chain: (grain id, owner) pairs, zero-\n                    // ended. The same word can be scenery in several rooms;\n                    // answer with the grain whose owner is in scope here.\n                    let c = peek_word(d + 7, 0)\n                    let j = 0\n                    let g = peek_word(c, j)\n                    while g is not 0\n                        if in_scope(peek_word(c, j + 1))\n                            return g\n                        change j to j + 2\n                        change g to peek_word(c, j)\n            change i to i + 1\n    return 0\n\n// Is this dictionary word a phrase boundary rather than a noun word? Any flagged\n// word qualifies: the grammar preposition (bit 3), but also a particle or a\n// direction word (on/in), which separate the two noun phrases just as well.\nblock is_separator(target)\n    // Only the words that JOIN two nouns split the phrases: a grammar\n    // preposition (flag 8), and the direction and particle words that\n    // double as one ("put coin IN box", "gib X AN Y", flags 64 and 32).\n    // Anything else is content: a pronoun binds as a noun, an article is\n    // skipped, and a noun that moonlights as a verb elsewhere ("pick the\n    // LOCK", "PAT the person") must not end the phrase it stars in.\n    if peek_byte(target + 6) is 8 or peek_byte(target + 6) is 136\n        return 1\n    if peek_byte(target + 6) is 64\n        return 1\n    if peek_byte(target + 6) is 32\n        return 1\n    return 0\n\n// Bind the two noun slots by position, the way the grammar reads them: the words\n// before the preposition are the first noun phrase, the words after it the\n// second. The boundary is the first separator word (the "to" of "give X to Y",\n// the "on" of "put X on Y"); each phrase resolves through the scoring matcher,\n// so adjectives narrow within a slot and a tie is a genuine ambiguity. Binding\n// by position, not by first-in-scope-wins, is what lets an out-of-scope first\n// noun stay unresolved (so the verb reports "you can\'t see that") instead of\n// letting the recipient slide into its slot.\nblock resolve_two_nouns()\n    let n = word_count\n    let b = 0\n    let i = 1\n    while i < n\n        if b is 0\n            let d = word_dict(i)\n            if d is not nothing\n                if is_separator(d)\n                    change b to i\n        change i to i + 1\n    // The reversed dative (GIVE/SHOW BOB COIN): two adjacent nouns, no\n    // preposition to split on. Probe each boundary for the first where BOTH\n    // sides name a single object, then swap the roles (the first object is the\n    // recipient, the second the thing). No clean split falls through to the\n    // ordinary single-phrase path, which asks "which do you mean", as before.\n    if two_reverse is 1\n        if b is 0\n            let sp = 2\n            while sp < n\n                let recip = probe_noun(1, sp)\n                if recip is not nothing\n                    let gift = probe_noun(sp, n)\n                    if gift is not nothing\n                        change second to recip\n                        change noun to gift\n                        return 1\n                change sp to sp + 1\n    if b is 0\n        change b to n\n    change noun to match_phrase(1, b, 0)\n    if parse_fault is not 0\n        return 1\n    // The first noun of a two-noun verb is required. If the player typed\n    // ANYTHING for it that did not resolve, a known object out of scope, an\n    // unknown word, or a stray non-noun, it named nothing here: fault so the\n    // turn is rejected rather than run, or dispatched to the recipient\'s own\n    // handler, with no noun (a custom `on give` reading the noun would fault).\n    // A non-empty first-noun slot is `b > 1`; an EMPTY one ("give to bob", b is\n    // 1) is left to the action, which asks "give what".\n    if noun is nothing\n        if b > 1\n            change parse_fault to noun_fault(1, b)\n            return 1\n    if b < n\n        change second to match_phrase(b + 1, n, 0)\n        if parse_fault is not 0\n            return 1\n        // Likewise the recipient: a named-but-unresolved second noun faults,\n        // an empty one (nothing after the preposition) goes to the action.\n        if second is nothing\n            if b + 1 < n\n                change parse_fault to noun_fault(b + 1, n)\n    return 1\n\n// Remember the command just parsed so a following "oops" can correct it: find the\n// first unrecognized word (one with no dictionary entry), verb or noun, and if\n// there is one, snapshot the parse buffer and note that word\'s index. With no\n// unknown word, clear the flag, so "oops" after an understood command has nothing\n// to fix. Scanning from word 0 means a mistyped verb is correctable too, but the\n// loop must call note_oops even when the verb did not parse (see run_game).\nblock note_oops()\n    change oops_ready to 0\n    let n = word_count\n    let i = 0\n    while i < n\n        if word_dict(i) is nothing\n            change oops_word to i\n            change oops_ready to 1\n            copy_bytes(parse_addr, oops_addr, 2 + 4 * n)\n            return 0\n        change i to i + 1\n    return 0\n\n// Correct the previous command\'s unrecognized word with the word typed after\n// "oops", then re-resolve the patched command and return its action (0 if there\n// is nothing to correct or the fix does not parse). run_turn dispatches the\n// result as an ordinary turn.\nblock fix_oops()\n    if oops_ready is 0\n        msg_cant_oops\n        return 0\n    let fix = word_dict(1)\n    if fix is nothing\n        msg_cant_oops\n        return 0\n    // Restore the saved command, then overwrite the bad word\'s dictionary slot\n    // (the two-byte entry at parse offset 2 + 4*index) with the correction.\n    copy_bytes(oops_addr, parse_addr, 2 + 4 * peek_byte(oops_addr + 1))\n    poke_word(parse_addr, 1 + 2 * oops_word, fix)\n    let act = resolve_verb\n    if act is 0\n        return 0\n    change tie_want to 1\n    if act is action_id("take")\n        change tie_want to 0\n    change way to find_direction\n    resolve_objects\n    if parse_fault is 1\n        msg_cant_see\n        return 0\n    if parse_fault is 3\n        msg_be_specific\n        return 0\n    if any_tables is 1\n        if line_act is not 0\n            change act to line_act\n    return act\n\n// ==========================================================================\n// 2. THE STANDARD VERBS\n// The verb vocabulary and grammar; the logic is in actions.prelude.\n// ==========================================================================\n\n// Bare LOOK describes the room; LOOK <noun> and LOOK AT <noun> are the usual\n// synonyms for EXAMINE, so the noun forms are accepted here and remapped to the\n// examine action once the noun is known (english.prelude, remap_action).\nverb "look", "l"\n    look\n    look noun\n    look at noun\n\n// Movement. The parser sets `way` to the chosen direction\'s property (a bare\n// direction word, or go + a direction). A room can override one direction with\n// its own `on go <direction>`, which runs first and consumes the action; this\n// default handles the rest: follow a static exit, or refuse the move.\nverb "go", "walk", "run"\n    go\n    go noun\n\n// The direction words: each maps its vocabulary to a fixed direction property.\n// This is the English set; a language pack redeclares these with its own words\n// (direction north "norte", "n"). The property names never change.\ndirection north     "north", "n"\ndirection south     "south", "s"\ndirection east      "east", "e"\ndirection west      "west", "w"\ndirection northeast "northeast", "ne"\ndirection northwest "northwest", "nw"\ndirection southeast "southeast", "se"\ndirection southwest "southwest", "sw"\ndirection up        "up", "u"\ndirection down      "down", "d"\ndirection in        "in", "into"\ndirection out       "out"\n\nverb "take", "get", "carry"\n    take noun\n\nverb "drop"\n    drop noun\n\nverb "examine", "x"\n    examine noun\n\n// Meta verbs. These report on or steer the session rather than act in the world,\n// so each sets meta_turn: the loop then skips the per-turn pulse and the turn\n// count (a cancelled quit must not cost a turn). quit and restart confirm first.\n// Override on quit for a custom send-off, reusing confirm_quit and do_quit.\nverb "quit", "q"\n    quit\n\nverb "score"\n    score\n\nverb "restart"\n    restart\n\n// Saving and restoring. do_save returns 1 when the save is written; a successful\n// restore does not return into the restore handler at all, it resumes at the\n// do_save point with result 2 (so the save handler redescribes the room after a\n// restore). The restore handler is reached only when the restore fails.\nverb "save"\n    save\n\nverb "restore", "load"\n    restore\n\n// The transcript: TRANSCRIPT (or SCRIPT) starts one, TRANSCRIPT OFF (or\n// UNSCRIPT, the Infocom word) ends it. The on/off particles route through\n// compound below, like switch; the interpreter owns the file.\nverb "transcript", "script"\n    transcript\n    transcript_off\n\nverb "unscript"\n    transcript_off\n\n// undo and again are intercepted by the turn loop (run_turn) before dispatch, so\n// they need no handler here; the declarations just register the verbs and their\n// actions. again replays the previous non-meta command.\nverb "undo"\n    undo\n\nverb "again", "g"\n    again\n\nverb "oops"\n    oops\n\n// The magic word. Not a meta verb (it is a normal, if fruitless, action), so it\n// takes a turn like any other; an author can override it for a real effect.\nverb "xyzzy"\n    xyzzy\n\nverb "inventory", "i", "inv"\n    inventory\n\nverb "switch"\n    switch_on noun\n    switch_off noun\n\n// Verb particles: the parser combines a base verb with a following particle word\n// (switch + on -> switch_on, take + off -> take_off), wherever it appears in the\n// command ("switch the lamp on" or "switch on the lamp"). The words are declared\n// here in the language layer, not in the compiler, so a pack localizes them; the\n// role is `on` or `off`. English has just the two.\nparticle on  "on"\nparticle off "off"\n\n// The chain words (docs/02 section 8b): each ends one command and starts the\n// next on the same line ("take the lamp and open the door then go north",\n// "drop cloak, hang cloak on hook"). The comma tokenizes as its own word, so\n// it chains with or without spaces around it.\nchain ",", "and", "then"\n\n// The noise words: the articles and fillers the parser knows but ignores.\n// Known is the point: a noun-list segment may contain them ("take lamp and\n// the box"), while a genuinely unknown word refuses the borrow (8b).\nnoise "the", "a", "an", "some", "my"\n\n// The pronouns (docs/02 section 8a): "it" for the last thing, "him"/"her" for\n// the last character, by its gender. The words map to canonical roles; the\n// note_pronouns rule below decides which role a resolved noun fills.\n// The player\'s own object: the standard self-words every game answers to\n// ("x me"), a printable name, and the proper-name flag so no article sticks\n// to it. A game ADDS its own with player.words (they accumulate) and sets its\n// own desc, plain or computed (docs/01 section 5a).\nplayer.words me, myself, self, yourself, you\nplayer.name "yourself"\nplayer.named\n\npronoun it  "it"\npronoun him "him"\npronoun her "her"\n\n// Which pronoun a just-resolved noun becomes: English splits by animacy (a\n// character is him or her, everything else is it), and by the feminine\n// attribute within characters. The skeleton calls this after each command.\nblock note_pronouns(obj)\n    if obj is animate\n        if obj is feminine\n            change pron_her to obj\n        else\n            change pron_him to obj\n        return 0\n    change pron_it to obj\n\nverb "wear", "don"\n    wear noun\n\nverb "remove", "doff", "disrobe", "shed"\n    take_off noun\n\nverb "put", "place"\n    put noun on noun\n    put noun in noun\n\nverb "insert"\n    insert noun in noun\n\nverb "open", "uncover", "unwrap"\n    open noun with noun\n    open noun\n\nverb "close", "shut", "cover"\n    close noun\n\nverb "lock"\n    lock noun with noun\n    lock noun\n\nverb "unlock"\n    unlock noun with noun\n    unlock noun\n\nverb "enter", "board"\n    enter noun\n\nverb "exit", "leave"\n    exit\n\nverb "give", "offer", "feed", "pay"\n    give noun to noun\n    give noun noun reverse\n\nverb "show", "display", "present"\n    show noun to noun\n    show noun noun reverse\n\nverb "touch", "feel", "pat"\n    touch noun\n\nverb "smell", "sniff"\n    smell noun\n\nverb "taste", "lick"\n    taste noun\n\nverb "listen", "hear"\n    listen\n    listen noun\n\nverb "eat"\n    eat noun\n\nverb "drink", "sip", "swallow"\n    drink\n    drink noun\n\nverb "attack", "hit", "break", "kill", "fight", "smash"\n    attack noun\n\nverb "kiss", "hug", "embrace"\n    kiss noun\n\nverb "push", "press", "shove"\n    push noun\n\nverb "pull", "drag", "yank"\n    pull noun\n\nverb "turn", "rotate", "twist", "screw", "unscrew"\n    turn noun\n\nverb "climb", "scale"\n    climb noun\n\nverb "read"\n    examine noun\n\nverb "talk", "greet"\n    talk noun\n\nverb "ask", "interrogate", "query"\n    ask noun\n    ask noun about\n    ask noun for\n\nverb "tell", "inform"\n    tell noun\n    tell noun about\n\nverb "answer", "respond"\n    answer noun\n\nverb "jump", "hop"\n    jump\n\nverb "wait", "z"\n    wait\n\nverb "sing"\n    sing\n\n// ==========================================================================\n// 3. THE MESSAGES\n// Every line shown to the player, and the room and content listing.\n// ==========================================================================\n\n// Articles. The compiler lowers ${the noun} / ${a noun} to a call to one of these\n// with the object and a capitalize flag (1 for ${The} / ${A}), so the article\n// words live here in the language layer, not in the compiler. A translation\n// redefines these two blocks for its own articles. English: "the", and "a" or\n// "an" chosen by the object\'s `an` attribute (the compiler derives that from the\n// name); a `named` object (Linda, Excalibur) takes no article at all. The named\n// check folds away in a game with no named objects (any_named).\nblock art_the(obj, cap)\n    // Total, like the containment test: an unresolved noun prints\n    // as the word, never an illegal print_obj 0 (docs/02 s.12).\n    if obj is nothing\n        show("nothing")\n        return\n\n    if any_named is 1\n        if obj is named\n            print_name(obj)\n            return\n    // A hand-set article wins over derivation (docs/01 section 16): las\n    // tijeras, el agua. Printed as stored, so keep it lowercase and let such\n    // objects sit mid-sentence.\n    if article_addr(obj) is not 0\n        show("${obj.article}")\n        show(" ")\n        print_name(obj)\n        return\n    if cap is 1\n        show("The ")\n    else\n        show("the ")\n    print_name(obj)\n\nblock art_a(obj, cap)\n    // Total, like the containment test: an unresolved noun prints\n    // as the word, never an illegal print_obj 0 (docs/02 s.12).\n    if obj is nothing\n        show("nothing")\n        return\n\n    if any_named is 1\n        if obj is named\n            print_name(obj)\n            return\n    // A hand-set indefinite wins over derivation: unas tijeras, some water.\n    if indefinite_addr(obj) is not 0\n        show("${obj.indefinite}")\n        show(" ")\n        print_name(obj)\n        return\n    // A pluribus object has no singular article: "some scissors" (the\n    // hand-set indefinite above still wins; folds away unmarked).\n    if any_pluribus is 1\n        if obj is pluribus\n            if cap is 1\n                show("Some ")\n            else\n                show("some ")\n            print_name(obj)\n            return\n    if obj is an\n        if cap is 1\n            show("An ")\n        else\n            show("an ")\n    else\n        if cap is 1\n            show("A ")\n        else\n            show("a ")\n    print_name(obj)\n\n// The number-agreeing copula (docs/01 section 16): ${is x} prints "is" or\n// "are" by the object\'s pluribus attribute, so one sentence template serves\n// the scissors and the lamp alike. cap 1 is ${Is x}. In an unmarked game\n// the plural branch folds away and this prints "is", period.\nblock art_is(obj, cap)\n    if any_pluribus is 1\n        if obj is pluribus\n            if cap is 1\n                show("Are")\n            else\n                show("are")\n            return 0\n    if cap is 1\n        show("Is")\n    else\n        show("is")\n    return 0\n\n// The banner words. The compiler assembles the banner (title, headline,\n// author, the release line), but the words BETWEEN the parts are language:\n// line_by prints the connector between headline and author, banner_headline\n// the default headline when a game sets none. A pack localizes both; a story\n// can override either for a custom banner voice.\nblock line_by()\n    show(" by ")\n\n// The nested-location suffix on the room title and the status bar: the\n// player stands on a supporter or in a container, and the header says so,\n// "Crypt (on the altar)". Supporters take "on", everything else "in".\nblock line_nested(obj)\n    if obj is supporter\n        show(" (on ")\n    else\n        show(" (in ")\n    art_the(obj, 0)\n    show(")")\n\nblock banner_headline()\n    show("An Interactive Fiction")\n\n// The input prompt. It requests a paragraph break (one blank line before it,\n// collapsed with any the turn already pending) rather than forcing its own, so\n// responses are separated from the next prompt by exactly one blank line.\nblock prompt()\n    par\n    show(">")\n\n// What of a holder\'s contents should be listed: not hidden or concealed, and\n// either the holder shows its contents (a supporter, or an open or clear\n// container) or the player already knows the item is there (it is `seen`). That\n// last case is the memory - a closed opaque box still lists what you have seen.\nblock content_listable(holder, x)\n    // The player never lists as a holder\'s contents ("an altar (contains\n    // yourself)"); possible only where something is enterable, so it folds.\n    if any_enterable is 1\n        if x is player\n            return 0\n    // A component is part of the holder, not carried contents: the machine\n    // never lists its own levers. Folds away without components.\n    if any_components is 1\n        if x is component\n            return 0\n    if x is hidden\n        return 0\n    if x is concealed\n        return 0\n    // Anything the player can see into (a supporter, or an open, clear, or\n    // lidless container) lists all its contents; a closed opaque container lists\n    // only what the player already knows is inside (the knowledge model).\n    if see_into(holder)\n        return 1\n    if x is seen\n        return 1\n    return 0\n\n// One scenery holder\'s paragraph (constant scenery_contents = 1): what\n// sits on or in it, the knowledge model deciding per item. Prints\n// nothing when the holder holds nothing tellable.\nblock scenery_holder_line(obj)\n    if obj is not container\n        if obj is not supporter\n            return 0\n    let total = 0\n    for each x in obj\n        if content_listable(obj, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    par\n    if obj is supporter\n        show("On ")\n    else\n        show("In ")\n    art_the(obj, 0)\n    show(" you can see ")\n    let shown = 0\n    for each x in obj\n        if content_listable(obj, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" and ")\n                else\n                    show(", ")\n            art_a(x, 0)\n            now x is seen\n            change shown to shown + 1\n    say "."\n\n// the contents the player can see or remembers and marking each as seen. Prints\n// nothing when there is nothing to show. One level deep, by design.\nblock list_contents(holder)\n    if holder is supporter\n        list_contents_run(holder)\n        return 0\n    if holder is container\n        list_contents_run(holder)\n    return 0\n\nblock list_contents_run(holder)\n    let total = 0\n    for each x in holder\n        if content_listable(holder, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    show(" (contains ")\n    let shown = 0\n    for each x in holder\n        if content_listable(holder, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" and ")\n                else\n                    show(", ")\n            show("${a x}")\n            now x is seen\n            change shown to shown + 1\n    show(")")\n    return 0\n\n// After a container is opened, name what is revealed inside (marking it seen), so\n// opening a box shows its contents at once rather than only on the next look.\nblock reveal_contents(holder)\n    let total = 0\n    for each x in holder\n        if content_listable(holder, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    show("Inside you find ")\n    let shown = 0\n    for each x in holder\n        if content_listable(holder, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" and ")\n                else\n                    show(", ")\n            show("${a x}")\n            now x is seen\n            change shown to shown + 1\n    say "."\n\n// One line of a room\'s contents listing, naming a container\'s or supporter\'s\n// contents in passing.\nblock list_item(obj)\n    show("You can see ")\n    show("${a obj}")\n    // A closed openable says so (Pablo Martinez\'s suggestion, the PunyInform\n    // qualifier): the one state a player cannot read off the listing.\n    if obj is openable\n        if obj is not open\n            show(" (closed)")\n    show_tag(obj)\n    list_contents(obj)\n    say " here."\n\n// Parser.\n// The player typed a word the story\'s dictionary does not know at\n// all: name it (spelled back from the text buffer), so a typo is\n// told apart from a real thing that is not here.\nblock msg_unknown_word()\n    show("This story doesn\'t know the word \\"")\n    let p = word_pos(unknown_at) - 2\n    let n = word_len(unknown_at)\n    let i = 0\n    while i < n\n        show_char(text_char(p + i))\n        change i to i + 1\n    say "\\"."\n\n// A bare verb ("take", "open") asks its question, echoing the verb as\n// typed ("Take what?"), the way msg_unknown_word spells a typo back. The\n// first letter is capitalized when it is plain a-z; an accented initial\n// is echoed as typed (the case tables stop at ASCII, and it stays honest).\nblock msg_noun_missing()\n    let p = word_pos(0) - 2\n    let n = word_len(0)\n    let i = 0\n    while i < n\n        let c = text_char(p + i)\n        if i is 0\n            if c >= 97\n                if c <= 122\n                    change c to c - 32\n        show_char(c)\n        change i to i + 1\n    say " what?"\n\n// The beyond refusal (docs/01, beyond): visible, examinable, and the\n// hand does not get there. Takes the object (noun or second).\nblock msg_beyond(obj)\n    if any_pluribus is 1\n        say "${The obj} ${is obj} beyond your reach."\n        return 0\n    say "${The obj} is beyond your reach."\n\nblock msg_cant_see()\n    say "You see nothing of the sort here."\n\nblock msg_open_first()\n    say "You\'ll have to open ${the shut_in} first."\n\nblock msg_no_it()\n    say "You\'ll have to say what you mean."\n\nblock msg_be_specific()\n    say "You\'ll have to be more specific."\n\n// The disambiguation question (docs/02 section 8): the framing around the\n// candidate list the parser prints ("Which do you mean, the gold coin or\n// the silver coin?"). line_which_item prints one candidate; a language\n// declines it as its grammar needs (German prints the accusative).\nblock line_which_open()\n    show("Which do you mean, ")\n\nblock line_which_or()\n    show(" or ")\n\nblock line_which_item(obj)\n    show("${the obj}")\n\nblock line_which_end()\n    say "?"\n\nblock msg_nothing_again()\n    say "There\'s nothing to repeat."\n\nblock msg_only_animate()\n    say "If you continue talking to objects, it might be time for another therapy session."\n\n// Conversation lines. The `you` and `reply` topic sugar auto-quotes and\n// attributes a line of dialogue; the compiler supplies the line\'s text and\n// calls these for the framing. The speaker label, the separator, and the\n// quotation marks all live here, so a story can restyle them and a language\n// pack can translate them (German low-high quotes, French guillemets, a\n// different speaker tag). line_reply receives the speaking person; ${The x}\n// prints a named person bare (Linda) and others with the article (The guard).\nblock line_you()\n    show("You: \\"")\n\nblock line_reply(speaker)\n    show("${The speaker}: \\"")\n\nblock line_end()\n    say "\\""\n\n// Append " (contains a, b and c)" to a container or supporter just named, listing\n// Conversation menu framing (the conversations granule, docs/05). Held in the\n// language layer so a pack translates it; every block here is dropped by dead-code\n// elimination in a game that does not summon the menu.\nblock line_talk_header(who)\n    show("Talk to ${the who} about:")\n\nblock line_talk_prompt()\n    show("Press a number to ask, or 0 to leave.")\n\nblock msg_no_topics()\n    say "You can\'t think of anything worth raising right now."\n\nblock msg_talk_over()\n    say "You let the conversation rest there."\n\n// The status line\'s score side (the statusline granule): the score and the move\n// count, right-aligned, in the language\'s own words and widths. status_digits is a\n// core helper, so this compiles whether or not the granule is summoned.\nblock line_status_score(w)\n    // A game that scores nothing shows only the move count; the score side\n    // would be a permanent "Score: 0". The fold decides at compile time.\n    if any_awards is 0\n        set_cursor(1, w - 8 - status_digits(turns))\n        show("Moves: ")\n        show(turns)\n        return 0\n    if w < 54\n        set_cursor(1, w - 8 - status_digits(score) - status_digits(turns))\n        show("Score: ")\n        show(score)\n        show("/")\n        show(turns)\n    else\n        set_cursor(1, w - 17 - status_digits(score) - status_digits(turns))\n        show("Score: ")\n        show(score)\n        show("   Moves: ")\n        show(turns)\n\n// Room and light.\nblock msg_dark_room()\n    say "Pitch black. Even your hands have gone missing."\n\nblock msg_too_dark()\n    say "It\'s too dark to make anything out."\n\n// Movement.\nblock msg_cant_go()\n    say "There\'s no exit in that direction."\n\nblock msg_no_direction()\n    say "Which way?"\n\nblock msg_cant_enter()\n    say "You can\'t get inside ${the noun}."\n\nblock msg_already_there()\n    say "You\'re already there."\n\nblock msg_not_inside()\n    say "You aren\'t inside anything to leave."\n\n// Boarding and leaving, worded by the world model: on a supporter, in a\n// container (the choice is made in board_report / leave_report).\nblock msg_get_on()\n    say "You get on ${the noun}."\n\nblock msg_get_in()\n    say "You get into ${the noun}."\n\nblock msg_get_off()\n    say "You get off ${the noun}."\n\nblock msg_get_out()\n    say "You get out of ${the noun}."\n\nblock msg_cant_climb()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} aren\'t for climbing."\n            return 0\n    say "${The noun} isn\'t for climbing."\n\n// Sensory.\n// Examining yourself with no player.desc set: the player deserves better\n// than the object fallback.\nblock msg_examine_self()\n    say "Are we going to admire ourselves for a while or do we play an\n         adventure game?"\n\nblock msg_nothing_special()\n    say "Nothing about ${the noun} rewards a closer look."\n\nblock msg_touch()\n    say "You touch ${the noun}. You feel nothing that your eyes didn\'t already see."\n\nblock msg_smell()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} smell about as you\'d expect."\n            return 0\n    say "${The noun} smells about as you\'d expect."\n\nblock msg_listen()\n    say "You listen. Nothing answers."\n\nblock msg_taste()\n    say "Best not."\n\n// Carrying and giving.\nblock msg_taken()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "Got them."\n            return 0\n    say "Got it."\n\nblock msg_fixed()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} stay exactly where they are."\n            return 0\n    say "${The noun} stays exactly where it is."\n\nblock msg_animate_refuses()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} have other ideas."\n            return 0\n    say "${The noun} has other ideas."\n\nblock msg_have_it()\n    say "You already have ${the noun}."\n\nblock msg_take_self()\n    say "You keep a firm grip on yourself."\n\n// Taking a component (a lever in a machine): the part stays on its whole.\n// Leaving a named thing the player is not actually in (exit noun).\nblock msg_not_in_that()\n    say "You aren\'t in that."\n\nblock msg_part_of()\n    let p = parent_of(noun)\n    show("That\'s part of ")\n    art_the(p, 0)\n    say "."\n\nblock msg_dropped()\n    // Nested, the message says where it lands (the Hibernated 2 manner):\n    // onto the altar, into the crate. Folds away without enterables.\n    if any_enterable is 1\n        if parent_of(player) is not here\n            // The plural wording is a full duplicate under the fold, so an\n            // unmarked game keeps the original strings, byte for byte.\n            if any_pluribus is 1\n                if noun is pluribus\n                    if parent_of(player) is supporter\n                        show("Down they go, onto ")\n                    else\n                        show("Down they go, into ")\n                    art_the(parent_of(player), 0)\n                    say "."\n                    return 0\n            if parent_of(player) is supporter\n                show("Down it goes, onto ")\n            else\n                show("Down it goes, into ")\n            art_the(parent_of(player), 0)\n            say "."\n            return 0\n    if any_pluribus is 1\n        if noun is pluribus\n            say "Down they go."\n            return 0\n    say "Down it goes."\n\nblock msg_not_holding()\n    say "You aren\'t carrying ${the noun}."\n\nblock msg_done()\n    say "Done."\n\nblock msg_put_where()\n    say "On what, or in what?"\n\nblock msg_cant_put()\n    say "${The second} won\'t hold it."\n\nblock msg_closed()\n    if any_pluribus is 1\n        say "${The second} ${is second} shut."\n        return 0\n    say "${The second} is shut."\n\nblock msg_to_whom()\n    say "To whom?"\n\nblock msg_give()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} don\'t want ${the noun}. Outrageous."\n            return 0\n    say "${The second} doesn\'t want ${the noun}. Outrageous."\n\nblock msg_show()\n    if any_pluribus is 1\n        say "Seems like ${the second} ${is second} not really into that."\n        return 0\n    say "Seems like ${the second} is not really into that."\n\n// Wearing.\nblock msg_worn()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "On they go."\n            return 0\n    say "On it goes."\n\nblock msg_already_worn()\n    say "You\'re already wearing ${the noun}."\n\nblock msg_cant_wear()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} were never meant to be worn."\n            return 0\n    say "${The noun} was never meant to be worn."\n\nblock msg_removed()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "Off they come."\n            return 0\n    say "Off it comes."\n\nblock msg_not_worn()\n    say "You aren\'t wearing ${the noun}."\n\n// Doors, containers, locks.\nblock msg_opened()\n    say "Open."\n\nblock msg_already_open()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} already open."\n        return 0\n    say "${The noun} is already open."\n\nblock msg_cant_open()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} don\'t open."\n            return 0\n    say "${The noun} doesn\'t open."\n\nblock msg_open_locked()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} locked."\n        return 0\n    say "${The noun} is locked."\n\nblock msg_door_locked(d)\n    if any_pluribus is 1\n        say "${The d} ${is d} locked."\n        return 0\n    say "${The d} is locked."\n\nblock msg_door_shut(d)\n    if any_pluribus is 1\n        if d is pluribus\n            say "${The d} are shut. You open them first."\n            return 0\n    say "${The d} is shut. You open it first."\n\nblock msg_closed_it()\n    say "Shut."\n\nblock msg_already_shut()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} already shut."\n        return 0\n    say "${The noun} is already shut."\n\nblock msg_cant_close()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} don\'t close."\n            return 0\n    say "${The noun} doesn\'t close."\n\nblock msg_locked()\n    say "Locked."\n\n// A LOCK on something already locked: distinct from the success line above.\nblock msg_already_locked()\n    say "Already locked. Thoroughly. Smugly, even."\n\nblock msg_cant_lock()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} don\'t lock, and show no ambition to start."\n            return 0\n    say "${The noun} doesn\'t lock, and shows no ambition to start."\n\nblock msg_close_first()\n    say "You\'d have to close ${the noun} first; locking an open thing fools no one."\n\n// Deliberately unnamed: a bare UNLOCK on an undiscovered lock must not spoil\n// what opens it. Mechanism-agnostic: the opener may be a key, a card, a code.\nblock msg_no_key()\n    say "You don\'t have whatever ${the noun} wants, and looking hopeful isn\'t helping."\n\nblock msg_wrong_key()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} are entirely unimpressed by ${the second}."\n            return 0\n    say "${The noun} is entirely unimpressed by ${the second}."\n\nblock msg_unlocked()\n    say "Unlocked."\n\n// A UNLOCK on something with no lock at all: the verb just opens it.\nblock msg_cant_unlock()\n    say "Nothing about ${the noun} needs unlocking, so you just open it."\n\n// A UNLOCK on a lockable thing that is already unlocked: open it instead.\nblock msg_not_locked()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} are already unlocked, so you skip the suspense and open them."\n            return 0\n    say "${The noun} is already unlocked, so you skip the suspense and open it."\n\n// Operating.\nblock msg_no_switch()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} aren\'t the switching kind."\n            return 0\n    say "${The noun} isn\'t the switching kind."\n\nblock msg_already_on()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} already on."\n        return 0\n    say "${The noun} is already on."\n\nblock msg_already_off()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} already off."\n        return 0\n    say "${The noun} is already off."\n\nblock msg_no_effect()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} hold firm."\n            return 0\n    say "${The noun} holds firm."\n\n// Body, action, idle.\nblock msg_attack()\n    say "Hitting things rarely helps, and it won\'t start now."\n\nblock msg_eat()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} not on the menu."\n        return 0\n    say "${The noun} is not on the menu."\n\nblock msg_drink()\n    say "Nothing here is worth a sip."\n\nblock msg_jump()\n    say "You hop on the spot. Nothing comes of it, but it felt good."\n\nblock msg_wait()\n    say "Time slips by."\n\nblock msg_kiss()\n    say "Now is hardly the moment."\n\nblock msg_sing()\n    say "You manage a few bars. The room is unmoved."\n\n// Conversation.\nblock msg_no_talk()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} don\'t seem up for a conversation."\n            return 0\n    say "${The noun} doesn\'t seem up for a conversation."\n\n// The gentle nudge when TELL should hand over to the conversations menu;\n// lives in the language layer so a pack translates it.\nblock msg_use_talk()\n    say "To get anywhere with ${the noun}, just TALK TO ${the noun}."\n\n// The flat ask/tell/answer defaults (the Infocom granule falls back to\n// these when no topic matches; with no conversation feature they are the\n// whole answer, as in PunyInform).\nblock msg_ask()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} stay mum on the subject."\n            return 0\n    say "${The noun} stays mum on the subject."\n\nblock msg_tell()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} receive the news with magnificent indifference."\n            return 0\n    say "${The noun} receives the news with magnificent indifference."\n\nblock msg_answer()\n    say "Your words go unanswered."\n\n// Inventory.\nblock msg_carrying()\n    say "You\'re carrying:"\n\nblock msg_empty_handed()\n    say "You\'re carrying precisely nothing."\n\n// Scenery default.\nblock msg_scenery()\n    say "Just some scenery. Don\'t worry about it."\n\n// Printed when the first word names no verb or direction.\nblock msg_no_verb()\n    say "Those words don\'t add up to anything."\n\n// The verb was understood, but it cannot use the words that followed it ("jump\n// north", "look cloak"). The verb is fine; the rest is one word too many.\nblock msg_extra_words()\n    say "You lost me after that."\n\n// Read a yes/no answer; returns 1 for an answer that starts with y or Y. The\n// caller prints the question first, so this is shared by every confirmation. The\n// yes test (a leading \'y\') is English, so it lives in the language layer.\nblock yes_no()\n    let term = read_input\n    let c = text_char(0)\n    if c is 121\n        return 1\n    if c is 89\n        return 1\n    return 0\n\n// Ask the player to confirm quitting; returns 1 for yes.\nblock confirm_quit()\n    show("Are you sure you want to quit? ")\n    return yes_no\n\n// The farewell, overridable for a custom send-off.\nblock msg_farewell()\n    say "We\'ll leave it there."\n\n// The post-mortem prompt after a finish banner (loop.prelude game_over).\nblock msg_game_over()\n    say "Would you like to RESTART, RESTORE a saved game, or QUIT?"\n\n// After a `death` ending only: the way back is on the menu.\nblock msg_game_over_died()\n    say "Would you like to RESTART, RESTORE a saved game, UNDO the last command, or QUIT?"\n\nblock msg_game_over_unknown()\n    say "That wasn\'t one of the choices."\n\n// Meta verbs (the score, a restart confirmation, the xyzzy easter egg). save,\n// restore, and undo bring their own messages with the meta-verb opcodes.\n// SCORE is the one score verb, Infocom-shaped: score, maximum, turn count,\n// and the rank when a `ranks` ladder is declared (the clause folds away\n// otherwise).\nblock msg_score()\n    // A game that scores nothing says so instead of "0 of a possible 0";\n    // the fold makes the branch free either way.\n    if any_awards is 0\n        say "This game does not keep score."\n        return 0\n    show("You have scored ${score} of a possible ${max_score}, in ")\n    show(turns)\n    if turns is 1\n        show(" turn")\n    else\n        show(" turns")\n    if any_ranks is 1\n        show(", which earns you the rank of ")\n        print_rank\n    say "."\n\nblock msg_confirm_restart()\n    show("Start over from the very beginning? ")\n\nblock msg_xyzzy()\n    say "Nothing happens, but you feel briefly clever."\n\nblock msg_saved()\n    say "Saved."\n\nblock msg_save_failed()\n    say "Something went wrong with that save."\n\nblock msg_restore_failed()\n    say "That save couldn\'t be restored."\n\nblock msg_transcript_on()\n    say "Transcript on. Everything from here is being recorded."\n\nblock msg_transcript_off()\n    say "Transcript off."\n\nblock msg_transcript_already()\n    say "The transcript is already running."\n\nblock msg_transcript_not_on()\n    say "No transcript is running."\n\nblock msg_transcript_failed()\n    say "No transcript was started."\n\nblock msg_undone()\n    say "Taken back."\n\nblock msg_cant_undo()\n    say "There\'s nothing to take back."\n\nblock msg_cant_oops()\n    say "There\'s nothing to put right."\n\n// How many things the player wears; the pure count beside list_worn, so a\n// story can guard its phrasing ("You\'re dressed in nothing at all") before\n// printing a prefix. Both cost nothing unless called (DCE).\nblock worn_count()\n    let n = 0\n    for each x in player\n        if x is worn\n            change n to n + 1\n    return n\n\n// Print what the player wears as a punctuated list, "a hat, a cloak and\n// boots", with no framing and no newline: the story writes its own prose\n// around it. Returns the count. The two-pass count-then-join shape is the\n// library\'s own listing idiom (list_contents_run).\nblock list_worn()\n    let total = worn_count\n    let shown = 0\n    for each x in player\n        if x is worn\n            if shown is not 0\n                if shown is total - 1\n                    show(" and ")\n                else\n                    show(", ")\n            show("${a x}")\n            change shown to shown + 1\n    return total\n\n\n// One line of an inventory listing; a worn item is tagged, a container or\n// supporter names what it holds.\nblock list_held(obj)\n    show("  ")\n    show("${a obj}")\n    if obj is worn\n        show(" (worn)")\n    show_tag(obj)\n    list_contents(obj)\n    say ""\n',
    'extendedverbs.granule': '// extendedverbs.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// The extended verb set: summon it with `summon.extendedverbs`. These are the\n// flavor and idle verbs beyond the always-in standard set (docs/verb-set.md,\n// the E column) - search, throw, dig, rub, pray, and their kin. Most just\n// speak a default an object can override (most-specific-wins), exactly like\n// the standard sensory verbs; search lists what a container or supporter\n// holds. Conversation is NOT here: ask/tell/answer are standard verbs, and\n// the two conversation presentations are their own granules (conversations,\n// infocom_talking; docs/05).\n//\n// The wording lives here, in the granule, so it ships only when summoned.\n// Reskin any line from the story by redefining its msg_ block (most-specific-\n// wins: game over granule over library), or fork the granule to reshape it\n// wholesale. An object overrides a verb\'s effect through ordinary handler\n// resolution the same way, below.\n//\n// ---------------------------------------------------------------------------\n// Examining and rummaging.\n\nverb "search", "frisk"\n    search noun\n\non search\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    // A shut, closed, or locked container yields nothing to a search: you\n    // cannot see inside a sealed thing (a locked container is not open, so\n    // this one check covers all three). A refusal, so it never fires an\n    // alter, per the alter contract; the Schroedinger\'s-loot flavor is\n    // reserved for exactly this.\n    if noun is container\n        if noun is not open\n            change refused to 1\n            msg_search_closed\n            stop\n    // A story that altered the report speaks it here, ahead of the soft\n    // defaults below (the shut container refused above and never reaches\n    // this, per the alter contract).\n    if any_alter is 1\n        if not (altered is 0)\n            run_alter\n            stop\n    // A LIVING thing is not a place to rummage: frisking a person is a\n    // social act, not a discovery, so the default is a cheeky rebuff. Not a\n    // refusal (a soft non-event that lets a chained command run on). The\n    // author overrides `on search` for a compliant, unconscious, or dead\n    // NPC; a corpse is not animate, so it falls through to the neutral\n    // default below and an override can turn out its loot.\n    if noun is animate\n        msg_search_animate\n        stop\n    // ANY other object is searchable, sense or not (the story\'s call): the\n    // default reveals nothing new. There is no built-in "list what it holds"\n    // on purpose (an open container already shows its contents in the room\n    // listing, and a character\'s belongings are not in scope, so listing\n    // would name things the player cannot reach). A real search is the\n    // author\'s `on search` override, revealing by making something REACHABLE\n    // (`now note is not hidden` for a note living in the room, or `move key\n    // to here` to spill an NPC\'s item out), never by naming the untouchable.\n    msg_search_nothing\n\n// ---------------------------------------------------------------------------\n// Acting on objects (futile by default; an object overrides for real effect).\n\nverb "throw", "chuck", "toss", "hurl"\n    throw noun at noun\n\non throw\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_throw\n        else\n            run_alter\n    else\n        msg_throw\n\n\nverb "rub", "polish", "clean", "wipe", "scrub", "dust", "shine", "buff"\n    rub noun\n\non rub\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if any_alter is 1\n        if altered is 0\n            msg_rub\n        else\n            run_alter\n    else\n        msg_rub\n\n\nverb "squeeze", "crush"\n    squeeze noun\n\non squeeze\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if any_alter is 1\n        if altered is 0\n            msg_squeeze\n        else\n            run_alter\n    else\n        msg_squeeze\n\n\nverb "tie", "attach", "fasten", "secure"\n    tie noun to noun\n\non tie\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_tie\n        else\n            run_alter\n    else\n        msg_tie\n\n\nverb "cut", "chop", "slice", "prune", "carve"\n    cut noun\n\non cut\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_cut\n        else\n            run_alter\n    else\n        msg_cut\n\n\nverb "fill"\n    fill noun\n\non fill\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_fill\n        else\n            run_alter\n    else\n        msg_fill\n\n\nverb "burn", "ignite", "torch", "kindle"\n    burn noun\n\non burn\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_burn\n        else\n            run_alter\n    else\n        msg_burn\n\n\nverb "blow"\n    blow noun\n\non blow\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if any_alter is 1\n        if altered is 0\n            msg_blow\n        else\n            run_alter\n    else\n        msg_blow\n\n\nverb "set", "adjust"\n    set noun to noun\n\non set\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_set\n        else\n            run_alter\n    else\n        msg_set\n\n\nverb "empty", "drain"\n    empty noun\n    empty noun into noun\n\non empty\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if any_alter is 1\n        if altered is 0\n            msg_empty\n        else\n            run_alter\n    else\n        msg_empty\n\n\nverb "buy", "purchase"\n    buy noun\n\non buy\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_buy\n        else\n            run_alter\n    else\n        msg_buy\n\n\nverb "consult", "reference"\n    consult noun about noun\n\non consult\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_alter is 1\n        if altered is 0\n            msg_consult\n        else\n            run_alter\n    else\n        msg_consult\n\n// ---------------------------------------------------------------------------\n// Body and idle actions (intransitive; they just speak).\n\nverb "dig", "excavate"\n    dig\n    dig noun\n\non dig\n    if any_alter is 1\n        if altered is 0\n            msg_dig\n        else\n            run_alter\n    else\n        msg_dig\n\n\nverb "wave", "brandish"\n    wave\n    wave noun\n\non wave\n    if any_alter is 1\n        if altered is 0\n            msg_wave\n        else\n            run_alter\n    else\n        msg_wave\n\n\nverb "sit", "rest"\n    sit\n\non sit\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_sit\n        else\n            run_alter\n    else\n        msg_sit\n\n\nverb "stand"\n    stand\n\non stand\n    if any_alter is 1\n        if altered is 0\n            msg_stand\n        else\n            run_alter\n    else\n        msg_stand\n\n\nverb "sleep", "nap", "doze"\n    sleep\n\non sleep\n    if any_alter is 1\n        if altered is 0\n            msg_sleep\n        else\n            run_alter\n    else\n        msg_sleep\n\n\nverb "swim", "dive", "paddle"\n    swim\n\non swim\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_swim\n        else\n            run_alter\n    else\n        msg_swim\n\n\nverb "swing"\n    swing\n\non swing\n    change refused to 1\n    if any_alter is 1\n        if altered is 0\n            msg_swing\n        else\n            run_alter\n    else\n        msg_swing\n\n\nverb "think", "ponder", "consider"\n    think\n\non think\n    if any_alter is 1\n        if altered is 0\n            msg_think\n        else\n            run_alter\n    else\n        msg_think\n\n\nverb "pray", "worship"\n    pray\n\non pray\n    if any_alter is 1\n        if altered is 0\n            msg_pray\n        else\n            run_alter\n    else\n        msg_pray\n\n\nverb "shout", "yell", "scream", "holler"\n    shout\n\non shout\n    if any_alter is 1\n        if altered is 0\n            msg_shout\n        else\n            run_alter\n    else\n        msg_shout\n\n// ---------------------------------------------------------------------------\n// The wording. Fork the granule to change any of these lines.\n\nblock msg_search_nothing()\n    say "Breaking news: Absolutely nothing new to see here."\n\nblock msg_search_animate()\n    say "${The noun} gives you a look that says, plainly: whatever it is you are about to try, stop it."\n\nblock msg_search_closed()\n    say "Schroedinger\'s loot remains safe, mostly because ${the noun} is completely shut."\n\nblock msg_throw()\n    say "Gravity has already been discovered; there is no need for you to test it again."\n\nblock msg_rub()\n    say "You give ${the noun} a thorough buffing. It continues to judge you in silence."\n\nblock msg_squeeze()\n    say "You give ${the noun} an uncomfortably long squeeze. Let\'s just move on."\n\nblock msg_tie()\n    say "Stringing things together won\'t help you unravel this particular problem."\n\nblock msg_cut()\n    say "${The noun} seems firmly opposed to being cut."\n\nblock msg_fill()\n    say "${The noun} remains empty, mostly because you don\'t have anything to put in it."\n\nblock msg_burn()\n    say "Starting a fire here seems like a quick way to create a much bigger problem."\n\nblock msg_blow()\n    say "You unleash a mighty breath. The local climate remains entirely unaffected."\n\nblock msg_set()\n    say "Set it to what, exactly?"\n\nblock msg_empty()\n    say "You up-end ${the noun}. Nothing of note falls out."\n\nblock msg_buy()\n    say "Your wealth is profoundly useless in this exact situation."\n\nblock msg_consult()\n    say "${The noun} has nothing to say on the matter."\n\nblock msg_dig()\n    say "The ground keeps its secrets."\n\nblock msg_wave()\n    say "You wave. The room declines to wave back."\n\nblock msg_sit()\n    say "Nothing here invites sitting."\n\nblock msg_stand()\n    say "You\'re already on your feet."\n\nblock msg_sleep()\n    say "You consider curling up into a ball and ignoring the plot, but your sense of duty rudely keeps you awake."\n\nblock msg_swim()\n    say "There\'s nowhere here to swim."\n\nblock msg_swing()\n    say "There\'s nothing here to swing on."\n\nblock msg_think()\n    say "A fine idea. Nothing comes of it."\n\nblock msg_pray()\n    say "You ask the heavens for a hint. The heavens remain conspicuously silent."\n\nblock msg_shout()\n    say "You test the location\'s acoustics with a loud yell. The results are entirely underwhelming."\n\n',
    'german.granule': '// german.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// THE GERMAN LANGUAGE LAYER (informal, du). A language pack, selected with\n// `summon.language "german"`, which compiles it in place of english.prelude. A\n// fork of the English layer: the language-agnostic parser logic in section 1 is\n// unchanged; the verbs, the direction words, the articles, and every message are\n// German. The message set has had a native pass (Stefan Vogt, 2026-07). It has\n// three parts, in order:\n//\n//   1. THE PARSER - the blocks that teach the parser how to read German input:\n//      which word is the verb, how a noun phrase is matched, how directions and\n//      particles are recognized, and the oops correction. The language-agnostic\n//      skeleton that drives these lives in parser.prelude; these are its hooks.\n//   2. THE STANDARD VERBS - the vocabulary: every standard verb word and its\n//      grammar. The behaviour behind each action is agnostic and lives in\n//      actions.prelude, keyed by action name; only the words are here.\n//   3. THE MESSAGES - every line the library prints to the player, each an\n//      overridable block, plus the room and content listing that frames them.\n//\n// Two things set German apart from the Spanish pack, and shape this file:\n//   - GENDER is three-way (der/die/das) with no spelling rule, so the author\n//     declares the article on the object (der/die/das); the compiler maps that to\n//     the feminine/neutral attributes this file reads. Masculine is the default.\n//   - The article INFLECTS FOR CASE (der/den/dem). A message asks for the case it\n//     needs with a tag on the article, ${the:acc noun} / ${a:dat noun}; art_the\n//     and art_a below turn gender and case into the right word. Predicate\n//     adjectives do NOT inflect ("die Kiste ist offen", "der Schrank ist offen"),\n//     so unlike Spanish there are almost no per-gender message variants: the\n//     article changes in one place. The exception is a PRONOUN that refers back\n//     to the noun (msg_fixed: wo sie/er/es ist), which branches on the gender.\n//\n// TYPING ON 8-BIT HARDWARE: an accented word is shown in full (the interpreters\n// render umlauts and ß), but every word the player must TYPE also has a plain\n// ASCII form here, since an 8-bit keyboard cannot enter umlauts: "oeffne"\n// beside "öffne", "sueden" beside "süden", "schliesse" beside "schließe".\n//\n// The self-identifying marker: this is the language pack for the code "german".\n// The compiler requires it to be chosen with summon.language, and rejects a plain\n// `summon german.granule` (which would leave English baked in).\nlanguage "german"\n\n// ==========================================================================\n// 1. THE PARSER\n// How input becomes a verb, its nouns, and a direction. Agnostic logic: this\n// section is identical to the English and Spanish skeletons, and is here only\n// because a language pack replaces english.prelude wholesale.\n// ==========================================================================\n\n// Resolve the verb: the first word, if its dictionary entry is flagged a verb.\n// Returns the action number, or 0 if the first word is not a known verb.\nblock resolve_verb()\n    let d = word_dict(0)\n    if d is not nothing\n        let flags = peek_byte(d + 6)\n        if any_tables is 1\n            // Ein Verb mit Grammatiktabelle (docs/02 Abschnitt 8c): die\n            // Datenbytes tragen die Adresse der Tabelle, deren erstes Byte\n            // die Handlung der ersten Zeile ist; die eigentliche Zeile\n            // waehlt spaeter der Matcher (line_act).\n            if flags is 144 or flags is 152\n                let tbl = peek_word(d + 7, 0)\n                return peek_byte(tbl)\n        if flags is 128 or flags is 136\n            let base = peek_byte(d + 7)\n            let p = find_particle\n            if p is not nothing\n                let c = compound(base, p)\n                if c is not nothing\n                    return c\n            return base\n        if flags is 64\n            return peek_byte(d + 7)\n    // Kein Verb am Satzanfang? Steht irgendwo im Satz eine Richtung, ist es\n    // trotzdem ein Gehen-Befehl: so versteht der Parser "nach oben" und "nach\n    // unten", wo das erste Wort ("nach") gar nicht im Woerterbuch steht.\n    if find_direction is not nothing\n        return action_id("go")\n    return 0\n\n// The first verb-particle word in the command, as its id (an/ein 1, aus/ab 2,\n// auf 3, zu 4, declared with `particle` below). This is what makes the trennbare\n// Verben work: "schalt die Lampe an" and "schliess die Tuer auf" find their\n// particle here, wherever it falls, and compound maps base verb + particle to\n// the real action.\nblock find_particle()\n    let n = word_count\n    let i = 1\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 32\n                return peek_byte(d + 7)\n        change i to i + 1\n    return nothing\n\n// Combine a base verb with a particle into a multi-word action. The particle ids\n// are the shared contract with the compiler (prelude._PARTICLE_ROLES): 1 on\n// (an/ein), 2 off (aus/ab), 3 auf, 4 zu. The same word can mean different things\n// after different base verbs, and this block is where that is resolved.\nblock compound(base, particle)\n    if base is action_id("switch_on")   // schalt(e): + an/ein an, + aus/ab aus\n        if particle is 1\n            return action_id("switch_on")\n        if particle is 2\n            return action_id("switch_off")\n    if base is action_id("close")        // schliess(e): + auf auf, + zu/ab ab\n        if particle is 3\n            return action_id("unlock")\n        if particle is 4\n            return action_id("lock")\n        if particle is 2\n            return action_id("lock")\n    if base is action_id("turn")\n        if particle is 1\n            return action_id("switch_on")\n        if particle is 2\n            return action_id("switch_off")\n    if base is action_id("take")         // nimm ... ab -> ausziehen (take_off)\n        if particle is 2\n            return action_id("take_off")\n    if base is action_id("transcript")   // mitschrift an / mitschrift aus\n        if particle is 1\n            return action_id("transcript")\n        if particle is 2\n            return action_id("transcript_off")\n    return nothing\n\n// The chosen direction\'s property number, from the first direction word typed\n// (a direction word\'s dictionary entry is flagged with bit 6, and byte 2 holds\n// the direction property). Returns nothing if no direction was named.\nblock find_direction()\n    let n = word_count\n    let i = 0\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 64\n                return peek_byte(d + 8)\n        change i to i + 1\n    return nothing\n\n// German reads SCHAU <noun> as EXAMINE, the usual synonym: a bare SCHAU describes\n// the room, while SCHAU MANTEL inspects the cloak. parser.prelude calls this once\n// the objects are known; here it remaps the look action to examine when a noun or\n// a scenery grain was named.\nblock remap_action(act)\n    if act is action_id("look")\n        if noun is not nothing\n            return action_id("examine")\n        if grain is not 0\n            return action_id("examine")\n    return act\n\n// Does the object\'s vocabulary include this dictionary word?\nblock has_word(obj, target)\n    let addr = words_addr(obj)\n    if addr is nothing\n        return 0\n    let count = words_count(obj)\n    let i = 0\n    while i < count\n        if peek_word(addr, i) is target\n            return 1\n        change i to i + 1\n    return 0\n\n// Can the player see and reach what is inside this object? A supporter\'s\n// contents are always in view. A container\'s are in view when it is open, when\n// it is `clear` (see-through), or when it is not `openable` at all: a bowl or a\n// basket has no lid to shut, so its contents are always reachable.\nblock see_into(obj)\n    if obj is supporter\n        return 1\n    if obj is container\n        if obj is open\n            return 1\n        if obj is clear\n            return 1\n        if obj is not openable\n            return 1\n    return 0\n\n// A closed opaque container: we cannot see into it.\nblock shut_holds(obj)\n    if obj is open\n        return 0\n    if obj is clear\n        return 0\n    if obj is not openable\n        return 0\n    return 1\n\n// Among the closed opaque containers directly within `where`, a known (seen)\n// content matching the word. Records the blocking container in shut_in.\nblock shut_search(where, target)\n    for each obj in where\n        if obj is not hidden\n            if obj is container\n                if shut_holds(obj)\n                    let known = shut_match(obj, target)\n                    if known is not nothing\n                        change shut_in to obj\n                        return known\n    return nothing\n\nblock shut_match(holder, target)\n    for each x in holder\n        if x is not hidden\n            if x is seen\n                if has_word(x, target)\n                    return x\n    return nothing\n\n// Match a noun: the typed words after the verb, as one phrase, through the\n// scoring matcher (parser.prelude match_phrase): the in-scope object matching\n// the most typed words wins, a tie is a genuine ambiguity (parse_fault 3).\nblock match_noun()\n    return match_first_phrase\n\n// Resolve the command\'s objects into the noun (and, for a two-noun verb, the\n// second). The verb\'s dictionary entry carries its noun arity in data byte 2.\nblock resolve_objects()\n    change noun to nothing\n    change second to nothing\n    change grain to 0\n    change parse_fault to 0\n    change two_reverse to 0\n    if any_tables is 1\n        change line_act to 0\n    let d = word_dict(0)\n    if d is not nothing\n        if any_tables is 1\n            // Ein Verb mit Grammatiktabelle: der positionsgenaue Matcher\n            // uebernimmt den ganzen Befehl (docs/02 Abschnitt 8c).\n            if peek_byte(d + 6) is 144 or peek_byte(d + 6) is 152\n                let tbl = peek_word(d + 7, 0)\n                grammar_match(tbl)\n                return 1\n        if peek_byte(d + 6) is 128 or peek_byte(d + 6) is 136\n            let arity = peek_byte(d + 8)\n            let va = peek_byte(d + 7)\n            // A reverse-capable two-noun verb (geben/zeigen) is encoded as 6:\n            // the recipient-first order (gib Bob die Muenze) with no preposition,\n            // the natural German dative, splits and swaps in resolve_two_nouns.\n            if arity is 6\n                change two_reverse to 1\n                change arity to 2\n            if arity is 2\n                resolve_two_nouns\n                return 1\n            if arity is 0\n                if va is not action_id("oops")\n                    if has_extra_words(va) is 1\n                        change parse_fault to 2\n                return 1\n    change noun to match_noun\n    // An ambiguity fault (3) stands: falling through to the grain and\n    // unseen checks would overwrite the honest "which do you mean".\n    if parse_fault is not 0\n        return 1\n    // A pending plural sweep ("take coins", THEM) binds per object later.\n    if any_plurals is 1\n        if plural_go is not 0\n            return 1\n    if noun is nothing\n        change noun to reach_unscoped\n    if noun is nothing\n        change grain to find_scenery\n        if grain is 0\n            change parse_fault to named_unseen\n            if parse_fault is 0\n                change unknown_at to first_unknown(1, word_count)\n                if unknown_at is not 0\n                    change parse_fault to 4\n    return 1\n\n// A hook for reaching an object ordinary scope could not: nothing by default.\nblock reach_unscoped()\n    return nothing\n\n// Did the player name an object word that nothing in scope answered to?\nblock named_unseen()\n    return phrase_named(1, word_count)\n\n// For an intransitive verb (no noun slot), is there a word after it the grammar\n// cannot use? A go command is the exception: dort zaehlt nur, ob irgendwo eine\n// Richtung steht, denn "geh nach oben" traegt das Fuellwort "nach", das gar\n// nicht im Woerterbuch steht.\nblock has_extra_words(act)\n    if act is action_id("go")\n        if find_direction is not nothing\n            return 0\n    let n = word_count\n    let i = 1\n    while i < n\n        let keep = 0\n        let d = word_dict(i)\n        // Eine Partikel, die mit diesem Verb ein Kompositum bildet, gehört\n        // zum Verb ("mitschrift an"); jedes andere Wort ist eines zu viel.\n        if d is not nothing\n            if peek_byte(d + 6) is 32\n                if compound(act, peek_byte(d + 7)) is not nothing\n                    change keep to 1\n        if keep is 0\n            return 1\n        change i to i + 1\n    return 0\n\n// A scenery grain word (flagged bit 4) whose owner is in scope; returns the\n// grain id.\nblock find_scenery()\n    // The walker folds away entirely (any_grains is a compile-time flag) in a\n    // game that declares no grains, so unused scenery costs nothing.\n    if any_grains is 1\n        let n = word_count\n        let i = 1\n        while i < n\n            let d = word_dict(i)\n            if d is not nothing\n                if peek_byte(d + 6) is 16\n                    // The word\'s grain chain: (grain id, owner) pairs, zero-\n                    // ended. The same word can be scenery in several rooms;\n                    // answer with the grain whose owner is in scope here.\n                    let c = peek_word(d + 7, 0)\n                    let j = 0\n                    let g = peek_word(c, j)\n                    while g is not 0\n                        if in_scope(peek_word(c, j + 1))\n                            return g\n                        change j to j + 2\n                        change g to peek_word(c, j)\n            change i to i + 1\n    return 0\n\n// Is this dictionary word a phrase boundary rather than a noun word?\nblock is_separator(target)\n    // Only the words that JOIN two nouns split the phrases: a grammar\n    // preposition (flag 8), and the direction and particle words that\n    // double as one ("put coin IN box", "gib X AN Y", flags 64 and 32).\n    // Anything else is content: a pronoun binds as a noun, an article is\n    // skipped, and a noun that moonlights as a verb elsewhere ("pick the\n    // LOCK", "PAT the person") must not end the phrase it stars in.\n    if peek_byte(target + 6) is 8 or peek_byte(target + 6) is 136\n        return 1\n    if peek_byte(target + 6) is 64\n        return 1\n    if peek_byte(target + 6) is 32\n        return 1\n    return 0\n\n// Bind the two noun slots by position: the words before the preposition name the\n// first noun, the words after it name the second.\nblock resolve_two_nouns()\n    let n = word_count\n    let b = 0\n    let i = 1\n    while i < n\n        if b is 0\n            let d = word_dict(i)\n            if d is not nothing\n                if is_separator(d)\n                    change b to i\n        change i to i + 1\n    // The reversed dative (gib Bob die Muenze), the natural German order: two\n    // adjacent nouns, no "an" to split on. Probe each boundary for the first\n    // where both sides name a single object, then bind them swapped (recipient\n    // first, thing second). No clean split falls through to the ordinary path.\n    if two_reverse is 1\n        if b is 0\n            let sp = 2\n            while sp < n\n                let recip = probe_noun(1, sp)\n                if recip is not nothing\n                    let gift = probe_noun(sp, n)\n                    if gift is not nothing\n                        change second to recip\n                        change noun to gift\n                        return 1\n                change sp to sp + 1\n    if b is 0\n        change b to n\n    change noun to match_phrase(1, b, 0)\n    if parse_fault is not 0\n        return 1\n    // A named-but-unresolved noun (a known object out of scope, an unknown word,\n    // a stray non-noun) faults so the turn is rejected rather than run with no\n    // noun; an EMPTY slot (b is 1) is left to the action\'s own default.\n    if noun is nothing\n        if b > 1\n            change parse_fault to noun_fault(1, b)\n            return 1\n    if b < n\n        change second to match_phrase(b + 1, n, 0)\n        if parse_fault is not 0\n            return 1\n        if second is nothing\n            if b + 1 < n\n                change parse_fault to noun_fault(b + 1, n)\n    return 1\n\n// Remember the command just parsed so a following "oops" can correct it.\nblock note_oops()\n    change oops_ready to 0\n    let n = word_count\n    let i = 0\n    while i < n\n        if word_dict(i) is nothing\n            change oops_word to i\n            change oops_ready to 1\n            copy_bytes(parse_addr, oops_addr, 2 + 4 * n)\n            return 0\n        change i to i + 1\n    return 0\n\n// Correct the previous command\'s unrecognized word with the word typed after\n// "oops", then re-resolve the patched command and return its action.\nblock fix_oops()\n    if oops_ready is 0\n        msg_cant_oops\n        return 0\n    let fix = word_dict(1)\n    if fix is nothing\n        msg_cant_oops\n        return 0\n    copy_bytes(oops_addr, parse_addr, 2 + 4 * peek_byte(oops_addr + 1))\n    poke_word(parse_addr, 1 + 2 * oops_word, fix)\n    let act = resolve_verb\n    if act is 0\n        return 0\n    change tie_want to 1\n    if act is action_id("take")\n        change tie_want to 0\n    change way to find_direction\n    resolve_objects\n    if parse_fault is 1\n        msg_cant_see\n        return 0\n    if parse_fault is 3\n        msg_be_specific\n        return 0\n    if any_tables is 1\n        if line_act is not 0\n            change act to line_act\n    return act\n\n// ==========================================================================\n// 2. THE STANDARD VERBS\n// The verb vocabulary and grammar; the logic is in actions.prelude. Informal\n// address (du). Every umlaut/ss word is paired with its plain ASCII form so an\n// 8-bit keyboard can type it.\n// ==========================================================================\n\n// Bare SCHAU describes the room; SCHAU <noun> is the usual synonym for EXAMINE,\n// remapped once the noun is known (remap_action above).\nverb "schau", "schaue", "sieh", "l"\n    look\n    look noun\n\n// Movement. The parser sets `way` to the chosen direction\'s property. A room can\n// override one direction with its own `on go <direction>`.\nverb "geh", "gehe", "gehen", "lauf", "laufe", "renne"\n    go\n\n// The direction words: each maps its vocabulary to a fixed direction property.\n// The property names never change; only the words are German. Each umlaut word\n// (sueden, suedosten, suedwesten) carries its ASCII form for typing.\ndirection north     "norden", "nord", "n"\ndirection south     "sueden", "süden", "sued", "süd", "s"\ndirection east      "osten", "ost", "o"\ndirection west      "westen", "west", "w"\ndirection northeast "nordosten", "nordost", "no"\ndirection northwest "nordwesten", "nordwest", "nw"\ndirection southeast "suedosten", "südosten", "suedost", "so"\ndirection southwest "suedwesten", "südwesten", "suedwest", "sw"\n// Hinauf und hinab brauchen im Deutschen viele Formen: hoch, rauf, hinauf,\n// aufwaerts, oben (fuer "nach oben"), und ebenso runter, hinunter, hinab,\n// abwaerts, unten. Das nackte "auf" fehlt mit Absicht: es ist die\n// Aufschliess-Partikel ("schliess die Tuer auf"), und ein Wort traegt im\n// Woerterbuch nur eine Rolle. Ein nacktes "ab" waere ohnehin kein Deutsch.\ndirection up        "hoch", "rauf", "hinauf", "aufwaerts", "aufwärts", "oben", "h"\ndirection down      "runter", "hinunter", "hinab", "abwaerts", "abwärts", "unten", "r"\ndirection in        "rein", "hinein"\ndirection out       "hinaus", "heraus"\n\nverb "nimm", "nehmen", "nimmt", "hol", "hole", "schnapp"\n    take noun\n\nverb "wirf", "fallenlassen", "wegwerfen", "weglegen"\n    drop noun\n\nverb "untersuch", "untersuche", "untersuchen", "betrachte", "pruefe", "prüfe", "x"\n    examine noun\n\n// Meta verbs. Each sets meta_turn, so the loop skips the per-turn pulse and the\n// turn count. quit and restart confirm first. Jedes Meta-Verb hört AUCH auf\n// sein englisches Original (quit, score, save, restore, undo, again, oops,\n// transcript): wer englische Adventures gewohnt ist, rät das deutsche Wort\n// nicht immer beim ersten Mal, und die Sitzungsverben müssen einfach gehen.\nverb "beende", "beenden", "ende", "quit"\n    quit\n\nverb "punkte", "punktzahl", "score"\n    score\n\nverb "neustart", "neustarten", "restart"\n    restart\n\n// Saving and restoring.\nverb "sichern", "sichere", "speichern", "speichere", "save"\n    save\n\nverb "laden", "lade", "wiederherstellen", "restore", "load"\n    restore\n\n// Die Mitschrift (Ausgabestrom 2): MITSCHRIFT oder PROTOKOLL startet sie,\n// MITSCHRIFT AUS beendet sie. Die Partikeln an/aus laufen wie bei schalt\n// über compound; die Datei gehört dem Interpreter. Englisch als Rückfall:\n// TRANSCRIPT ON/OFF (die Partikeln unten kennen on und off) und UNSCRIPT.\nverb "mitschrift", "protokoll", "transkript", "transcript", "script"\n    transcript\n    transcript_off\n\nverb "unscript"\n    transcript_off\n\n// undo and again are intercepted by the turn loop before dispatch.\nverb "widerrufen", "rueckgaengig", "rückgängig", "undo"\n    undo\n\nverb "wiederhole", "wiederholen", "nochmal", "g", "again"\n    again\n\nverb "ups", "hoppla", "korrigiere", "oops"\n    oops\n\n// The magic word, a normal (if fruitless) action; an author can override it.\nverb "xyzzy"\n    xyzzy\n\nverb "inventar", "i", "inv"\n    inventory\n\n// Ein- und ausschalten. Das Grundverb "schalt(e)" trägt eine Partikel danach oder\n// davor: "schalt die Lampe an", "schalt die Lampe ein", und (grammatisch schief,\n// aber in Textadventures üblich) "schalt an Lampe", "schalt ein Lampe". Die\n// zusammengeschriebenen Formen decken "einschalten Lampe" mit ab.\nverb "schalt", "schalte"\n    switch_on noun\n    switch_off noun\n\nverb "einschalten", "anschalten", "anmachen"\n    switch_on noun\n\nverb "ausschalten", "abschalten", "ausmachen"\n    switch_off noun\n\n// Die Schaltpartikeln. "an"/"ein" schalten ein, "aus"/"ab" schalten aus. "an"\n// dient auch als Präposition (gib X an Y); das stört nicht, denn der Parser\n// behandelt jedes markierte Wort als Phrasengrenze, und compound wirkt nur auf\n// switch/turn/take.\nparticle on  "an", "ein", "on"\nparticle off "aus", "ab", "off"\n\nverb "anziehen", "anlegen", "trag", "trage"\n    wear noun\n\nverb "ausziehen", "ablegen", "abnehmen"\n    take_off noun\n\nverb "leg", "lege", "stell", "stelle", "setz", "setze"\n    put noun auf noun\n    put noun in noun\n\nverb "steck", "stecke", "einstecken"\n    insert noun in noun\n\nverb "oeffne", "öffne", "oeffnen", "öffnen"\n    open noun mit noun\n    open noun\n\n// Schliessen, ab- und aufschliessen als trennbares Grundverb. "schliess(e)"\n// allein macht zu (close). Mit einer Partikel wird daraus die natuerliche,\n// trennbare Form: "schliess die Tuer ab" oder "... zu" schliesst ab (lock, mit\n// oder ohne "mit dem Schluessel"), "... auf" schliesst auf (unlock). Die Partikel\n// darf davor oder danach stehen. Das ist genau, wie ein Deutscher es sagt:\n// "Hast du die Haustuer abgeschlossen?" -> "schliess die Haustuer ab".\n// Die mit-Zeile traegt den Schluessel ins zweite Feld ("schliess die Tuer mit\n// dem Schluessel ab"); WELCHE Handlung laeuft, entscheidet allein die Partikel\n// (compound oben), nie die Zeile, darum steht hier ueberall close.\nverb "schliesse", "schließe", "schliess", "schließ", "schliessen", "schließen", "zumachen"\n    close noun\n    close noun mit noun\n\n// Die Schliesspartikeln. "auf" schliesst auf (unlock); "zu" und "ab" schliessen ab\n// (lock). "ab" ist zugleich die Ausschalt-Partikel; compound unterscheidet nach\n// dem Grundverb (schalt vs. schliess), darum stoert die Doppelrolle nicht.\n// Die Pronomen: das grammatische Geschlecht entscheidet, nicht die Belebtheit.\n// Die Lampe ist "sie", der Schlüssel "ihn" (Akkusativ, das Objekt eines\n// Befehls), das Buch "es". "nimm die lampe" und dann "untersuche sie".\n// Das Spieler-Objekt: die Selbstwörter, auf die jedes Spiel hört\n// ("untersuche dich"), ein druckbarer Name, und das named-Flag gegen den\n// Artikel. Ein Spiel ergänzt eigene Wörter mit player.words.\nplayer.words mich, dich, selbst\nplayer.name "dich selbst"\nplayer.named\n\n// Die Kettenwörter (docs/02 Abschnitt 8b): jedes beendet einen Befehl und\n// beginnt den nächsten auf derselben Zeile ("nimm die lampe und öffne die\n// tür, dann geh nach norden"). Das Komma zählt als eigenes Wort, mit oder\n// ohne Leerzeichen.\nchain ",", "und", "dann"\n\n// Die Füllwörter: die Artikel, die der Parser kennt, aber überliest. Das\n// Kennen zählt: eine Substantivliste darf sie tragen ("nimm die lampe und\n// den schlüssel"), während ein wirklich unbekanntes Wort das Ausleihen des\n// Verbs ehrlich verweigert (docs/02 8b).\nnoise "der", "die", "das", "den", "dem", "des", "ein", "eine", "einen", "einem", "einer"\n\npronoun it  "es"\npronoun him "ihn"\npronoun her "sie"\n\n// Welches Pronomen ein aufgelöstes Substantiv wird: nach dem Genus, das der\n// Autor mit der/die/das erklärt hat. Das Skelett ruft dies nach jedem Befehl.\nblock note_pronouns(obj)\n    if obj is feminine\n        change pron_her to obj\n        return 0\n    if obj is neutral\n        change pron_it to obj\n        return 0\n    change pron_him to obj\n\nparticle auf "auf"\nparticle zu  "zu"\n\n// Zusaetzlich ver- und entriegeln als eigene, UNTRENNBARE Verben ("entriegele die\n// Tuer mit dem Schluessel"), samt den zusammengeschriebenen ab-/aufsperren als\n// Synonyme, fuer Spieler, die lieber ein einzelnes Verb tippen.\nverb "verriegele", "verriegle", "verriegeln", "absperren", "zusperren"\n    lock noun mit noun\n    lock noun\n\nverb "entriegele", "entriegle", "entriegeln", "aufsperren"\n    unlock noun mit noun\n    unlock noun\n\nverb "betrete", "betreten", "besteige", "besteigen"\n    enter noun\n\nverb "aussteigen", "raussteigen", "heraussteigen"\n    exit\n\nverb "gib", "gebe", "geben", "reich", "reiche"\n    give noun an noun\n    give noun noun reverse\n\nverb "zeig", "zeige", "zeigen"\n    show noun an noun\n    show noun noun reverse\n\nverb "beruehre", "berühre", "beruehren", "berühren", "fuehl", "fühl"\n    touch noun\n\nverb "riech", "rieche", "riechen", "schnupper"\n    smell noun\n\nverb "schmeck", "schmecke", "koste", "probier", "probiere"\n    taste noun\n\nverb "hoer", "hör", "hoere", "höre", "lausche", "horch"\n    listen\n    listen noun\n\nverb "iss", "essen", "esse"\n    eat noun\n\nverb "trink", "trinke", "trinken", "schluck"\n    drink\n    drink noun\n\nverb "schlag", "schlage", "angreifen", "hau", "tritt", "zerstoere", "zerstöre", "brich"\n    attack noun\n\nverb "kuess", "küss", "kuesse", "küsse", "umarme"\n    kiss noun\n\nverb "drueck", "drück", "druecke", "drücke", "schieb", "schiebe", "press"\n    push noun\n\nverb "zieh", "ziehe", "ziehen", "zerr"\n    pull noun\n\nverb "dreh", "drehe", "drehen", "rotiere"\n    turn noun\n\nverb "kletter", "klettere", "klettern", "erklimme"\n    climb noun\n\nverb "lies", "lesen", "liest"\n    examine noun\n\nverb "sprich", "rede", "reden", "sprechen"\n    talk noun\n\nverb "frag", "frage", "befrage"\n    ask noun\n    ask noun nach\n    ask noun über\n    ask noun ueber\n\nverb "erzähl", "erzaehl", "erzähle", "erzaehle", "sag", "sage"\n    tell noun\n    tell noun von\n    tell noun über\n    tell noun ueber\n\nverb "antworte", "antworten"\n    answer noun\n\nverb "spring", "springe", "huepf", "hüpf", "huepfe", "hüpfe"\n    jump\n\nverb "warte", "warten", "z"\n    wait\n\nverb "sing", "singe", "singen"\n    sing\n\n// ==========================================================================\n// 3. THE MESSAGES\n// Every line shown to the player, and the room and content listing.\n// ==========================================================================\n\n// Articles. The compiler lowers ${the noun} / ${a noun} to a call to one of these\n// with the object, a capitalize flag (1 for ${The} / ${A}), and, when the message\n// tags one, a grammatical case (${the:acc noun}). With no tag, the case argument\n// is not passed at all, so `kase` keeps its default of 0 (nominative).\n//\n// Gender comes from the object: `neutral` (das), `feminine` (die), or neither\n// (der, masculine). Case is `kase`: 0 nominative, 1 accusative, 2 dative, 3\n// genitive. Every definite article starts with d, every indefinite with e, so the\n// capital is printed once and the case/gender tail follows: der/die/das, den, dem,\n// des; ein/eine, einen, einem, eines. A `named` object (Linda, Excalibur) takes no\n// article; that check folds away in a game with no named objects (any_named).\nblock art_the(obj, cap, kase)\n    // Total, like the containment test: an unresolved noun prints\n    // as the word, never an illegal print_obj 0 (docs/02 s.12).\n    if obj is nothing\n        show("nichts")\n        return\n\n    if any_named is 1\n        if obj is named\n            print_name(obj)\n            return\n    // A hand-set article wins over derivation (docs/01 section 16): las\n    // tijeras, el agua. Printed as stored, so keep it lowercase and let such\n    // objects sit mid-sentence.\n    if article_addr(obj) is not 0\n        show("${obj.article}")\n        show(" ")\n        print_name(obj)\n        return\n    // Der Plural (pluribus): die/die/den/der, die eigene Spalte der\n    // Kasustabelle. Faltet sich ohne markierte Objekte weg.\n    if any_pluribus is 1\n        if obj is pluribus\n            if cap is 1\n                show("D")\n            else\n                show("d")\n            if kase is 2\n                show("en ")\n            else\n                if kase is 3\n                    show("er ")\n                else\n                    show("ie ")\n            print_name(obj)\n            return\n    if cap is 1\n        show("D")\n    else\n        show("d")\n    if obj is neutral\n        if kase is 2\n            show("em ")\n        else\n            if kase is 3\n                show("es ")\n            else\n                show("as ")\n    else\n        if obj is feminine\n            if kase is 2\n                show("er ")\n            else\n                if kase is 3\n                    show("er ")\n                else\n                    show("ie ")\n        else\n            if kase is 0\n                show("er ")\n            else\n                if kase is 1\n                    show("en ")\n                else\n                    if kase is 2\n                        show("em ")\n                    else\n                        show("es ")\n    print_name(obj)\n\nblock art_a(obj, cap, kase)\n    // Total, like the containment test: an unresolved noun prints\n    // as the word, never an illegal print_obj 0 (docs/02 s.12).\n    if obj is nothing\n        show("nichts")\n        return\n\n    if any_named is 1\n        if obj is named\n            print_name(obj)\n            return\n    // A hand-set indefinite wins over derivation: unas tijeras, some water.\n    if indefinite_addr(obj) is not 0\n        show("${obj.indefinite}")\n        show(" ")\n        print_name(obj)\n        return\n    // Unbestimmter Plural hat im Deutschen keinen Artikel: "Du siehst\n    // hier Stiefel." Faltet sich ohne markierte Objekte weg.\n    if any_pluribus is 1\n        if obj is pluribus\n            print_name(obj)\n            return\n    if cap is 1\n        show("E")\n    else\n        show("e")\n    if obj is neutral\n        if kase is 2\n            show("inem ")\n        else\n            if kase is 3\n                show("ines ")\n            else\n                show("in ")\n    else\n        if obj is feminine\n            if kase is 2\n                show("iner ")\n            else\n                if kase is 3\n                    show("iner ")\n                else\n                    show("ine ")\n        else\n            if kase is 0\n                show("in ")\n            else\n                if kase is 1\n                    show("inen ")\n                else\n                    if kase is 2\n                        show("inem ")\n                    else\n                        show("ines ")\n    print_name(obj)\n\n// Die Kopula mit Numerus (docs/01 Abschnitt 16): ${is x} druckt "ist"\n// oder "sind" nach dem pluribus-Attribut des Objekts. Ohne markierte\n// Objekte faltet sich der Plural-Zweig weg.\nblock art_is(obj, cap)\n    if any_pluribus is 1\n        if obj is pluribus\n            if cap is 1\n                show("Sind")\n            else\n                show("sind")\n            return 0\n    if cap is 1\n        show("Ist")\n    else\n        show("ist")\n    return 0\n\n// Die Banner-Wörter. Der Compiler setzt das Banner zusammen (Titel, Untertitel,\n// Autor, Versionszeile), aber die Wörter ZWISCHEN den Teilen gehören der\n// Sprache: line_by druckt das Bindewort zwischen Untertitel und Autor, und\n// banner_headline den Untertitel, wenn das Spiel keinen eigenen setzt.\nblock line_by()\n    show(" von ")\n\n// Der Ortszusatz in Titelzeile und Statusleiste: "Krypta (auf dem Altar)",\n// "Keller (in der Kiste)". Träger nehmen "auf", alles andere "in"; der\n// Artikel kommt im Dativ aus art_the (kase 2).\nblock line_nested(obj)\n    if obj is supporter\n        show(" (auf ")\n    else\n        show(" (in ")\n    art_the(obj, 0, 2)\n    show(")")\n\nblock banner_headline()\n    show("Ein Textadventure")\n\n// The input prompt. It requests a paragraph break rather than forcing its own.\nblock prompt()\n    par\n    show(">")\n\n// What of a holder\'s contents should be listed: not hidden or concealed, and\n// either the holder shows its contents or the player already knows the item is\n// there (the knowledge model).\nblock content_listable(holder, x)\n    // The player never lists as a holder\'s contents ("an altar (contains\n    // yourself)"); possible only where something is enterable, so it folds.\n    if any_enterable is 1\n        if x is player\n            return 0\n    // A component is part of the holder, not carried contents: the machine\n    // never lists its own levers. Folds away without components.\n    if any_components is 1\n        if x is component\n            return 0\n    if x is hidden\n        return 0\n    if x is concealed\n        return 0\n    if see_into(holder)\n        return 1\n    if x is seen\n        return 1\n    return 0\n\n// One scenery holder\'s paragraph (constant scenery_contents = 1): what\n// sits on or in it, the knowledge model deciding per item. Prints\n// nothing when the holder holds nothing tellable.\nblock scenery_holder_line(obj)\n    if obj is not container\n        if obj is not supporter\n            return 0\n    let total = 0\n    for each x in obj\n        if content_listable(obj, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    par\n    if obj is supporter\n        show("Auf ")\n    else\n        show("In ")\n    art_the(obj, 0, 2)\n    show(" siehst du ")\n    let shown = 0\n    for each x in obj\n        if content_listable(obj, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" und ")\n                else\n                    show(", ")\n            art_a(x, 0)\n            now x is seen\n            change shown to shown + 1\n    say "."\n\n// Append " (enthaelt ...)" to a container or supporter just named. "enthaelt"\n// takes the accusative, so the contents are listed with ${a:acc x}.\nblock list_contents(holder)\n    if holder is supporter\n        list_contents_run(holder)\n        return 0\n    if holder is container\n        list_contents_run(holder)\n    return 0\n\nblock list_contents_run(holder)\n    let total = 0\n    for each x in holder\n        if content_listable(holder, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    show(" (enthält ")\n    let shown = 0\n    for each x in holder\n        if content_listable(holder, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" und ")\n                else\n                    show(", ")\n            show("${a:acc x}")\n            now x is seen\n            change shown to shown + 1\n    show(")")\n    return 0\n\n// After a container is opened, name what is revealed inside (marking it seen).\n// "Darin findest du" governs the accusative.\nblock reveal_contents(holder)\n    let total = 0\n    for each x in holder\n        if content_listable(holder, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    show("Darin findest du ")\n    let shown = 0\n    for each x in holder\n        if content_listable(holder, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" und ")\n                else\n                    show(", ")\n            show("${a:acc x}")\n            now x is seen\n            change shown to shown + 1\n    say "."\n\n// One line of a room\'s contents listing. "Du siehst hier" governs the accusative.\nblock list_item(obj)\n    show("Du siehst hier ")\n    show("${a:acc obj}")\n    // Ein verschließbares Ding, das zu ist, sagt es (Pablo Martínez\' Vorschlag,\n    // der PunyInform-Qualifier): der eine Zustand, den das Listing sonst nicht\n    // verrät. Das Prädikativ beugt sich nicht, also reicht EIN Wort.\n    if obj is openable\n        if obj is not open\n            show(" (geschlossen)")\n    show_tag(obj)\n    list_contents(obj)\n    say "."\n\n// Parser.\n// The player typed a word the story\'s dictionary does not know at\n// all: name it (spelled back from the text buffer), so a typo is\n// told apart from a real thing that is not here.\nblock msg_unknown_word()\n    show("Das Wort \\"")\n    let p = word_pos(unknown_at) - 2\n    let n = word_len(unknown_at)\n    let i = 0\n    while i < n\n        show_char(text_char(p + i))\n        change i to i + 1\n    say "\\" kennt diese Geschichte nicht."\n\n// Ein nacktes Verb ("nimm", "öffne") fragt nach, mit dem Verb wie\n// getippt als Echo ("Nimm was?"). Der erste Buchstabe wird nur im\n// ASCII-Bereich großgeschrieben; ein Umlaut-Anfang bleibt wie getippt.\nblock msg_noun_missing()\n    let p = word_pos(0) - 2\n    let n = word_len(0)\n    let i = 0\n    while i < n\n        let c = text_char(p + i)\n        if i is 0\n            if c >= 97\n                if c <= 122\n                    change c to c - 32\n        show_char(c)\n        change i to i + 1\n    say " was?"\n\n// Die beyond-Abweisung (docs/01): sichtbar, aber die Hand kommt nicht hin.\nblock msg_beyond(obj)\n    if any_pluribus is 1\n        say "${The obj} ${is obj} außer Reichweite."\n        return 0\n    say "${The obj} ist außer Reichweite."\n\nblock msg_cant_see()\n    say "So etwas siehst du hier nicht."\n\nblock msg_open_first()\n    say "Dazu musst du erst ${the:acc shut_in} öffnen."\n\nblock msg_no_it()\n    say "Du musst schon genau sagen, was gemeint ist."\n\nblock msg_be_specific()\n    say "Du musst dich schon etwas genauer ausdrücken."\n\n// Die Rueckfrage bei Mehrdeutigkeit (docs/02 Abschnitt 8): der Rahmen um die\n// Kandidatenliste des Parsers ("Was meinst du: die goldene Münze oder den\n// Schlüssel?"). Nach "meinen" steht der Akkusativ, darum ${the:acc obj}.\nblock line_which_open()\n    show("Was meinst du: ")\n\nblock line_which_or()\n    show(" oder ")\n\nblock line_which_item(obj)\n    show("${the:acc obj}")\n\nblock line_which_end()\n    say "?"\n\nblock msg_nothing_again()\n    say "Es gibt nichts zu wiederholen."\n\nblock msg_only_animate()\n    say "Wenn du weiter mit Gegenständen redest, wird wohl die nächste Sitzung beim Therapeuten fällig."\n\n// Conversation lines. The speaker label, the separator, and the quotation marks\n// live here. line_reply receives the speaking person; ${The x} prints a named\n// person bare (Linda) and others with the article (der Wächter).\nblock line_you()\n    show("Du: \\"")\n\nblock line_reply(speaker)\n    show("${The speaker}: \\"")\n\nblock line_end()\n    say "\\""\n\n// Conversation menu framing (the conversations granule). "sprich mit" governs the\n// dative; "über" heads the topic list.\nblock line_talk_header(who)\n    show("Sprich mit ${the:dat who} über:")\n\nblock line_talk_prompt()\n    show("Wähle ein Thema oder beende mit 0.")\n\nblock msg_no_topics()\n    say "Dir fällt gerade nichts Sinnvolles ein."\n\nblock msg_talk_over()\n    say "Du beendest das Gespräch."\n\n// The status line\'s score side (the statusline granule): score and moves,\n// right-aligned, in German words and widths. "Punkte: " is eight cells like the\n// English "Score: " string it replaces; the wide form adds "   Zuege: ".\nblock line_status_score(w)\n    if any_awards is 0\n        set_cursor(1, w - 7 - status_digits(turns))\n        show("Züge: ")\n        show(turns)\n        return 0\n    if w < 54\n        set_cursor(1, w - 9 - status_digits(score) - status_digits(turns))\n        show("Punkte: ")\n        show(score)\n        show("/")\n        show(turns)\n    else\n        set_cursor(1, w - 17 - status_digits(score) - status_digits(turns))\n        show("Punkte: ")\n        show(score)\n        show("   Züge: ")\n        show(turns)\n\n// Room and light.\nblock msg_dark_room()\n    say "Völlige Dunkelheit. Nicht einmal deine Hände kannst du sehen."\n\nblock msg_too_dark()\n    say "Es ist zu dunkel, um etwas zu erkennen."\n\n// Movement.\nblock msg_cant_go()\n    say "Es gibt keinen Ausgang in diese Richtung."\n\nblock msg_no_direction()\n    say "In welche Richtung?"\n\nblock msg_cant_enter()\n    say "In ${the:acc noun} kommst du nicht hinein."\n\nblock msg_already_there()\n    say "Du bist schon hier."\n\nblock msg_not_inside()\n    say "Du bist in nichts, aus dem du aussteigen könntest."\n\n// Auf-/Einsteigen und Ab-/Aussteigen (board_report / leave_report). auf/in mit\n// Bewegung fordern den Akkusativ, von/aus den Dativ. (Zur Durchsicht: Stefan.)\nblock msg_get_on()\n    say "Du steigst auf ${the:acc noun}."\n\nblock msg_get_in()\n    say "Du steigst in ${the:acc noun}."\n\nblock msg_get_off()\n    say "Du steigst von ${the:dat noun} herunter."\n\nblock msg_get_out()\n    say "Du steigst aus ${the:dat noun}."\n\nblock msg_cant_climb()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} nicht zum Klettern geeignet."\n        return 0\n    say "${The noun} ist nicht zum Klettern geeignet."\n\n// Sensory.\n// Sich selbst betrachten, ohne dass player.desc gesetzt ist.\nblock msg_examine_self()\n    say "Bewundern wir uns noch eine Weile, oder spielen wir jetzt ein\n         Adventure?"\n\nblock msg_nothing_special()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "An ${the:dat noun} ist nichts Besonderes zu sehen."\n            return 0\n    say "An ${the:dat noun} ist nichts Besonderes zu sehen."\n\nblock msg_touch()\n    say "Du berührst ${the:acc noun}. Nichts, was deine Augen nicht schon gesehen hätten."\n\nblock msg_smell()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} riechen ungefähr so, wie du es erwartet hast."\n            return 0\n    say "${The noun} riecht ungefähr so, wie du es erwartet hast."\n\nblock msg_listen()\n    say "Du horchst und nichts antwortet."\n\nblock msg_taste()\n    say "Lieber nicht."\n\n// Carrying and giving. German past participles used as terse replies do not\n// inflect, so a single word serves every gender.\nblock msg_taken()\n    say "Genommen."\n\nblock msg_fixed()\n    // Das Pronomen richtet sich nach dem Geschlecht: die Tür bleibt, wo SIE\n    // ist; der Schrank, wo ER ist; das Buch, wo ES ist. Der Plural zuerst:\n    // die Stiefel bleiben, wo sie sind.\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} bleiben ziemlich genau, wo sie sind."\n            return 0\n    if noun is feminine\n        say "${The noun} bleibt ziemlich genau, wo sie ist."\n        return 0\n    if noun is neutral\n        say "${The noun} bleibt ziemlich genau, wo es ist."\n        return 0\n    say "${The noun} bleibt ziemlich genau, wo er ist."\n\nblock msg_animate_refuses()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} haben andere Pläne."\n            return 0\n    say "${The noun} hat andere Pläne."\n\nblock msg_have_it()\n    say "Du hast ${the:acc noun} bereits."\n\nblock msg_take_self()\n    say "Dich selbst zumindest hast du fest im Griff."\n\n// Ein Bestandteil bleibt an seinem Ganzen; der Artikel steht im Dativ (zu).\n// Leaving a named thing the player is not actually in (exit noun).\nblock msg_not_in_that()\n    say "Da bist du nicht drin."\n\nblock msg_part_of()\n    let p = parent_of(noun)\n    show("Das gehört zu ")\n    art_the(p, 0, 2)\n    say "."\n\nblock msg_dropped()\n    // Verschachtelt sagt die Zeile wohin (Akkusativ: auf den Altar, in\n    // die Kiste). Entfaellt ohne betretbare Dinge.\n    if any_enterable is 1\n        if parent_of(player) is not here\n            if parent_of(player) is supporter\n                show("Fallen gelassen, auf ")\n            else\n                show("Fallen gelassen, in ")\n            art_the(parent_of(player), 0, 1)\n            say "."\n            return 0\n    say "Fallen gelassen."\n\nblock msg_not_holding()\n    say "Du hast ${the:acc noun} nicht bei dir."\n\nblock msg_done()\n    say "Erledigt."\n\nblock msg_put_where()\n    say "Worauf, oder worin?"\n\nblock msg_cant_put()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} können das nicht fassen."\n            return 0\n    say "${The second} kann das nicht fassen."\n\nblock msg_closed()\n    if any_pluribus is 1\n        say "${The second} ${is second} geschlossen."\n        return 0\n    say "${The second} ist geschlossen."\n\nblock msg_to_whom()\n    say "Wem?"\n\nblock msg_give()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} wollen ${the:acc noun} nicht. Skandal."\n            return 0\n    say "${The second} will ${the:acc noun} nicht. Skandal."\n\nblock msg_show()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} scheinen sich nicht dafür zu interessieren."\n            return 0\n    say "${The second} scheint sich nicht dafür zu interessieren."\n\n// Wearing.\nblock msg_worn()\n    say "Angezogen."\n\nblock msg_already_worn()\n    say "Du trägst ${the:acc noun} bereits."\n\nblock msg_cant_wear()\n    say "Du kannst ${the:acc noun} nicht anziehen."\n\nblock msg_removed()\n    say "Ausgezogen."\n\nblock msg_not_worn()\n    say "Du trägst ${the:acc noun} nicht."\n\n// Doors, containers, locks. "offen", "zu", "abgeschlossen" are predicate\n// adjectives and stay uninflected across genders.\nblock msg_opened()\n    say "Geöffnet."\n\nblock msg_already_open()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} schon offen."\n        return 0\n    say "${The noun} ist schon offen."\n\nblock msg_cant_open()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} lassen sich nicht öffnen."\n            return 0\n    say "${The noun} lässt sich nicht öffnen."\n\nblock msg_open_locked()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} abgeschlossen."\n        return 0\n    say "${The noun} ist abgeschlossen."\n\nblock msg_door_locked(d)\n    if any_pluribus is 1\n        say "${The d} ${is d} abgeschlossen."\n        return 0\n    say "${The d} ist abgeschlossen."\n\nblock msg_door_shut(d)\n    if any_pluribus is 1\n        say "${The d} ${is d} zu. Du musst ${the:acc d} erst öffnen."\n        return 0\n    say "${The d} ist zu. Du musst ${the:acc d} erst öffnen."\n\nblock msg_closed_it()\n    say "Geschlossen."\n\nblock msg_already_shut()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} schon geschlossen."\n        return 0\n    say "${The noun} ist schon geschlossen."\n\nblock msg_cant_close()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} lassen sich nicht schließen."\n            return 0\n    say "${The noun} lässt sich nicht schließen."\n\nblock msg_locked()\n    say "Abgeschlossen."\n\n// Neu (Cosmos 0.37): abgeschlossen-bereits und nicht-abgeschlossen. Sachlich\n// gehalten; Stefans Feinschliff-Durchgang gibt ihnen den frechen Ton.\nblock msg_already_locked()\n    say "Schon abgeschlossen."\n\nblock msg_not_locked()\n    say "${The noun} ist gar nicht abgeschlossen; du öffnest ${the:acc noun}."\n\nblock msg_cant_lock()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} lassen sich nicht abschließen."\n            return 0\n    say "${The noun} lässt sich nicht abschließen."\n\nblock msg_close_first()\n    say "Zuerst musst du ${the:acc noun} schließen."\n\n// Bewusst ohne Namen: ein nacktes SCHLIESS AUF darf nicht verraten,\n// welcher Schlüssel zu einem noch unentdeckten Schloss passt.\nblock msg_no_key()\n    say "Dir fehlt der passende Schlüssel."\n\nblock msg_wrong_key()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} passen nicht."\n            return 0\n    say "${The second} passt nicht."\n\nblock msg_unlocked()\n    say "Aufgeschlossen."\n\nblock msg_cant_unlock()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} lassen sich nicht aufschließen."\n            return 0\n    say "${The noun} lässt sich nicht aufschließen."\n\n// Operating.\nblock msg_no_switch()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} lassen sich nicht einschalten."\n            return 0\n    say "${The noun} lässt sich nicht einschalten."\n\nblock msg_already_on()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} schon an."\n        return 0\n    say "${The noun} ist schon an."\n\nblock msg_already_off()\n    if any_pluribus is 1\n        say "${The noun} ${is noun} schon aus."\n        return 0\n    say "${The noun} ist schon aus."\n\nblock msg_no_effect()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} rühren sich nicht."\n            return 0\n    say "${The noun} rührt sich nicht."\n\n// Body, action, idle.\nblock msg_attack()\n    say "Auf Dinge einzuschlagen hilft selten, und daran wird sich auch jetzt nichts ändern."\n\nblock msg_eat()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} stehen nicht auf dem Speiseplan."\n            return 0\n    say "${The noun} steht nicht auf dem Speiseplan."\n\nblock msg_drink()\n    say "Nichts hier ist es wert, getrunken zu werden."\n\nblock msg_jump()\n    say "Du hüpfst auf der Stelle herum. Nichts passiert, aber es tat gut."\n\nblock msg_wait()\n    say "Die Zeit vergeht."\n\nblock msg_kiss()\n    say "Das ist gerade nicht der richtige Moment."\n\nblock msg_sing()\n    say "Du bringst ein paar Töne heraus. Der Raum bleibt ungerührt."\n\n// Conversation.\nblock msg_no_talk()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} scheinen nicht zum Reden aufgelegt."\n            return 0\n    say "${The noun} scheint nicht zum Reden aufgelegt."\n\nblock msg_use_talk()\n    say "Um mit ${the:dat noun} weiterzukommen, benutze SPRICH MIT\n         ${the:dat noun}."\n\nblock msg_ask()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} lassen sich zu dem Thema nichts entlocken."\n            return 0\n    say "${The noun} lässt sich zu dem Thema nichts entlocken."\n\nblock msg_tell()\n    say "${The noun} nimmt die Neuigkeit mit großartiger Gleichgültigkeit\n         zur Kenntnis."\n\nblock msg_answer()\n    say "Deine Worte bleiben unbeantwortet."\n\n// Inventory.\nblock msg_carrying()\n    say "Du trägst mit dir:"\n\nblock msg_empty_handed()\n    say "Du hast rein gar nichts bei dir."\n\n// Scenery default.\nblock msg_scenery()\n    say "Das gehört nur zur Kulisse. Kümmere dich nicht darum."\n\n// Printed when the first word names no verb or direction.\nblock msg_no_verb()\n    say "Diese Worte ergeben keinen Sinn."\n\n// The verb was understood, but it cannot use the words that followed it.\nblock msg_extra_words()\n    say "Nach dem Verb konnte ich nicht mehr folgen."\n\n// Read a yes/no answer; returns 1 for an answer that starts with j or J (ja). The\n// caller prints the question first, so this is shared by every confirmation.\nblock yes_no()\n    let term = read_input\n    let c = text_char(0)\n    if c is 106\n        return 1\n    if c is 74\n        return 1\n    return 0\n\n// Ask the player to confirm quitting; returns 1 for yes.\nblock confirm_quit()\n    show("Willst du wirklich aufhören? ")\n    return yes_no\n\n// The farewell, overridable for a custom send-off.\nblock msg_farewell()\n    say "Dann lassen wir es für heute gut sein."\n\nblock msg_game_over()\n    say "Möchtest du NEU STARTEN, einen Spielstand LADEN oder BEENDEN?"\n\n// Nur nach einem `death`-Ende: der Weg zurück steht zur Wahl.\nblock msg_game_over_died()\n    say "Möchtest du NEU STARTEN, einen Spielstand LADEN, den letzten Zug WIDERRUFEN oder BEENDEN?"\n\nblock msg_game_over_unknown()\n    say "Das war keine der Möglichkeiten."\n\n// How many things the player wears; the pure count beside list_worn, so a\n// story can guard its phrasing ("You\'re dressed in nothing at all") before\n// printing a prefix. Both cost nothing unless called (DCE).\nblock worn_count()\n    let n = 0\n    for each x in player\n        if x is worn\n            change n to n + 1\n    return n\n\n// Print what the player wears as a punctuated list, "einen Hut, einen Umhang und\n// Stiefel", with no framing and no newline: the story writes its own prose\n// around it. Returns the count. The two-pass count-then-join shape is the\n// library\'s own listing idiom (list_contents_run).\nblock list_worn()\n    let total = worn_count\n    let shown = 0\n    for each x in player\n        if x is worn\n            if shown is not 0\n                if shown is total - 1\n                    show(" und ")\n                else\n                    show(", ")\n            show("${a:acc x}")\n            change shown to shown + 1\n    return total\n\n\n// Meta verbs.\nblock msg_score()\n    if any_awards is 0\n        say "Dieses Spiel zählt keine Punkte."\n        return 0\n    show("Du hast ${score} von ${max_score} Punkten in ")\n    show(turns)\n    if turns is 1\n        show(" Zug")\n    else\n        show(" Zügen")\n    show(" erreicht")\n    if any_ranks is 1\n        show(". Das bringt dir den Rang: ")\n        print_rank\n    say "."\n\nblock msg_confirm_restart()\n    show("Von vorne beginnen? ")\n\nblock msg_xyzzy()\n    say "Nichts passiert, aber für einen Moment fühlst du dich clever."\n\nblock msg_saved()\n    say "Gespeichert."\n\nblock msg_save_failed()\n    say "Beim Speichern ist etwas schiefgegangen."\n\nblock msg_restore_failed()\n    say "Dieser Spielstand ließ sich nicht laden."\n\nblock msg_transcript_on()\n    say "Mitschrift läuft. Ab jetzt wird alles aufgezeichnet."\n\nblock msg_transcript_off()\n    say "Mitschrift beendet."\n\nblock msg_transcript_already()\n    say "Die Mitschrift läuft schon."\n\nblock msg_transcript_not_on()\n    say "Es läuft gerade keine Mitschrift."\n\nblock msg_transcript_failed()\n    say "Es ist keine Mitschrift zustande gekommen."\n\nblock msg_undone()\n    say "Rückgängig gemacht."\n\nblock msg_cant_undo()\n    say "Es gibt nichts rückgängig zu machen."\n\nblock msg_cant_oops()\n    say "Es gibt nichts zu korrigieren."\n\n// One line of an inventory listing; a worn item is tagged, a container or\n// supporter names what it holds. A bare list reads as nominative.\nblock list_held(obj)\n    show("  ")\n    show("${a obj}")\n    if obj is worn\n        show(" (getragen)")\n    show_tag(obj)\n    list_contents(obj)\n    say ""\n',
    'infocom_talking.granule': "// infocom_talking.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// summon.infocom_talking: the Infocom-style ask/tell presentation of the\n// `topic` model. ASK <person> ABOUT <subject> (and TELL) scans the typed\n// words for a subject one of the person's visible topics answers to (01\n// section 15; topics live in the person's body), runs it, and falls back to\n// the standard flat default when nothing matches. There is no topic list\n// anywhere: discovery is play, the Infocom way.\n//\n// This granule holds ONLY logic: the ask/tell verb words, their grammar, and\n// every message live in the language layer, so an infocom_talking game is as\n// translatable as any other (the packs carry the words and the lines; the\n// flat defaults msg_ask/msg_tell/msg_answer are called only from here, so\n// they cost every other game nothing). It overrides the standard\n// ask_to/tell_to/answer_to seams; the guards (can't see, only animate)\n// already ran in the standard handlers.\n//\n// The conversations menu is the OTHER presentation of the same topics, and a\n// game picks exactly one: summoning both is a compile error. An author\n// settles on one conversation model; the topics themselves are identical\n// either way, so switching later is a one-line change.\n\nblock ask_to(person)\n    if converse(person) is 1\n        return 0\n    msg_ask\n\nblock tell_to(person)\n    if converse(person) is 1\n        return 0\n    msg_tell\n\nblock answer_to(person)\n    msg_answer\n\n// Find and run a topic the player named. Scanning the typed words for one a\n// visible topic answers to (in declaration order) lets ask and tell share one\n// path: a topic matches on its subject words, not on which verb reached it.\n// Returns 1 if a topic ran, so the seam knows whether to speak the default.\nblock converse(person)\n    let count = topics_count(person)\n    let i = 0\n    while i < count\n        if topic_visible(person, i)\n            if subject_typed(person, i)\n                topic_run(person, i)\n                return 1\n        change i to i + 1\n    return 0\n\n// Did the player type a word this topic answers to (one of its match words)?\nblock subject_typed(person, i)\n    let n = word_count\n    let w = 1\n    while w < n\n        let target = word_dict(w)\n        if target is not nothing\n            if topic_matches(person, i, target)\n                return 1\n        change w to w + 1\n    return 0\n",
    'loop.prelude': '// loop.prelude\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// The turn loop (docs/02 section 10), the heart of a running game. The compiler\n// hands control here after printing the banner (the __main__ shim). The loop\n// fires the opening event, describes the starting room, then repeats: prompt,\n// parse, dispatch the action, fire the per-turn events, count the turn. A `finish`\n// in any handler quits, ending the loop.\n\n// The status bar, painted into row 1 of the current upper window. The default is\n// empty; summon.statusline overrides it to draw the room/score bar. Factoring it\n// out this way lets the conversations menu paint the same bar at the top of its\n// window, so the two features coexist, while a game with neither pays nothing.\nblock status_bar()\n    return 0\n\n// How many rows the status bar occupies: 0 by default, 1 once statusline is\n// summoned. The conversations menu reads this to know whether to leave room 1 for\n// the bar or reclaim it for the topic list, so it never wastes a blank line.\nblock status_lines()\n    return 0\n\n// Is the room name already on screen in a status bar? 0 by default; the\n// statusline granule overrides it to 1, and the opening room description\n// then skips its title line (the bar says where you are), so the opening\n// prose scrolls straight under the bar: Stefan\'s start-screen design.\n// Later looks print the title as usual.\nblock title_in_bar()\n    return 0\n\n// The current rank (docs/01, Scoring): the highest ladder entry at or\n// under the score, thresholds computed by the compiler from the summed\n// max_score. The packs\' msg_score calls this; folds away with any_ranks.\nblock print_rank()\n    let t = ranks_table\n    if t is 0\n        return 0\n    let n = peek_word(t, 0)\n    let best = 0\n    let i = 0\n    while i < n\n        if score >= peek_word(t, 1 + i * 2)\n            change best to peek_word(t, 2 + i * 2)\n        change i to i + 1\n    if best is not 0\n        print_packed(best)\n    return 0\n\n// The author\'s state qualifier, appended to a listed object: "a fluid\n// canister (full)". `tag` is a text property, usually computed (tag block);\n// the packs\' listing lines call this, and it folds away with any_tagged in\n// a game that tags nothing.\nblock show_tag(obj)\n    if any_tagged is 1\n        if tag_addr(obj) is not 0\n            show(" (")\n            show("${obj.tag}")\n            show(")")\n    return 0\n\n// TAKE ALL\'s expander: the takeall granule overrides this with the real\n// sweep (docs/05); the stub exists so the hand-off call resolves, and it\n// folds away with its caller in a game that never summons the granule.\nblock run_all(act)\n    return 0\n\n// The plural sweep: the plurals granule overrides this to run the action on\n// every in-scope object whose `plural` vocabulary carries the group word w\n// ("take coins"). Stub for the same reason as run_all.\nblock run_plural(act, w)\n    return 0\n\n// One swept item, shared by the takeall and plurals granules: name it, run\n// the real action through the full pipeline (an object\'s own handlers still\n// override), then the per-turn pulse: EACH SWEPT ITEM IS A FULL TURN, the\n// same rule a chained line follows. The pending break is dropped so the\n// sweep prints as one compact report; a daemon that printed text mid-sweep\n// already made its own paragraph. Dead code without either granule.\nblock sweep_one(obj, act)\n    change par_pending to 0\n    print_name(obj)\n    show(": ")\n    change noun to obj\n    dispatch(act)\n    // Each swept item is a full turn, so it takes the after pass too\n    // (docs/02 s.9 step 6; folds away without an `on after` in the game).\n    if any_after is 1\n        if grain is 0\n            if refused is 0\n                let aft = after_of(act)\n                if aft is not 0\n                    dispatch(aft)\n    // last_here is captured BEFORE the pulse: a scenery quip answers for the\n    // room it ran in, and the pulse may relocate the player (a teleport in\n    // each_turn), which is the one way a grain replay can go stale.\n    if any_grains is 1\n        change last_here to here\n    fire_turn\n    tick\n    change last_act to act\n    change last_noun to noun\n    change last_second to second\n    change last_way to way\n    change last_grain to grain\n    return 0\n\n// The post-mortem, after a finish banner: the final score, then the\n// classic prompt until the player picks a way out. The answer words are\n// whatever the language pack declared for the restart/restore/quit verbs,\n// matched by their ACTIONS, so every language works without a line here.\nblock game_over()\n    par\n    msg_score\n    while true\n        par\n        // A death offers the way back; a finish (a victory, a completed\n        // story) stays final: a won game must stay won. The whole choice\n        // folds to the classic prompt in a game with no death statement.\n        if any_death is 1\n            if died is 1\n                msg_game_over_died\n            else\n                msg_game_over\n        else\n            msg_game_over\n        prompt\n        let n = read_line\n        let handled = 0\n        let d = word_dict(0)\n        if d is not nothing\n            if peek_byte(d + 6) is 128\n                let act = peek_byte(d + 7)\n                if act is action_id("restart")\n                    do_restart\n                if act is action_id("restore")\n                    // A successful restore never returns here (it resumes at\n                    // the save point); reaching the next line means failure.\n                    let r = do_restore\n                    change handled to 1\n                    msg_restore_failed\n                if act is action_id("undo")\n                    if any_death is 1\n                        if died is 1\n                            // Take back the fatal command (the checkpoint\n                            // every turn takes, before it dispatched): on\n                            // success restore_undo resumes inside run_turn,\n                            // which reports the undo and redescribes the\n                            // room, so this line is only reached when the\n                            // interpreter has no undo to give. After a\n                            // finish, undo falls to "not one of the\n                            // choices": a won game stays won.\n                            let u = do_restore_undo\n                            change handled to 1\n                            msg_cant_undo\n                if act is action_id("quit")\n                    do_quit\n        if handled is 0\n            msg_game_over_unknown\n\nblock run_game()\n    move player to here\n    // The start room is visited by definition (and never scores: you did\n    // not earn arriving where you begin).\n    now here is visited\n    // `on start` runs FIRST (Inform\'s Initialise order): the game sets up its\n    // world and its screen (colours, which erase the screen to repaint it)\n    // before anything is drawn. THEN the library prints the banner, onto the\n    // screen the game just established, so setting zcolor.background in\n    // `on start` no longer erases the banner out from under itself.\n    run_free(ev_start)\n    if auto_banner is 1\n        // One newline before the banner: it steps the title down to row 2 so a\n        // summoned status bar (which splits and paints row 1 at the first\n        // prompt) does not overwrite it, and it separates any text `on start`\n        // printed above from the banner. This is the placement the compiler\n        // used before the banner moved into the loop.\n        new_line\n        print_banner\n    // Separate the banner (and any text `on start` printed above it) from the\n    // opening room description: one blank line, collapsed with describe_room\'s.\n    par\n    if title_in_bar is 1\n        change hide_title to 1\n    describe_room\n    while true\n        prompt\n        run_chain(parse)\n        // Snapshot the line\'s unrecognized word (verb or noun, if any) so a\n        // following "oops" can correct it. Done here, after both the understood\n        // and the unknown-verb paths, so a mistyped verb is correctable too.\n        // After a chained line the buffer holds its last command, so oops\n        // corrects exactly the command the player last saw fail.\n        note_oops\n\n// Carry out a parsed command, then any commands chained after it on the same\n// line ("take the lamp and open the door then go north", docs/02 section 8b).\n// The chain stops the moment a command fails: a parse failure, or a turn a\n// refusal path could not carry out (`refused`, set by the library\'s refusals\n// and settable by a story handler). What was already done stays done.\nblock run_chain(act)\n    while true\n        change refused to 0\n        if act is 0\n            if parse_fault is 1\n                msg_cant_see\n            else\n                if parse_fault is 2\n                    msg_extra_words\n                else\n                    if parse_fault is 3\n                        msg_be_specific\n                    else\n                        if parse_fault is 4\n                            msg_unknown_word\n                        else\n                            // Fault 5: a pronoun with nothing to refer to\n                            // (IT before anything was named, THEM with no\n                            // group, a Spanish clitic left unbound).\n                            if parse_fault is 5\n                                msg_no_it\n                            else\n                                if word_count is not 0\n                                    msg_no_verb\n            return 0\n        run_turn(act)\n        if refused is not 0\n            return 0\n        if chain_pos is 0\n            return 0\n        // Remember this command\'s action: a verb-less next segment borrows\n        // it ("take lamp and box", the noun lists of docs/02 section 8b).\n        change chain_prev to act\n        // Each chained command\'s response is its own paragraph.\n        par\n        change act to chain_next\n\n// Run an action as part of the CURRENT turn, the way the player\'s own\n// command would dispatch it: Inform\'s <<take book>>, Dialog\'s (try ...).\n// Reached through the perform intrinsic, perform("take", book): the action\n// name resolves at compile time, the operands default to nothing, and a\n// direction rides the way slot (perform("go", west)), because go reads\n// way, never noun. The full pipeline runs: the can\'t/won\'t refusals, the\n// handler chain, the messages, and the after phase; then the enclosing\n// command\'s own operands come back, so the outer turn (and a later AGAIN)\n// still sees what the player actually typed. Returns 1 when the action\n// carried, 0 when it refused; the enclosing turn\'s own refused flag is\n// untouched either way. No new undo point and no extra turn tick: it is\n// one turn\'s work. Costs nothing unless called (DCE).\nblock cosmos_perform(act, obj, other)\n    let sn = noun\n    let ss = second\n    let sw = way\n    let sg = grain\n    let sr = refused\n    change refused to 0\n    change grain to 0\n    if act is action_id("go")\n        change way to obj\n        change noun to nothing\n    else\n        change noun to obj\n        change way to nothing\n    change second to other\n    dispatch(act)\n    if any_after is 1\n        if refused is 0\n            let aft = after_of(act)\n            if aft is not 0\n                dispatch(aft)\n    let ok = 1\n    if refused is not 0\n        change ok to 0\n    change noun to sn\n    change second to ss\n    change way to sw\n    change grain to sg\n    change refused to sr\n    return ok\n\n// Carry out one understood command. Undo is handled here, not through dispatch:\n// every other command first takes an undo checkpoint (save_undo), so that a later\n// undo rewinds to just before it. When save_undo returns 2 the machine has just\n// resumed here via restore_undo, meaning the previous turn is being taken back.\nblock run_turn(act)\n    change meta_turn to 0\n    // The named object is known but shut inside a closed container: tell the\n    // player to open it rather than carrying out the action on something sealed.\n    if shut_in is not nothing\n        change meta_turn to 1\n        change refused to 1\n        msg_open_first\n        return 0\n    if act is action_id("undo")\n        change meta_turn to 1\n        do_undo\n        return 0\n    if act is action_id("oops")\n        change act to fix_oops\n        if act is 0\n            change meta_turn to 1\n            change refused to 1\n            return 0\n    if act is action_id("again")\n        if last_act is 0\n            change meta_turn to 1\n            change refused to 1\n            msg_nothing_again\n            return 0\n        // The world may have moved on since the command was typed: an\n        // operand that has left scope refuses now, exactly as retyping the\n        // command would, instead of acting on a ghost (the field report was\n        // a lantern spirited to nothing, forever examinable through AGAIN).\n        // A scenery quip is bound to its room the same way.\n        if last_noun is not nothing\n            if not in_scope(last_noun)\n                change meta_turn to 1\n                change refused to 1\n                msg_cant_see\n                return 0\n        if last_second is not nothing\n            if not in_scope(last_second)\n                change meta_turn to 1\n                change refused to 1\n                msg_cant_see\n                return 0\n        if any_grains is 1\n            if last_grain is not 0\n                if here is not last_here\n                    change meta_turn to 1\n                    change refused to 1\n                    msg_cant_see\n                    return 0\n        // Replay the previous command by restoring its resolved operands, then\n        // fall through to dispatch it exactly as a fresh turn.\n        change act to last_act\n        change noun to last_noun\n        change second to last_second\n        change way to last_way\n        change grain to last_grain\n    let r = do_save_undo\n    if r is 2\n        change meta_turn to 1\n        // The rewound state may date from the middle of a chained line or\n        // carry a pending sweep hand-off; taking a turn back must not\n        // replay either. Each guard folds away without its granule.\n        change chain_pos to 0\n        if any_allwords is 1\n            change all_go to 0\n        if any_plurals is 1\n            change plural_go to 0\n        msg_undone\n        par\n        describe_room\n        return 0\n    // A pending sweep (TAKE ALL, "take coins") replaces the ordinary\n    // dispatch: one undo checkpoint for the whole sweep (it is one typed\n    // command), each swept item still a full turn inside the granule.\n    if any_allwords is 1\n        if all_go is 1\n            change all_go to 0\n            run_all(act)\n            return 0\n    if any_plurals is 1\n        if plural_go is not 0\n            let w = plural_go\n            change plural_go to 0\n            run_plural(act, w)\n            return 0\n    dispatch(act)\n    // The after phase: the action ran; if nothing refused it, the `on after`\n    // handlers walk the same chain under the action\'s synthetic after number\n    // (docs/02 section 9 step 6). The library\'s can\'t/won\'t paths all set\n    // `refused`, and a story handler that refuses should too. A grain turn\n    // is a scenery quip, not a world action, so it takes no after pass. In\n    // a game with no `on after` anywhere, any_after folds all this away.\n    if any_after is 1\n        if grain is 0\n            if refused is 0\n                let aft = after_of(act)\n                if aft is not 0\n                    dispatch(aft)\n    if meta_turn is 0\n        // last_here is captured BEFORE the pulse: a scenery quip answers for\n        // the room it ran in, and the pulse may relocate the player (a\n        // teleport in each_turn), the one way a grain replay can go stale.\n        if any_grains is 1\n            change last_here to here\n        fire_turn\n        tick\n        // Remember a real (non-meta) command so a later "again" can repeat it.\n        change last_act to act\n        change last_noun to noun\n        change last_second to second\n        change last_way to way\n        change last_grain to grain\n    return 0\n\n// Undo the previous turn. restore_undo, on success, resumes at the save_undo in\n// run_turn (it does not return here); so reaching the line after it means the\n// undo failed, and reaching here with no turns yet means there is nothing to take\n// back.\nblock do_undo()\n    change refused to 1\n    if turns is 0\n        msg_cant_undo\n        return 0\n    let r = do_restore_undo\n    msg_cant_undo\n    return 0\n\n// Fire the current room\'s `on enter` (the loop and the go verb call this after\n// the player arrives). The handler may move the player elsewhere (a bounce).\nblock fire_enter()\n    if here is not nothing\n        let r = handler_of(here)\n        if r is not nothing\n            call_handler(r, ev_enter)\n\n// The per-turn pulse, in reach order: the room\'s `on each_turn`, then every\n// in-scope object\'s (a daemon on a thing, active while the thing is here or\n// carried), then the free `on each_turn` rules, then the after/every schedule.\n// Each handler\'s `when` guard is compiled into the handler itself; the schedule\n// counts down and fires anything now due.\nblock fire_turn()\n    if here is not nothing\n        let r = handler_of(here)\n        if r is not nothing\n            par\n            call_handler(r, ev_each_turn)\n    fire_object_turns(here)\n    fire_object_turns(player)\n    par\n    run_free(ev_each_turn)\n    par\n    tick_timers\n\n// Fire the `on each_turn` of every object within `holder` that the player can see\n// into it, recursing into supporters and open or clear containers the same way\n// scope does, so an object\'s daemon runs exactly while the object is in scope.\nblock fire_object_turns(holder)\n    for each obj in holder\n        if obj is not hidden\n            let r = handler_of(obj)\n            if r is not nothing\n                par\n                call_handler(r, ev_each_turn)\n            if see_into(obj)\n                fire_object_turns(obj)\n\n// Draw the current room\'s picture (arc_image, B11), or clear the band when the\n// room has none. Only reached behind `any_images` (compile-time) and only draws\n// on an interpreter that reports picture support (pictures_available, run time),\n// so a text-only interpreter never issues the opcode. The `shown_image` dedup is\n// the performance guard Stefan asked for: a re-LOOK in the same room changes\n// nothing, so the picture is never reloaded (a retro target would otherwise\n// re-decompress its image on every look). A game can override this block to\n// change the rendering policy. The mode operand is arc_mode, the game\'s picture\n// mode (band height in text rows, 9 or 12), so the interpreter knows the band\n// size from the opcode alone, without loading the picture.\nblock draw_room_image()\n    if pictures_available is 1\n        let id = image_of(here)\n        if id is not shown_image\n            draw_image(id, arc_mode)\n            change shown_image to id\n\n// Describe the current room: its name, its description, and what it contains.\n// The title line adds where the player stands when nested inside or on\n// something ("Crypt (on the altar)"): the wording is the language layer\'s\n// line_nested, and the whole check folds away, byte-identical, in a game\n// with nothing to climb into (any_enterable).\nblock describe_room()\n    par\n    if is_lit is 0\n        msg_dark_room\n        return\n    if any_images is 1\n        draw_room_image\n    if hide_title is 1\n        change hide_title to 0\n    else\n        if any_enterable is 1\n            print_name(here)\n            if parent_of(player) is not here\n                line_nested(parent_of(player))\n            new_line\n        else\n            say here\n    if desc_addr(here) is not nothing\n        say here.desc\n    let listed = 0\n    // Two shapes of the same loop body, chosen at compile time\n    // (any_appearance): an object with an `appearance` ALWAYS owns its\n    // paragraph (Inform\'s describe, Dialog\'s appearance), before intro\'s\n    // until-moved rule and the plain listing; a game without one keeps\n    // the original body, byte-identical.\n    for each obj in here\n        if obj is not player and obj is not hidden and obj is not concealed\n            if any_appearance is 1\n                if appearance_addr(obj) is not nothing\n                    par\n                    say obj.appearance\n                    change listed to 0\n                else\n                    if intro_addr(obj) is not nothing and obj is not moved\n                        par\n                        say obj.intro\n                        change listed to 0\n                    else\n                        if obj is not scenery\n                            if listed is 0\n                                par\n                            change listed to 1\n                            list_item(obj)\n            else\n                if intro_addr(obj) is not nothing and obj is not moved\n                    par\n                    say obj.intro\n                    change listed to 0\n                else\n                    if obj is not scenery\n                        if listed is 0\n                            par\n                        change listed to 1\n                        list_item(obj)\n    // The scenery pass (constant scenery_contents = 1, the PunyInform\n    // OPTIONAL_PRINT_SCENERY_CONTENTS bridge): what sits on or in a\n    // scenery holder gets its own paragraph ("On the table you can see\n    // a jar."), worded by the language layer. Off by default; folds away.\n    if any_scenery_contents is 1\n        for each obj in here\n            if obj is scenery and obj is not hidden and obj is not concealed\n                scenery_holder_line(obj)\n\n// How many digits a non-negative number prints as (scores and turn counts stay\n// well under five). Used to right-align the score block without a string length.\nblock status_digits(n)\n    if n < 10\n        return 1\n    if n < 100\n        return 2\n    if n < 1000\n        return 3\n    return 4\n',
    'matrix.granule': "// matrix.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// An opt-in feature: summon it with `summon.matrix`. A matrix is the mutable\n// sibling of a catalog. A catalog is fixed data you read many ways (entry,\n// calculate, last, for each, membership); a matrix is the same, made\n// mutable-in-LENGTH: you append and remove and insert at runtime. Reach for\n// one only when a collection genuinely grows or shrinks as the game plays, or\n// when you want a two-dimensional table. For almost everything else a catalog\n// is smaller and faster on 8-bit hardware; prefer it.\n//\n// A matrix shares the catalog region, its __catalogs__ base, and the header\n// shape [count, capacity, cells]. It is a catalog's [count, widest] with the\n// never-used widest word holding the CAPACITY instead, so count is the LIVE\n// length (mutable) and capacity is the reserved bound. Every catalog READ\n// verb already works on a matrix unchanged; only these MUTATORS and the\n// declaration are new. They live here, in editable Arcturus, not baked into\n// the compiler: override a block by declaring one of the same name.\n//\n// Each block takes the matrix as a runtime word offset `m` into the region\n// (the compiler passes the constant at the call site). A cell at 1-based\n// index i sits at word m + 1 + i; the count is at m and the capacity at m + 1.\n// Everything is peek_word / poke_word against catalogs_base, exactly like the\n// shared `position` scan, so there is no heap and no per-operation library:\n// each mutator is a short routine, and any it does not use is dead-code\n// eliminated. Calls carry at most three operands (the Z-machine call limit),\n// which is why the capacity rides the header rather than an argument.\n\n// append v: grow the length by one, writing v into the first free cell.\n// Returns 1, or 0 when the matrix is already full (the author's to test:\n// `if append v to m is 0`).\nblock matrix_append(m, v)\n    let n = peek_word(catalogs_base, m)\n    if n >= peek_word(catalogs_base, m + 1)\n        return 0\n    poke_word(catalogs_base, m + 2 + n, v)\n    poke_word(catalogs_base, m, n + 1)\n    return 1\n\n// remove the entry at 1-based index i. Order-preserving by default (shift the\n// tail down); `swap` moves the last entry into the hole instead, O(1) but\n// unordered. Returns 1, or 0 when i is out of range.\nblock matrix_remove_at(m, i, swap)\n    let n = peek_word(catalogs_base, m)\n    if i < 1\n        return 0\n    if i > n\n        return 0\n    if swap is 1\n        poke_word(catalogs_base, m + 1 + i, peek_word(catalogs_base, m + 1 + n))\n    else\n        let j = i\n        while j < n\n            poke_word(catalogs_base, m + 1 + j, peek_word(catalogs_base, m + 2 + j))\n            change j to j + 1\n    poke_word(catalogs_base, m, n - 1)\n    return 1\n\n// remove the first entry equal to v (by value). Returns 1, or 0 when v is not\n// present. Shares the `position` scan with catalogs.\nblock matrix_remove_val(m, v, swap)\n    let i = position(m, v)\n    if i is 0\n        return 0\n    return matrix_remove_at(m, i, swap)\n\n// insert v so it becomes the new entry at 1-based index i, shifting the tail\n// up. Returns 1, or 0 when the matrix is full or i is out of range (1..n+1).\nblock matrix_insert(m, i, v)\n    let n = peek_word(catalogs_base, m)\n    if n >= peek_word(catalogs_base, m + 1)\n        return 0\n    if i < 1\n        return 0\n    if i > n + 1\n        return 0\n    let j = n\n    while j >= i\n        poke_word(catalogs_base, m + 2 + j, peek_word(catalogs_base, m + 1 + j))\n        change j to j - 1\n    poke_word(catalogs_base, m + 1 + i, v)\n    poke_word(catalogs_base, m, n + 1)\n    return 1\n\n// load a catalog's values into the matrix as its new contents, replacing what\n// was there. The count becomes the catalog's, clamped to the matrix capacity\n// (the compiler checks the fit for a named catalog, so the clamp is a runtime\n// backstop). Returns how many entries were copied.\nblock matrix_load(m, src)\n    let cap = peek_word(catalogs_base, m + 1)\n    let n = peek_word(catalogs_base, src)\n    if n > cap\n        change n to cap\n    let i = 1\n    while i <= n\n        poke_word(catalogs_base, m + 1 + i, peek_word(catalogs_base, src + 1 + i))\n        change i to i + 1\n    poke_word(catalogs_base, m, n)\n    return n\n",
    'nautical.granule': '// nautical.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// An opt-in feature: summon it with `summon.nautical`. The four nautical\n// directions, FORE, AFT, PORT, and STARBOARD, for a game set aboard a ship,\n// a submarine, or a deep space craft, where the compass fails: cardinal\n// directions are measured around the pole of a planet, and in deep space\n// there is no pole (the Hibernated problem, solved here the way Hibernated\n// solved it).\n//\n// The direction PROPERTIES (fore, aft, port, starboard) are part of the\n// compiler\'s standard set, so an exit reads like any other and the whole\n// pipeline already understands it: `fore engine_room` on a room, `on go\n// fore` in a handler, `if way is aft`, teleports and conveys alike. Like\n// every direction, a property costs nothing in a game that never writes an\n// exit with it. What this granule adds is the PLAYER-FACING WORDS, exactly\n// as the language layer declares the compass words; unsummoned, the words\n// are not in the dictionary and typing "fore" is an ordinary unknown word.\n//\n// The abbreviations: F for fore and SB for starboard (the classic ship\'s\n// shorthand); AFT and PORT are already as short as spoken. A is not offered\n// for aft, because a language pack needs it as an article. Nautical and\n// compass directions coexist: a lighthouse game may use both.\n//\n// A vessel is a volume, not a deck plan (a submarine, a crow\'s nest), so\n// the nautical vocabulary is 3D: ALOFT and BELOW ride the existing up and\n// down properties as extra words, exactly as spoken aboard. They are NOT\n// gated by dirs_nautical below, because they are synonyms of universal\n// directions: gating them would gate every cellar staircase ashore.\n//\n// WHERE NAUTICAL WORDS APPLY: dirs_nautical, a flag, true by default (a\n// pure ship game never touches it). Set it false when the player steps\n// ashore and true at the gangplank back, and FORE/AFT/PORT/STARBOARD then\n// refuse honestly ("Nautical directions mean nothing here.") instead of\n// the misleading "no exit that way" (a field request). The message is a\n// msg block, so a story rewords it; the whole gate costs nothing while\n// the flag stays true.\n//\n// IF YOUR GAME BEGINS ASHORE: the default is true (aboard), so set the\n// flag false at the very start, not only when stepping off the boat, or\n// the OPENING room treats nautical directions as live and answers "no\n// exit" there. An `on start` rule does it:\n//\n//   on start\n//       change dirs_nautical to false\n//\n// The compiler notes this for you when the start room has no nautical\n// exit (a field report: the opening room is the one place a step-off\n// handler cannot reach).\n//\n// The words are English, like every granule\'s wording: a translation forks\n// this file beside its language pack (docs/05).\n\ndirection fore      "fore", "f"\ndirection aft       "aft"\ndirection port      "port"\ndirection starboard "starboard", "sb"\ndirection up        "aloft"\ndirection down      "below"\n\nflag dirs_nautical = true\n\n// The gate, a free rule ahead of the library\'s walk (granule origin runs\n// first): ashore, the four nautical-only words answer for themselves.\non go\n    if dirs_nautical is false\n        if way is fore or way is aft\n            change refused to 1\n            msg_no_nautical\n            stop\n        if way is port or way is starboard\n            change refused to 1\n            msg_no_nautical\n            stop\n    continue\n\nblock msg_no_nautical()\n    say "Nautical directions mean nothing here."\n',
    'parser.prelude': '// parser.prelude\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// The language-agnostic parser skeleton (docs/02 section 8). It reads a line,\n// asks the language layer (english.prelude, swappable per summon.language) to\n// identify the verb and resolve the noun, and reports the result. It makes no\n// assumption about word order, articles, or inflection; all of that lives in the\n// language layer. Two-noun grammar, prepositions, and disambiguation are wired\n// with the turn loop and the verbs in B4.5e.\n\n// Copy n bytes from src to dst (used to snapshot and restore the parse buffer\n// for oops). A plain byte loop; the regions do not overlap.\nblock copy_bytes(src, dst, n)\n    let i = 0\n    while i < n\n        poke_byte(dst + i, peek_byte(src + i))\n        change i to i + 1\n    return 0\n\n// Read and parse one command. Returns the action number (0 if none was\n// understood) and sets the noun. A 0 return with parse_fault set means a verb was\n// understood but the rest did not fit: parse_fault 1 named an object out of scope\n// (the loop reports "can\'t see"), parse_fault 2 piled extra words onto a verb\n// that has no slot for them (the loop reports "extra words"), parse_fault 3 is\n// an ambiguity the player did not resolve, parse_fault 4 a typed word the\n// dictionary does not know at all (unknown_at holds its index; the loop names\n// it back), and parse_fault 5 a pronoun with nothing to refer to (IT before\n// anything was named, THEM with no group; the loop asks the player to say\n// what they mean). A noun slot that HAD words but resolved nothing always\n// faults, so a handler seeing noun = nothing can trust the player typed the\n// bare verb, and the handlers ask their question (msg_noun_missing).\n// Read one line of player input. When an input colour is set (zcolor.input),\n// the typed text prints in that colour and the base font colour returns the\n// moment the line is entered, the way PunyInform\'s clr_fginput works. With no\n// input colour this is a plain read.\nblock read_input()\n    // Every fresh line claims the one text buffer, so a chained tail still\n    // queued there dies with it (a confirmation asked mid-turn: quit, restart).\n    change chain_pos to 0\n    if zc_input is not 0\n        set_colour(zc_input, 0)\n    let term = read_line\n    if zc_input is not 0\n        set_colour(zc_font, 0)\n    return term\n\n// The remembered referent for a canonical pronoun role (docs/02 section 8a):\n// 1 it, 2 him, 3 her, 4 them. The language layer\'s note_pronouns fills the\n// slots as nouns resolve; scope_match reads them back when a pronoun is typed.\nblock pronoun_slot(role)\n    if role is 1\n        return pron_it\n    if role is 2\n        return pron_him\n    if role is 3\n        return pron_her\n    if role is 4\n        return pron_them\n    return nothing\n\n// Notice a resolved noun so a later pronoun can refer to it: skip nothing and\n// skip the player (the player is never IT/HIM/HER), then let the language layer\n// file it in the right slot. Called for both nouns, so a two-object command\n// binds both.\nblock note_referent(obj)\n    if obj is nothing\n        return 0\n    if obj is player\n        return 0\n    note_pronouns(obj)\n\nblock parse()\n    let term = read_input\n    // A fresh line borrows no verb from the last one (noun lists, 8b).\n    change chain_prev to 0\n    // Remember the full typed length: chain_next restores it when it wakes the\n    // queued rest of a chained line (docs/02 section 8b).\n    change chain_max to peek_byte(text_addr + 1)\n    return parse_line\n\n// Parse the command now in the buffers: the whole typed line on the first\n// call, or the re-tokenized tail of a chained line when chain_next re-enters.\nblock parse_line()\n    change parse_fault to 0\n    change shut_in to nothing\n    if word_count is 0\n        return 0\n    chain_split\n    let act = resolve_verb\n    if act is 0\n        // A verb-less chained segment borrows the previous command\'s verb:\n        // "take lamp and box" runs the take twice (docs/02 section 8b).\n        change act to verb_fallback\n        if act is 0\n            return 0\n    // The held tiebreak\'s direction for this command (the matcher applies\n    // it where a tie is found): most verbs mean the thing in hand, TAKE\n    // means the one not yet there.\n    change tie_want to 1\n    if act is action_id("take")\n        change tie_want to 0\n    change way to find_direction\n    resolve_objects\n    // An ambiguous noun phrase asks rather than refuses: "Which do you\n    // mean, the gold coin or the silver coin?" (docs/02 section 8).\n    if parse_fault is 3\n        return ask_which\n    if parse_fault is not 0\n        return 0\n    // A tabled verb\'s matched grammar line may have chosen its own action\n    // (look_under under noun); the flag path leaves line_act at 0.\n    if any_tables is 1\n        if line_act is not 0\n            change act to line_act\n    // Remember what the pronouns now mean: the language layer decides which\n    // slot each noun fills (English by animacy, German by grammatical gender).\n    // Both nouns are noticed, so after "show coin to bob" IT is the coin and\n    // HIM is Bob; when both fall in one slot the second wins, the last thing\n    // named. The player is never a pronoun referent.\n    note_referent(noun)\n    note_referent(second)\n    // TAKE ALL (summon.takeall): a typed all-word hands the command to the\n    // granule\'s expander; a bound noun rides along as the source ("take all\n    // from the chest"). The guard folds away without the granule.\n    if any_allwords is 1\n        if all_typed is 1\n            change all_go to 1\n    // A language may remap the action now the nouns are known (English turns\n    // LOOK <noun> into an examine); the seam lives in the language layer.\n    return remap_action(act)\n\n// ==========================================================================\n// The noun matcher (docs/02 section 8). Language-agnostic: the packs\' thin\n// match_noun/resolve_two_nouns hand their word ranges to match_phrase here.\n// ==========================================================================\n\n// How many of the typed words in [lo, hi) this object\'s vocabulary contains.\n// Membership in the object\'s own `words` is the whole test: a word that also\n// serves as a verb or particle elsewhere still counts (a person named Pat,\n// "pat" the verb), because has_word compares dictionary entries, not flags.\nblock phrase_score(obj, lo, hi)\n    let s = 0\n    let i = lo\n    while i < hi\n        let d = word_dict(i)\n        if d is not nothing\n            if has_word(obj, d)\n                change s to s + 1\n            else\n                if any_plurals is 1\n                    if has_plural(obj, d) is 1\n                        change s to s + 1\n        change i to i + 1\n    return s\n\n// A side-effect-free probe: the single in-scope object the words in [lo, hi)\n// name, or nothing when none matches or two tie. Unlike match_phrase it sets no\n// parse_fault and asks nothing, so the reversed-dative split can try candidate\n// boundaries without disturbing the real parse. Folds away with the reverse\n// grammar it serves (no give/show reverse line, no caller, DCE drops it).\nblock probe_noun(lo, hi)\n    let best = nothing\n    let best_score = 0\n    let tied = 0\n    let obj = 1\n    while obj <= object_count\n        if obj is not hidden\n            let s = phrase_score(obj, lo, hi)\n            if s > 0\n                if in_scope(obj)\n                    if s > best_score\n                        change best to obj\n                        change best_score to s\n                        change tied to 0\n                    else\n                        if s is best_score\n                            change tied to 1\n        change obj to obj + 1\n    if best_score is 0\n        return nothing\n    if tied is 1\n        return nothing\n    return best\n\n// ==========================================================================\n// The positional grammar matcher (docs/02 section 8c). A verb whose grammar\n// the flag model cannot represent (a leading preposition on a two-noun verb,\n// "dig in noun with held", or wording that selects the action, "look_under\n// under noun") carries a TABLE: its lines in matcher order, each an action\n// byte, one byte per token (1 noun, 2 held, 3 multi, 4 text; 5 a literal\n// word, its dictionary address in the next two bytes), and a closing zero; a\n// zero in action position ends the table. The matcher walks the typed words\n// against each line and the first line whose shape fits wins: its action\n// goes to line_act, its slots resolve through match_phrase. Everything here\n// folds away (any_tables) in a game whose verbs all fit the flag model.\n// ==========================================================================\n\n// The dictionary address of the next literal token on this grammar line, or\n// 0 when only slots and the line\'s end remain (a slot then absorbs to the\n// end of the command).\nblock next_literal(tok)\n    let t = peek_byte(tok)\n    while t is not 0\n        if t is 5\n            return peek_word(tok + 1, 0)\n        change tok to tok + 1\n        change t to peek_byte(tok)\n    return 0\n\n// Does this line fit the typed words, position by position? A literal token\n// must BE the typed word at its place; a slot absorbs the words up to the\n// line\'s next literal (scanning ahead for it; a line whose literal the\n// player did not type cannot match) or to the end; and the whole command\n// must be consumed. On a fit the slots resolve through the scoring matcher,\n// with the same faults as the classic path: a tie asks (fault 3), a\n// named-but-unresolved noun on a two-slot line is rejected (fault 1), a\n// one-slot miss falls to the debug reach, scenery, and the honest can\'t-see.\n// An EMPTY slot stays nothing and the action asks its own question ("dig\n// what?"). Returns 1 when the line matched (any fault stands), 0 to try the\n// next line.\n// The index of the first typed direction word in [p, n), or 0 when there is\n// none (word 0 is always the verb, so 0 is free to mean "none"). try_line\n// calls this rather than scanning inline: it already carries the Z-machine\'s\n// full 15 local slots.\nblock dir_scan(p, n)\n    while p < n\n        let d = word_dict(p)\n        if d is not nothing\n            if peek_byte(d + 6) is 64\n                return p\n        change p to p + 1\n    return 0\n\nblock try_line(line, n)\n    let tok = line + 1\n    let p = 1\n    let slots = 0\n    let s1lo = 0\n    let s1hi = 0\n    let s2lo = 0\n    let s2hi = 0\n    let t = peek_byte(tok)\n    while t is not 0\n        if t is 5\n            // A literal: the typed word here must be exactly this word.\n            if p >= n\n                return 0\n            let lw = peek_word(tok + 1, 0)\n            if word_dict(p) is not lw\n                return 0\n            change p to p + 1\n            change tok to tok + 3\n        else\n            if t is 6\n                // A direction slot (swim direction, push noun direction):\n                // the typed word here must be a direction word. Its value\n                // needs no binding: the parser set `way` from the line\n                // before the tables ran, so consuming the word is the job.\n                // (dir_scan, not a local: this routine sits at the\n                // Z-machine\'s 15-slot ceiling already.)\n                if p >= n\n                    return 0\n                if dir_scan(p, p + 1) is 0\n                    return 0\n                change p to p + 1\n                change tok to tok + 1\n            else\n                // A slot: absorb up to this line\'s next literal, or, when a\n                // direction slot closes the line, up to the first typed\n                // direction word (PUSH CRATE WEST: the noun is "crate"),\n                // or to the end.\n                let edge = n\n                let litw = next_literal(tok + 1)\n                if litw is not 0\n                    change edge to p\n                    let found = 0\n                    while found is 0\n                        if edge >= n\n                            return 0\n                        if word_dict(edge) is litw\n                            change found to 1\n                        else\n                            change edge to edge + 1\n                else\n                    if peek_byte(tok + 1) is 6\n                        change edge to dir_scan(p, n)\n                        if edge is 0\n                            return 0\n                change slots to slots + 1\n                if slots is 1\n                    change s1lo to p\n                    change s1hi to edge\n                else\n                    change s2lo to p\n                    change s2hi to edge\n                change p to edge\n                change tok to tok + 1\n        change t to peek_byte(tok)\n    if p < n\n        return 0\n    // The shape fits: resolve the slots.\n    if slots is 0\n        return 1\n    if s1hi > s1lo\n        let pl = 0\n        if slots is 1\n            change pl to 1\n        change noun to match_phrase(s1lo, s1hi, pl)\n        if parse_fault is not 0\n            return 1\n        if noun is nothing\n            // A pending plural sweep ("take coins") binds per object later.\n            if any_plurals is 1\n                if plural_go is not 0\n                    return 1\n            if slots is 2\n                change parse_fault to noun_fault(s1lo, s1hi)\n                return 1\n            change noun to reach_unscoped\n            if noun is nothing\n                change grain to find_scenery\n                if grain is 0\n                    change parse_fault to named_unseen\n                    if parse_fault is 0\n                        change unknown_at to first_unknown(s1lo, s1hi)\n                        if unknown_at is not 0\n                            change parse_fault to 4\n            return 1\n    if slots is 2\n        if s2hi > s2lo\n            change second to match_phrase(s2lo, s2hi, 0)\n            if parse_fault is not 0\n                return 1\n            if second is nothing\n                change parse_fault to noun_fault(s2lo, s2hi)\n    return 1\n\n// Try a tabled verb\'s lines in table order (most literal words first, so a\n// bare noun slot cannot swallow a wording a more specific line spells out).\n// The first line that fits sets line_act and the nouns; no fit at all means\n// the verb was understood but the rest was not (fault 2, "you lost me").\nblock grammar_match(tbl)\n    let n = word_count\n    let act = peek_byte(tbl)\n    while act is not 0\n        if try_line(tbl, n) is 1\n            change line_act to act\n            return 1\n        // Step past this line\'s tokens to the next line\'s action byte.\n        change tbl to tbl + 1\n        let k = peek_byte(tbl)\n        while k is not 0\n            if k is 5\n                change tbl to tbl + 3\n            else\n                change tbl to tbl + 1\n            change k to peek_byte(tbl)\n        change tbl to tbl + 1\n        change act to peek_byte(tbl)\n    change parse_fault to 2\n    return 0\n\n// Is this word in the object\'s plural (group) vocabulary? The plurals\n// granule\'s counterpart of has_word (docs/05); a game without `plural`\n// declarations has no property and the intrinsic answers 0.\nblock has_plural(obj, target)\n    let addr = plural_addr(obj)\n    if addr is nothing\n        return 0\n    let count = plural_count(obj)\n    let i = 0\n    while i < count\n        if peek_word(addr, i) is target\n            return 1\n        change i to i + 1\n    return 0\n\n// The plurals granule\'s hooks (summon.plurals overrides them; the stubs fold\n// away with their any_plurals guards). plural_tie claims a tie made by a\n// group word ("take coins"); plural_them claims a typed THEM.\nblock plural_tie(lo, hi)\n    return 0\n\nblock plural_them()\n    return 0\n\n// NOUN LISTS, a core parser feature (docs/02 section 8b): a chained segment\n// with no verb of its own borrows the previous command\'s verb, so "take lamp\n// and box" runs as take lamp, take box, one full turn each. The list words\n// are the chain words, which the language layer already localizes, so this\n// works in every language. Only a segment that starts with something\n// noun-like (an object word, a pronoun) qualifies; anything else keeps the\n// honest "those words don\'t add up to anything".\nblock verb_fallback()\n    if chain_prev is 0\n        return 0\n    // Every word must be KNOWN and at least one noun-like. Articles qualify\n    // because the language layer declares them as noise words ("take lamp\n    // and THE box", "coge la lampara y LA llave"); a genuinely unknown word\n    // is most likely a verb we do not know ("and frobnicate box"), and\n    // borrowing over it would silently run the wrong action.\n    let n = word_count\n    let i = 0\n    let named = 0\n    while i < n\n        let d = word_dict(i)\n        if d is nothing\n            return 0\n        if peek_byte(d + 6) is 0\n            change named to 1\n        if peek_byte(d + 6) is 4\n            change named to 1\n        change i to i + 1\n    if named is 1\n        return chain_prev\n    return 0\n\n// The index of the first typed word in [lo, hi) the dictionary does not\n// know at all, or 0 when every word is known. An unknown word can never\n// resolve, so the turn reports it by name rather than dispatching the\n// action with an empty noun (the custom-verb trap: "read sdlfjh" ran the\n// author\'s handler as if the player had typed a bare "read").\nblock first_unknown(lo, hi)\n    let i = lo\n    while i < hi\n        if word_dict(i) is nothing\n            return i\n        change i to i + 1\n    return 0\n\n// The fault for a noun slot that HAD typed words but resolved to nothing:\n// 4 (with unknown_at set, the turn names the word) when a word is not in\n// the dictionary at all; else 1, a real thing that is not here (can\'t see).\nblock noun_fault(lo, hi)\n    change unknown_at to first_unknown(lo, hi)\n    if unknown_at is not 0\n        return 4\n    return 1\n\n// Does the range name any object word at all (one the matcher could try)?\n// Distinguishes "took a shot at something and missed" (a can\'t-see fault)\n// from a command that named nothing resolvable in the first place.\nblock phrase_named(lo, hi)\n    let i = lo\n    while i < hi\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 0\n                return 1\n        change i to i + 1\n    return 0\n\n// Match one noun phrase (the typed words from lo up to hi) against scope.\n// Every in-scope object is scored by how many of the typed words its\n// vocabulary contains, and the single best match wins: with a brass hook and\n// an iron hook in scope, "hook" alone is ambiguous but "brass hook" resolves,\n// and typing more adjectives narrows further. A TIE at the best score is a\n// genuine ambiguity: parse_fault 3, and the turn asks the player rather than\n// silently taking whichever object happens to come first (docs/02 section 8).\n// A typed pronoun short-circuits to its remembered referent. When nothing in\n// scope matches at all, the closed-container knowledge gets its chance\n// (shut_search), so naming the coin you know is in the shut chest still\n// answers "you\'ll have to open it first" rather than "you can\'t see it".\nblock match_phrase(lo, hi, plural_ok)\n    let d = nothing\n    let i = lo\n    while i < hi\n        change d to word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 4\n                // THEM names the last group (the plurals granule): the sweep\n                // takes over, in the noun slot only.\n                if any_plurals is 1\n                    if plural_ok is 1\n                        if peek_byte(d + 7) is 4\n                            if plural_them is 1\n                                return nothing\n                let ref = pronoun_slot(peek_byte(d + 7))\n                if ref is not nothing\n                    if in_scope(ref)\n                        return ref\n                // A pronoun with nothing to refer to is its own honest\n                // fault (5, msg_no_it): the player pointed, but at nothing;\n                // neither a bare verb nor a thing that is elsewhere.\n                change parse_fault to 5\n                return nothing\n        change i to i + 1\n    let best = nothing\n    let best_score = 0\n    let tied = 0\n    let obj = 1\n    while obj <= object_count\n        if obj is not hidden\n            let s = phrase_score(obj, lo, hi)\n            if s > 0\n                if in_scope(obj)\n                    if s > best_score\n                        change best to obj\n                        change best_score to s\n                        change tied to 0\n                    else\n                        if s is best_score\n                            change tied to 1\n        change obj to obj + 1\n    if best_score is 0\n        change i to lo\n        while i < hi\n            change d to word_dict(i)\n            if d is not nothing\n                if peek_byte(d + 6) is 0\n                    let known = shut_search(here, d)\n                    if known is nothing\n                        change known to shut_search(player, d)\n                    if known is not nothing\n                        return known\n            change i to i + 1\n        return nothing\n    if tied is 1\n        // A tie made by a group word is not an ambiguity: "take coins" means\n        // every coin, and the plurals granule sweeps them (noun slot only).\n        if any_plurals is 1\n            if plural_ok is 1\n                if plural_tie(lo, hi) is 1\n                    return nothing\n        // Remember the phrase first (the tiebreak and the ask both read\n        // the ask_* range), then the held tiebreak: exactly one candidate\n        // on the side this verb wants (tie_want: in hand for most verbs,\n        // out of hand for TAKE) settles the tie silently, the mirror you\n        // carry over the guard\'s. Only a tie that survives becomes the\n        // genuine ambiguity, and parse_line runs the ask; ask_at is where\n        // an answer\'s narrowing words weave back in.\n        change ask_lo to lo\n        change ask_hi to hi\n        change ask_score to best_score\n        change ask_at to word_pos(hi - 1) + word_len(hi - 1)\n        if which_tiebreak(tie_want) is not nothing\n            return which_tiebreak(tie_want)\n        change parse_fault to 3\n        return nothing\n    return best\n\n// The first noun phrase after the verb, through the scoring matcher: from the\n// first non-preposition word up to the next grammar preposition (flag bit 3).\n// Only a true preposition ends the phrase: it is what separates a noun from\n// the subject of "ask the guard ABOUT the coin", and what "look AT coin"\n// reaches past. Any other word is phrase content; the scoring simply ignores\n// what no object\'s vocabulary carries, so a particle or direction word inside\n// the phrase costs nothing, and a person named Pat survives "pat" the verb.\nblock match_first_phrase()\n    let n = word_count\n    let lo = 1\n    // A borrowed-verb segment (the "box" leg of "take lamp and box") has no\n    // verb word: word 0 is already the noun, so the phrase starts there. A\n    // normal command\'s word 0 is a verb or a direction.\n    let d0 = word_dict(0)\n    if d0 is nothing\n        change lo to 0\n    else\n        if not (peek_byte(d0 + 6) is 128)\n            if not (peek_byte(d0 + 6) is 64)\n                change lo to 0\n    let going = 1\n    while going is 1\n        change going to 0\n        if lo < n\n            let d = word_dict(lo)\n            if d is not nothing\n                if peek_byte(d + 6) is 8 or peek_byte(d + 6) is 136\n                    change lo to lo + 1\n                    change going to 1\n    if lo >= n\n        return nothing\n    let hi = lo + 1\n    change going to 1\n    while going is 1\n        change going to 0\n        if hi < n\n            let e = word_dict(hi)\n            if e is nothing\n                change hi to hi + 1\n                change going to 1\n            else\n                let ef = peek_byte(e + 6)\n                if ef is not 8\n                    if ef is not 136\n                        change hi to hi + 1\n                        change going to 1\n    return match_phrase(lo, hi, 1)\n\n// Did the line name an all-word (dictionary flag 1)? Only consulted when\n// the takeall granule is summoned; without it the any_allwords guard folds\n// and dead-code elimination drops this block.\nblock all_typed()\n    let n = word_count\n    let i = 1\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 1\n                return 1\n        change i to i + 1\n    return 0\n\n// Print the question naming the tied candidates: "Which do you mean, the\n// gold coin or the silver coin?" The framing and the connectors come from\n// the language layer (line_which_*); the list itself is mechanical.\nblock list_which()\n    let total = 0\n    let obj = 1\n    while obj <= object_count\n        if obj is not hidden\n            if phrase_score(obj, ask_lo, ask_hi) is ask_score\n                if in_scope(obj)\n                    change total to total + 1\n        change obj to obj + 1\n    line_which_open\n    let shown = 0\n    change obj to 1\n    while obj <= object_count\n        if obj is not hidden\n            if phrase_score(obj, ask_lo, ask_hi) is ask_score\n                if in_scope(obj)\n                    if shown is not 0\n                        if shown is total - 1\n                            line_which_or\n                        else\n                            show(", ")\n                    line_which_item(obj)\n                    change shown to shown + 1\n        change obj to obj + 1\n    line_which_end\n\n// The held tiebreak (docs/02 section 8, a field rule): a tie where exactly\n// one candidate answers for the player\'s hands is not an ambiguity worth a\n// question. EXAMINE MIRROR with one in hand and one on the guard means the\n// held one; TAKE MIRROR in the same room means the one NOT held (taking\n// wants the takeable one), so the caller asks for the side the verb can do\n// something with. Returns the single candidate on that side, or nothing\n// when the tie genuinely stands (none there, or more than one).\nblock which_tiebreak(want_held)\n    let pick = nothing\n    let obj = 1\n    while obj <= object_count\n        if obj is not hidden\n            if phrase_score(obj, ask_lo, ask_hi) is ask_score\n                if in_scope(obj)\n                    let h = 0\n                    if player holds obj\n                        change h to 1\n                    if h is want_held\n                        if pick is not nothing\n                            return nothing\n                        change pick to obj\n        change obj to obj + 1\n    return pick\n\n// The disambiguation ask (docs/02 section 8): the phrase in [ask_lo, ask_hi)\n// tied between several objects at score ask_score. Ask which one, then read\n// the answer through the shared text buffer. An answer that starts with a\n// verb or a direction is a change of mind: it replaces the command outright.\n// Anything else is narrowing words: they are woven into the saved command\n// right after the ambiguous phrase (ask_at) and the whole line re-parses,\n// so the scoring does the rest ("hook" plus an answer of "brass" resolves\n// exactly like "brass hook" typed whole). An empty answer, or one the line\n// has no room for, gives up with the be-specific refusal.\nblock ask_which()\n    par\n    list_which\n    // Save the command; the answer claims the live buffer.\n    copy_bytes(text_addr, ask_addr, peek_byte(text_addr + 1) + 2)\n    let term = read_input\n    if word_count is 0\n        change parse_fault to 3\n        return 0\n    change chain_max to peek_byte(text_addr + 1)\n    let d = word_dict(0)\n    if d is not nothing\n        let f = peek_byte(d + 6)\n        if f is 128\n            return parse_line\n        if f is 64\n            return parse_line\n        if any_tables is 1\n            // A tabled verb (a positional grammar table instead of an arity)\n            // is a change of mind too.\n            if f is 144 or f is 152\n                return parse_line\n    let alen = peek_byte(ask_addr + 1)\n    let blen = peek_byte(text_addr + 1)\n    if alen + blen + 1 > peek_byte(text_addr)\n        change parse_fault to 3\n        return 0\n    // Weave: head, a space, the answer, then the rest of the original line.\n    // The answer moves right to make room; the regions can overlap, so it\n    // copies backward. The head and tail come from the untouched backup.\n    let i = blen\n    while i > 0\n        change i to i - 1\n        poke_byte(text_addr + ask_at + 1 + i, peek_byte(text_addr + 2 + i))\n    copy_bytes(ask_addr + 2, text_addr + 2, ask_at - 2)\n    poke_byte(text_addr + ask_at, 32)\n    copy_bytes(ask_addr + ask_at, text_addr + ask_at + 1 + blen, alen - ask_at + 2)\n    poke_byte(text_addr + 1, alen + blen + 1)\n    change chain_max to alen + blen + 1\n    retokenize\n    return parse_line\n\n// Command chaining (docs/02 section 8b). A chain word (the language layer\'s\n// `chain` declarations: "and", "then", the comma) ends the current command;\n// what follows runs as the next command once this one succeeds. The split is\n// buffer surgery, not copying: the typed length byte is cut down so the\n// tokenizer sees only the current command, while the tail stays where it was\n// typed; chain_pos remembers where it starts (0 when the line has no tail).\nblock chain_split()\n    change chain_pos to 0\n    let n = word_count\n    let i = 1\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 2\n                // Queue the tail past the chain word, skipping a run of them\n                // ("take lamp, then go north" chains once, not twice).\n                let j = i + 1\n                let skipping = 1\n                while skipping is 1\n                    change skipping to 0\n                    if j < n\n                        let t = word_dict(j)\n                        if t is not nothing\n                            if peek_byte(t + 6) is 2\n                                change j to j + 1\n                                change skipping to 1\n                if j < n\n                    change chain_pos to word_pos(j)\n                // Cut the line down to the current command and re-tokenize.\n                poke_byte(text_addr + 1, word_pos(i) - 2)\n                retokenize\n                return 0\n        change i to i + 1\n    return 0\n\n// Wake the queued rest of a chained line: blank everything already carried\n// out, restore the full typed length, re-tokenize, and parse what remains as\n// a fresh command (chain_split then splits off any further chain word).\nblock chain_next()\n    poke_byte(text_addr + 1, chain_max)\n    let i = 2\n    while i < chain_pos\n        poke_byte(text_addr + i, 32)\n        change i to i + 1\n    change chain_pos to 0\n    retokenize\n    return parse_line\n',
    'plurals.granule': '// plurals.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// THE PLURAL MODEL: summon it with `summon.plurals` (docs/05). Two things,\n// one coherent feature:\n//\n//   1. GROUP WORDS. An object declares the words that name it as part of a\n//      group (`plural coins` on each coin); "take coins" then runs the take\n//      on every coin in scope instead of asking which one.\n//   2. THEM. The pronoun for the last group: "take coins" then "drop them".\n//\n// (Noun lists, "take lamp and box", are CORE, not part of this granule: a\n// verb-less chained segment borrows the previous verb, docs/02 section 8b.)\n//\n// Every swept item is a FULL TURN, the same rule as a chained line and TAKE\n// ALL (a deliberate departure from Inform). The core deliberately omits the\n// group model; without the summon, every hook folds away.\n//\n// English-worded like every granule: a translation forks this file. Note\n// for Spanish: the plural clitics (-los/-las) already live in the core\n// Spanish pack, and bare "los"/"las" are the articles, so a Spanish fork\n// should keep the THEM part out rather than declare them as words.\n\n// The THEM word. This declaration is ALSO the compile-time marker the\n// any_plurals guard keys on: remove it and the whole granule folds away.\npronoun them "them"\n\n// A tie made by a group word is a group, not an ambiguity. Claim it when a\n// typed word in the phrase is plural vocabulary on at least two in-scope\n// objects: the word rides plural_go to the turn loop, which sweeps it.\nblock plural_tie(lo, hi)\n    let i = lo\n    while i < hi\n        let d = word_dict(i)\n        if d is not nothing\n            let count = 0\n            let obj = 1\n            while obj <= object_count\n                if obj is not hidden\n                    if has_plural(obj, d) is 1\n                        if in_scope(obj)\n                            change count to count + 1\n                change obj to obj + 1\n            if count > 1\n                change plural_go to d\n                return 1\n        change i to i + 1\n    return 0\n\n// A typed THEM names the last group, if there was one; the sweep re-runs\n// over that group word, so it honestly covers whatever of the group is\n// still in scope. With no group remembered, the ordinary pronoun path\n// answers (an empty them is the pronoun fault, msg_no_it).\nblock plural_them()\n    if last_plural is 0\n        return 0\n    change plural_go to last_plural\n    return 1\n\n// The group sweep (the run_plural stub in loop.prelude): the action runs on\n// every in-scope object whose plural vocabulary carries the group word, one\n// full turn each, through the shared sweep_one. The word is remembered for\n// a later THEM.\nblock run_plural(act, w)\n    change last_plural to w\n    let n = object_count\n    let count = 0\n    let obj = 1\n    while obj <= n\n        if obj is not hidden\n            if has_plural(obj, w) is 1\n                if in_scope(obj)\n                    change count to count + 1\n                    sweep_one(obj, act)\n        change obj to obj + 1\n    if count is 0\n        change refused to 1\n        msg_cant_see\n    return 0\n',
    'quotes.granule': '// quotes.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// THE QUOTE BOX (summon.quotes). A centered, reverse-video quote box in the\n// upper window, in the tradition of Infocom\'s Trinity: the classic way to open\n// a game with an epigraph. Designed for the retro targets first: the box is\n// centered from the interpreter-reported screen width, so it sits right on a\n// 40-column Commodore 64 and on a modern 100-column terminal alike.\n//\n// Usage: state the box size, then alternate quote_line and show(...), one\n// pair per line, and close with quote_done, which waits for a keypress and\n// clears the screen for whatever follows:\n//\n//   summon.quotes\n//\n//   on start\n//       quote(3, 37)\n//       quote_line\n//       show("In order to make an apple pie from")\n//       quote_line\n//       show("scratch, you must first create the")\n//       quote_line\n//       show("universe.        -- Carl Sagan")\n//       quote_done\n//\n// quote(lines, width) takes the number of text lines and the length of the\n// LONGEST line; the box adds one space of padding on each side and a blank\n// reverse row above and below. Lines print left-aligned inside the box; pad\n// with spaces by hand for a right-aligned attribution, exactly as you would\n// on paper. Text goes through show(...) directly (a string cannot travel\n// through a block parameter), which is why the API is line-then-show.\n//\n// The box has no player-facing words of its own, so it needs nothing from the\n// language packs and works identically in every language.\n\n// The box geometry, kept between the calls: the current row, the left column,\n// and the full box width (text width plus the padding spaces).\nglobal qb_row = 0\nglobal qb_left = 0\nglobal qb_width = 0\n\n// Paint the full reverse-video row at qb_row and leave the cursor at the text\n// position inside it, style still reverse, so a following show(...) prints\n// into the row. Internal; quote_line and quote_done call it.\nblock quote_fill()\n    set_cursor(qb_row, qb_left)\n    set_style(1)\n    let i = 0\n    while i < qb_width\n        show(" ")\n        change i to i + 1\n    set_cursor(qb_row, qb_left + 1)\n\n// Open a quote box for `lines` lines of text, the longest `width` characters.\n// Clears the screen, splits the upper window, and draws the box\'s top row.\nblock quote(lines, width)\n    // Drop any pending paragraph break: the screen is about to be erased, and\n    // an unconsumed break would otherwise flush as a newline into the box\'s\n    // first row and drag the whole layout off by one.\n    change par_pending to 0\n    // The whole box draws unbuffered (quote_done restores buffering): with the\n    // word-wrap buffer on, interpreters reorder the writes around set_cursor.\n    buffer_mode(0)\n    change qb_width to width + 2\n    let sw = screen_width\n    change qb_left to (sw - qb_width) / 2 + 1\n    if qb_left < 1\n        change qb_left to 1\n    erase_window(-1)\n    split_window(lines + 4)\n    set_window(1)\n    change qb_row to 2\n    quote_fill\n\n// Advance to the next line of the box. Follow with show("the line\'s text").\nblock quote_line()\n    change qb_row to qb_row + 1\n    quote_fill\n\n// Close the box: draw the bottom row, wait for a keypress, and clear the\n// screen. The status line, if summoned, redraws at the next prompt.\nblock quote_done()\n    change qb_row to qb_row + 1\n    quote_fill\n    set_style(0)\n    set_window(0)\n    read_key\n    erase_window(-1)\n    // erase -1 unsplits the whole screen, so give the status bar its row\n    // back before prose resumes: without this, the first line printed\n    // after a mid-game box lands on row 1 and the next prompt\'s bar\n    // repaint paints straight over it (found when quote_catalog\'s\n    // follow-up say vanished under the statusline).\n    if status_lines > 0\n        split_window(status_lines)\n    buffer_mode(1)\n    // The screen is fresh; no break is owed to it.\n    change par_pending to 0\n\n// The one-call form (docs/01, catalogs): draw the whole box from a text\n// catalog. The line count and the width of the longest line are read from\n// the catalog\'s header words, both computed at compile time from the\n// literals, so nothing is measured at run time and the author does no\n// arithmetic: declare the letter as a catalog, then quote_catalog(letter).\nblock quote_catalog(l)\n    let n = peek_word(catalogs_base, l)\n    let w = peek_word(catalogs_base, l + 1)\n    quote(n, w)\n    let i = 1\n    while i <= n\n        quote_line\n        print_packed(peek_word(catalogs_base, l + 1 + i))\n        change i to i + 1\n    quote_done\n',
    'scope.prelude': "// scope.prelude\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// Scope and light (docs/02 sections 5 and 6), written in Arcturus. Scope is the\n// set of objects the parser considers and an action may touch; light decides\n// whether the location is lit, which collapses scope to what the player carries\n// when dark. Closed/transparent container nuances and held-container recursion\n// are refined later; this covers the room, its contents, carried items, and the\n// contents of in-scope supporters and open containers.\n\n// Is the location lit? The room's own lit, or an in-scope object glowing.\nblock is_lit()\n    if here is lit\n        return 1\n    for each held in player\n        if held is lit\n            return 1\n    for each near in here\n        if near is lit\n            return 1\n    return 0\n\n// Does this object span the current room? A fixed object declared to span\n// several rooms (docs/01 section 5) lives in one room in the object tree but is\n// in scope in each room it spans, so a door reaches both sides and a piece of\n// scenery is referable from every room that can see it.\nblock spans_here(obj)\n    let addr = spans_addr(obj)\n    if addr is nothing\n        return 0\n    let count = spans_count(obj)\n    let i = 0\n    while i < count\n        if peek_word(addr, i) is here\n            return 1\n        change i to i + 1\n    return 0\n\n// A noun match among the objects that span the current room. They are in scope\n// here (spans_here) but do not live in this room's tree, so the room-and-carry\n// walk the matcher does first cannot reach them; this scan fills that gap. It\n// runs only when the ordinary match has already failed.\nblock spans_match(target)\n    let i = 1\n    while i <= object_count\n        if spans_here(i)\n            if i is not hidden\n                if has_word(i, target)\n                    return i\n        change i to i + 1\n    return nothing\n\n// The room across a door from where the player stands. A door joins two rooms:\n// it lives in one (its tree parent) and spans the other, so the far side is the\n// one that is not `here`. Returns nothing for a door with no second room.\nblock door_other_side(door)\n    let home = parent_of(door)\n    if here is home\n        let addr = spans_addr(door)\n        if addr is nothing\n            return nothing\n        return peek_word(addr, 0)\n    return home\n\n// Is obj in scope right now?\nblock in_scope(obj)\n    if obj is player\n        return 1\n    // Backstage (docs/01 section 5): an object placed `in scope` lives in an\n    // invisible room whose contents are in scope EVERYWHERE, light or dark:\n    // the home of a companion who follows, of parts of them, of anything the\n    // parser should always answer for. It is never listed (its room is never\n    // entered), so a backstage object defends itself in its own handlers.\n    // The check folds away in a game that places nothing there.\n    if any_scoperoom is 1\n        if obj is in scope_room\n            return 1\n    if is_lit is 0\n        // Dark: only what the player carries is in scope.\n        if obj in player\n            return 1\n        return 0\n    if obj is here\n        return 1\n    // Spanning objects are checked only in a game that has any; the guard folds\n    // away and the spans blocks drop out otherwise (docs/01 section 5).\n    if any_spans is 1\n        if spans_here(obj)\n            return 1\n    let p = parent_of(obj)\n    if p is here\n        return 1\n    if p is player\n        return 1\n    if p is not nothing\n        // A component (a lever in a machine, docs/01) is in scope wherever\n        // the thing it is part of is: the tree carries the relation, the\n        // attribute grants the visibility a plain thing's insides never get.\n        if any_components is 1\n            if obj is component\n                return in_scope(p)\n        // On a supporter, or inside a container the player can see into (open,\n        // clear, or lidless), that is itself in scope. see_into is the single\n        // rule both this and the noun matcher share.\n        if p is supporter\n            return in_scope(p)\n        if p is container\n            if see_into(p)\n                return in_scope(p)\n    return 0\n\n// Visible needs light (examining); reachable also needs to not be shut away.\nblock visible(obj)\n    if is_lit is 0\n        return 0\n    return in_scope(obj)\n\n// The shut container standing between the player's hand and the object, or\n// nothing when the way is clear. Sight and touch differ exactly here: a\n// closed CLEAR jar shows its coin (see_into) and still blocks the hand.\nblock reach_blocker(obj)\n    let p = parent_of(obj)\n    while p is not nothing\n        if p is here\n            return nothing\n        if p is player\n            return nothing\n        if p is container\n            if p is openable\n                if p is not open\n                    return p\n        change p to parent_of(p)\n    return nothing\n\n// Visible AND touchable: the documented contract (docs/02 section 5), which\n// taking and most physical actions want. `<obj> is reachable` reads it as a\n// predicate.\nblock reachable(obj)\n    if visible(obj) is 0\n        return 0\n    if reach_blocker(obj) is nothing\n        return 1\n    return 0\n",
    'spanish.granule': '// spanish.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// Spanish translation by Pablo Martínez.\n// https://github.com/ByteProject/Arcturus\n//\n// THE SPANISH LANGUAGE LAYER (informal, tuteo). A language pack, selected with\n// `summon.language "spanish"`, which compiles it in place of english.prelude. A\n// fork of the English layer: the language-agnostic parser logic in section 1 is\n// unchanged; the verbs, the direction words, the articles, and every message are\n// Spanish. The pack has had its native pass (Pablo Martínez, the maker of\n// PunyInformES, 2026-07). It has three parts, in order:\n//\n//   1. THE PARSER - the blocks that teach the parser how to read Spanish input:\n//      which word is the verb, how a noun phrase is matched, how directions and\n//      particles are recognized, and the oops correction. The language-agnostic\n//      skeleton that drives these lives in parser.prelude; these are its hooks.\n//   2. THE STANDARD VERBS - the vocabulary: every standard verb word and its\n//      grammar. The behaviour behind each action is agnostic and lives in\n//      actions.prelude, keyed by action name; only the words are here.\n//   3. THE MESSAGES - every line the library prints to the player, each an\n//      overridable block, plus the room and content listing that frames them.\n//\n// A verb\'s WORDS are Spanish and live here; a verb\'s LOGIC is not and lives in\n// actions.prelude.\n//\n// The self-identifying marker: this is the language pack for the code "spanish".\n// The compiler requires it to be chosen with summon.language, and rejects a plain\n// `summon spanish.granule` (which would leave English baked in).\nlanguage "spanish"\n\n// ==========================================================================\n// 1. THE PARSER\n// How English input becomes a verb, its nouns, and a direction.\n// ==========================================================================\n\n// Resolve the verb: the first word, if its dictionary entry is flagged a verb.\n// Returns the action number, or 0 if the first word is not a known verb.\n// Pliega los acentos del texto tecleado (el ProcessChars de PunyInformES):\n// á->a, é->e, í->i, ó->o, ú/ü->u, ñ->n, y se vuelve a analizar si cambió\n// algo. Así "cógela" funciona tecleado con su tilde, y el diccionario solo\n// necesita las formas sin acento para lo que el jugador escribe. Los códigos\n// son los del juego de caracteres ZSCII por defecto (Standard 1.1, 3.8.5).\nblock fold_accents()\n    let n = peek_byte(text_addr + 1)\n    let i = 0\n    let changed = 0\n    while i < n\n        let a = text_addr + 2 + i\n        let c = peek_byte(a)\n        if c is 169\n            poke_byte(a, 97)\n            change changed to 1\n        if c is 170\n            poke_byte(a, 101)\n            change changed to 1\n        if c is 171\n            poke_byte(a, 105)\n            change changed to 1\n        if c is 172\n            poke_byte(a, 111)\n            change changed to 1\n        if c is 173\n            poke_byte(a, 117)\n            change changed to 1\n        if c is 157\n            poke_byte(a, 117)\n            change changed to 1\n        if c is 206\n            poke_byte(a, 110)\n            change changed to 1\n        change i to i + 1\n    if changed is 1\n        retokenize\n\nblock resolve_verb()\n    fold_accents\n    let d = word_dict(0)\n    if d is not nothing\n        let flags = peek_byte(d + 6)\n        if any_tables is 1\n            // Un verbo con tabla de gramática (docs/02 sección 8c): los bytes\n            // de datos llevan la dirección de la tabla, cuyo primer byte es\n            // la acción de su primera línea; la línea de verdad la elige\n            // luego el matcher (line_act).\n            if flags is 144 or flags is 152\n                let tbl = peek_word(d + 7, 0)\n                return peek_byte(tbl)\n        if flags is 128 or flags is 136\n            let base = peek_byte(d + 7)\n            let p = find_particle\n            if p is not nothing\n                let c = compound(base, p)\n                if c is not nothing\n                    return c\n            return base\n        if flags is 64\n            return peek_byte(d + 7)\n    // ¿Ningún verbo al principio? Si en la frase aparece una dirección, sigue\n    // siendo una orden de ir: así el parser entiende "hacia arriba" o "para\n    // abajo", donde la primera palabra ni siquiera está en el diccionario.\n    if find_direction is not nothing\n        return action_id("go")\n    // Los clíticos de PunyInformES: una palabra desconocida que termina en\n    // -lo/-la/-le/-los/-las/-les suele ser un imperativo con su pronombre\n    // pegado ("cogela", "cógele"), y -te el reflexivo ("examinate"). Se borra\n    // el sufijo del texto tecleado, se vuelve a analizar el verbo, y el\n    // pronombre queda pendiente en `clitico` (2 lo/le, 3 la, 4 plurales, 5 el\n    // propio jugador) para que resolve_objects lo convierta en el sustantivo.\n    // Encadena con el recorte de la -r: "cogerla" -> "coger" -> "coge". Y de\n    // ahí también el truco del infinitivo: una desconocida que termina en -r\n    // pierde la -r y se reanaliza, con lo que "comer pan" encuentra "come".\n    if word_dict(0) is nothing\n        let len = word_len(0)\n        let base = text_addr + word_pos(0)\n        let cut = 0\n        let slot = 0\n        if len > 4\n            if peek_byte(base + len - 3) is 108\n                if peek_byte(base + len - 1) is 115\n                    let v = peek_byte(base + len - 2)\n                    if ((v is 111) or (v is 97)) or (v is 101)\n                        change cut to 3\n                        change slot to 4\n        if cut is 0\n            if len > 3\n                let m = peek_byte(base + len - 2)\n                let u = peek_byte(base + len - 1)\n                if m is 108\n                    if u is 111\n                        change cut to 2\n                        change slot to 2\n                    if u is 97\n                        change cut to 2\n                        change slot to 3\n                    // El leísmo: "cógele" para personas apunta al masculino.\n                    if u is 101\n                        change cut to 2\n                        change slot to 2\n                if m is 116\n                    if u is 101\n                        change cut to 2\n                        change slot to 5\n        if cut is not 0\n            let i = 0\n            while i < cut\n                poke_byte(base + len - 1 - i, 32)\n                change i to i + 1\n            retokenize\n            let act = resolve_verb\n            if act is not 0\n                change clitico to slot\n            return act\n        if len > 2\n            if peek_byte(base + len - 1) is 114\n                poke_byte(base + len - 1, 32)\n                retokenize\n                return resolve_verb\n    return 0\n\n// A verb particle after the verb (the "off" in "switch off"), as its id.\nblock find_particle()\n    let n = word_count\n    let i = 1\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 32\n                return peek_byte(d + 7)\n        change i to i + 1\n    return nothing\n\n// El clítico pendiente de la última orden: 0 ninguno, o la casilla del\n// pronombre (2 lo, 3 la, 4 los/las). Lo deja resolve_verb al separar un\n// clítico ("cogela" -> "coge" + la), y lo consume resolve_objects como el\n// sustantivo de la orden. Los clíticos NO son palabras del diccionario: "la"\n// y "los" son también los artículos, y marcarlos confundiría "coge la\n// lámpara".\nglobal clitico = 0\n\n// El objeto del jugador: las palabras de sí mismo a las que todo juego\n// responde ("examina a yo" no, pero "examinate" sí, y también estas), un\n// nombre imprimible y la marca de nombre propio contra el artículo. Un juego\n// añade las suyas con player.words.\n// Las palabras de encadenar (docs/02 sección 8b): cada una cierra una orden y\n// abre la siguiente en la misma línea ("coge la lámpara y abre la puerta,\n// luego ve al norte"). La coma cuenta como palabra propia, con o sin espacios.\nchain ",", "y", "luego"\n\n// Las palabras de relleno: los artículos que el parser conoce pero ignora.\n// Conocerlas importa: una lista de sustantivos puede llevarlas ("coge la\n// lámpara y la llave"), mientras que una palabra desconocida de verdad\n// rechaza el préstamo del verbo (docs/02 8b).\nnoise "el", "la", "los", "las", "un", "una", "unos", "unas", "al", "del"\n\nplayer.words yo, mismo\nplayer.name "ti mismo"\nplayer.named\n\n// A qué pronombre se convierte un sustantivo resuelto: por su género. Sin\n// palabras `pronoun` propias todavía (los clíticos cogelo/cogela llegan en la\n// parte 2), pero las casillas se rellenan desde ya. El esqueleto llama a este\n// bloque tras cada orden.\nblock note_pronouns(obj)\n    if obj is feminine\n        change pron_her to obj\n        return 0\n    change pron_him to obj\n\n// Combine a base verb with a particle into a multi-word action, only for the\n// verbs that take one: switch and turn with on/off become switch_on/switch_off,\n// and take with off becomes take_off. Any other base ignores the particle (so\n// "put X on Y" stays a put). Particle ids: on is 1, off is 2.\nblock compound(base, particle)\n    if base is action_id("switch_on")\n        if particle is 1\n            return action_id("switch_on")\n        if particle is 2\n            return action_id("switch_off")\n    if base is action_id("turn")\n        if particle is 1\n            return action_id("switch_on")\n        if particle is 2\n            return action_id("switch_off")\n    if base is action_id("take")\n        if particle is 2\n            return action_id("take_off")\n    if base is action_id("transcript")   // transcripcion no / transcript on\n        if particle is 1\n            return action_id("transcript")\n        if particle is 2\n            return action_id("transcript_off")\n    return nothing\n\n// The chosen direction\'s property number, from the first direction word typed\n// (a direction word\'s dictionary entry is flagged with bit 6, and byte 2 holds\n// the direction property). Returns nothing if no direction was named.\nblock find_direction()\n    let n = word_count\n    let i = 0\n    while i < n\n        let d = word_dict(i)\n        if d is not nothing\n            if peek_byte(d + 6) is 64\n                return peek_byte(d + 8)\n        change i to i + 1\n    return nothing\n\n// English reads LOOK <noun> and LOOK AT <noun> as EXAMINE, the usual synonyms:\n// a bare LOOK describes the room, while LOOK CLOAK (or LOOK AT CLOAK) inspects the\n// cloak. parser.prelude calls this once the objects are known; here it remaps the\n// look action to examine when a noun or a scenery grain was named. A language pack\n// may override it for its own conventions.\nblock remap_action(act)\n    if act is action_id("look")\n        if noun is not nothing\n            return action_id("examine")\n        if grain is not 0\n            return action_id("examine")\n    return act\n\n// Does the object\'s vocabulary include this dictionary word?\nblock has_word(obj, target)\n    let addr = words_addr(obj)\n    if addr is nothing\n        return 0\n    let count = words_count(obj)\n    let i = 0\n    while i < count\n        if peek_word(addr, i) is target\n            return 1\n        change i to i + 1\n    return 0\n\n// Can the player see and reach what is inside this object? A supporter\'s\n// contents are always in view. A container\'s are in view when it is open, when\n// it is `clear` (see-through), or when it is not `openable` at all: a bowl or a\n// basket has no lid to shut, so its contents are always reachable. This is the\n// scope rule the noun matcher follows.\nblock see_into(obj)\n    if obj is supporter\n        return 1\n    if obj is container\n        if obj is open\n            return 1\n        if obj is clear\n            return 1\n        if obj is not openable\n            return 1\n    return 0\n\n// A closed opaque container: we cannot see into it. The inverse of see_into for\n// a container: open, clear, or lidless (not openable) all mean it is not shut.\nblock shut_holds(obj)\n    if obj is open\n        return 0\n    if obj is clear\n        return 0\n    if obj is not openable\n        return 0\n    return 1\n\n// Among the closed opaque containers directly within `where`, a known (seen)\n// content matching the word. Records the blocking container in shut_in.\nblock shut_search(where, target)\n    for each obj in where\n        if obj is not hidden\n            if obj is container\n                if shut_holds(obj)\n                    let known = shut_match(obj, target)\n                    if known is not nothing\n                        change shut_in to obj\n                        return known\n    return nothing\n\nblock shut_match(holder, target)\n    for each x in holder\n        if x is not hidden\n            if x is seen\n                if has_word(x, target)\n                    return x\n    return nothing\n\n// Match a noun: the typed words after the verb, as one phrase, through the\n// scoring matcher (parser.prelude match_phrase): the in-scope object matching\n// the most typed words wins, a tie is a genuine ambiguity (parse_fault 3).\nblock match_noun()\n    return match_first_phrase\n\n// Resolve the command\'s objects into the noun (and, for a two-noun verb like\n// "put noun on noun", the second). The verb\'s dictionary entry carries its noun\n// arity in data byte 2: 0 intransitive, 1 one noun, 2 two nouns. An intransitive\n// verb handed extra words (jump n, look cloak) is a command the grammar cannot\n// account for, so it sets parse_fault 2 and the loop answers msg_extra_words\n// rather than silently dropping the words.\nblock resolve_objects()\n    change noun to nothing\n    change second to nothing\n    change grain to 0\n    change parse_fault to 0\n    if any_tables is 1\n        change line_act to 0\n    let d = word_dict(0)\n    if d is not nothing\n        if any_tables is 1\n            // Un verbo con tabla: el matcher posicional se encarga de toda la\n            // orden (docs/02 sección 8c). Un clítico pendiente ("cávalo")\n            // sigue siendo el sustantivo cuando la línea no trajo ninguno.\n            if peek_byte(d + 6) is 144 or peek_byte(d + 6) is 152\n                let tbl = peek_word(d + 7, 0)\n                grammar_match(tbl)\n                if noun is nothing\n                    if parse_fault is 0\n                        if clitico is 5\n                            change noun to player\n                        else\n                            if clitico is not 0\n                                let ref = pronoun_slot(clitico)\n                                if ref is not nothing\n                                    if in_scope(ref)\n                                        change noun to ref\n                                // Un clítico sin referente ("cógelos" sin\n                                // grupo) es el fallo del pronombre (5).\n                                if noun is nothing\n                                    change parse_fault to 5\n                change clitico to 0\n                return 1\n        if peek_byte(d + 6) is 128 or peek_byte(d + 6) is 136\n            let arity = peek_byte(d + 8)\n            let va = peek_byte(d + 7)\n            if arity is 2\n                resolve_two_nouns\n                return 1\n            if arity is 0\n                // oops takes a trailing correction word, not a noun; never an error.\n                if va is not action_id("oops")\n                    if has_extra_words(va) is 1\n                        change parse_fault to 2\n                return 1\n    change noun to match_noun\n    // Un clítico pendiente ("cogela") es el sustantivo de la orden: el\n    // referente de su casilla, si sigue a la vista. Si el referente se fue,\n    // cae en el fallo honesto de siempre ("No ves nada de eso por aquí").\n    if noun is nothing\n        if clitico is 5\n            change noun to player\n        else\n            if clitico is not 0\n                let ref = pronoun_slot(clitico)\n                if ref is not nothing\n                    if in_scope(ref)\n                        change noun to ref\n                // Un clítico sin referente ("cógelos" sin grupo previo) es\n                // el fallo del pronombre (5, msg_no_it), no un verbo a secas.\n                if noun is nothing\n                    change parse_fault to 5\n    change clitico to 0\n    // Un fallo de ambigüedad (3) se respeta: caer en el decorado o en el\n    // "no lo ves" taparía el honesto "cuál quieres decir".\n    if parse_fault is not 0\n        return 1\n    // Un barrido plural pendiente ("coge monedas") liga objeto a objeto.\n    if any_plurals is 1\n        if plural_go is not 0\n            return 1\n    if noun is nothing\n        change noun to reach_unscoped\n    if noun is nothing\n        change grain to find_scenery\n        if grain is 0\n            change parse_fault to named_unseen\n            if parse_fault is 0\n                change unknown_at to first_unknown(1, word_count)\n                if unknown_at is not 0\n                    change parse_fault to 4\n    return 1\n\n// A hook for reaching an object ordinary scope could not: nothing by default, so\n// a word that names something out of view stays unresolved (and the turn answers\n// "you can\'t see that"). The debug granule overrides this to match the word\n// against every object, so its fetch/warp/inspect verbs reach anything.\nblock reach_unscoped()\n    return nothing\n\n// Did the player name an object word that nothing in scope answered to? Every\n// unflagged dictionary word is object vocabulary (verbs, directions, particles,\n// prepositions, and grain words all carry a flag byte), so an unflagged word that\n// the noun match did not consume names a thing that simply is not here.\nblock named_unseen()\n    return phrase_named(1, word_count)\n\n// For an intransitive verb (no noun slot), is there a word after it the grammar\n// cannot use? Returns 1 the moment it finds one. A go command is the exception:\n// solo importa que haya una dirección en la frase, porque "ve hacia arriba"\n// lleva la palabra de relleno "hacia", que ni siquiera está en el diccionario.\nblock has_extra_words(act)\n    if act is action_id("go")\n        if find_direction is not nothing\n            return 0\n    let n = word_count\n    let i = 1\n    while i < n\n        let keep = 0\n        let d = word_dict(i)\n        // Una partícula que forma compuesto con este verbo es parte del\n        // verbo ("transcripcion no"); cualquier otra palabra sobra.\n        if d is not nothing\n            if peek_byte(d + 6) is 32\n                if compound(act, peek_byte(d + 7)) is not nothing\n                    change keep to 1\n        if keep is 0\n            return 1\n        change i to i + 1\n    return 0\n\n// A scenery grain word (flagged bit 4) whose owner is in scope; returns the\n// grain id (so dispatch can route to its response or the scenery default).\nblock find_scenery()\n    // The walker folds away entirely (any_grains is a compile-time flag) in a\n    // game that declares no grains, so unused scenery costs nothing.\n    if any_grains is 1\n        let n = word_count\n        let i = 1\n        while i < n\n            let d = word_dict(i)\n            if d is not nothing\n                if peek_byte(d + 6) is 16\n                    // The word\'s grain chain: (grain id, owner) pairs, zero-\n                    // ended. The same word can be scenery in several rooms;\n                    // answer with the grain whose owner is in scope here.\n                    let c = peek_word(d + 7, 0)\n                    let j = 0\n                    let g = peek_word(c, j)\n                    while g is not 0\n                        if in_scope(peek_word(c, j + 1))\n                            return g\n                        change j to j + 2\n                        change g to peek_word(c, j)\n            change i to i + 1\n    return 0\n\n// Is this dictionary word a phrase boundary rather than a noun word? Any flagged\n// word qualifies: the grammar preposition (bit 3), but also a particle or a\n// direction word (on/in), which separate the two noun phrases just as well.\nblock is_separator(target)\n    // Only the words that JOIN two nouns split the phrases: a grammar\n    // preposition (flag 8), and the direction and particle words that\n    // double as one ("put coin IN box", "gib X AN Y", flags 64 and 32).\n    // Anything else is content: a pronoun binds as a noun, an article is\n    // skipped, and a noun that moonlights as a verb elsewhere ("pick the\n    // LOCK", "PAT the person") must not end the phrase it stars in.\n    if peek_byte(target + 6) is 8 or peek_byte(target + 6) is 136\n        return 1\n    if peek_byte(target + 6) is 64\n        return 1\n    if peek_byte(target + 6) is 32\n        return 1\n    return 0\n\n// Bind the two noun slots by position, the way the grammar reads them: the words\n// before the preposition name the first noun, the words after it name the second.\n// The boundary is the first separator word (the "to" of "give X to Y", the "on"\n// of "put X on Y"). Binding by position, not by first-in-scope-wins, is what lets\n// an out-of-scope first noun stay unresolved (so the verb reports "you can\'t see\n// that") instead of letting the recipient slide into its slot.\nblock resolve_two_nouns()\n    let n = word_count\n    let b = 0\n    let i = 1\n    while i < n\n        if b is 0\n            let d = word_dict(i)\n            if d is not nothing\n                if is_separator(d)\n                    change b to i\n        change i to i + 1\n    if b is 0\n        change b to n\n    change noun to match_phrase(1, b, 0)\n    if parse_fault is not 0\n        return 1\n    // A named-but-unresolved noun (a known object out of scope, an unknown word,\n    // a stray non-noun) faults so the turn is rejected rather than run with no\n    // noun; an EMPTY slot (b is 1) is left to the action\'s own default.\n    if noun is nothing\n        if b > 1\n            change parse_fault to noun_fault(1, b)\n            return 1\n    if b < n\n        change second to match_phrase(b + 1, n, 0)\n        if parse_fault is not 0\n            return 1\n        if second is nothing\n            if b + 1 < n\n                change parse_fault to noun_fault(b + 1, n)\n    return 1\n\n// Remember the command just parsed so a following "oops" can correct it: find the\n// first unrecognized word (one with no dictionary entry), verb or noun, and if\n// there is one, snapshot the parse buffer and note that word\'s index. With no\n// unknown word, clear the flag, so "oops" after an understood command has nothing\n// to fix. Scanning from word 0 means a mistyped verb is correctable too, but the\n// loop must call note_oops even when the verb did not parse (see run_game).\nblock note_oops()\n    change oops_ready to 0\n    let n = word_count\n    let i = 0\n    while i < n\n        if word_dict(i) is nothing\n            change oops_word to i\n            change oops_ready to 1\n            copy_bytes(parse_addr, oops_addr, 2 + 4 * n)\n            return 0\n        change i to i + 1\n    return 0\n\n// Correct the previous command\'s unrecognized word with the word typed after\n// "oops", then re-resolve the patched command and return its action (0 if there\n// is nothing to correct or the fix does not parse). run_turn dispatches the\n// result as an ordinary turn.\nblock fix_oops()\n    if oops_ready is 0\n        msg_cant_oops\n        return 0\n    let fix = word_dict(1)\n    if fix is nothing\n        msg_cant_oops\n        return 0\n    // Restore the saved command, then overwrite the bad word\'s dictionary slot\n    // (the two-byte entry at parse offset 2 + 4*index) with the correction.\n    copy_bytes(oops_addr, parse_addr, 2 + 4 * peek_byte(oops_addr + 1))\n    poke_word(parse_addr, 1 + 2 * oops_word, fix)\n    let act = resolve_verb\n    if act is 0\n        return 0\n    change tie_want to 1\n    if act is action_id("take")\n        change tie_want to 0\n    change way to find_direction\n    resolve_objects\n    if parse_fault is 1\n        msg_cant_see\n        return 0\n    if parse_fault is 3\n        msg_be_specific\n        return 0\n    if any_tables is 1\n        if line_act is not 0\n            change act to line_act\n    return act\n\n// ==========================================================================\n// 2. THE STANDARD VERBS\n// The verb vocabulary and grammar; the logic is in actions.prelude.\n// ==========================================================================\n\n// Bare LOOK describes the room; LOOK <noun> and LOOK AT <noun> are the usual\n// synonyms for EXAMINE, so the noun forms are accepted here and remapped to the\n// examine action once the noun is known (english.prelude, remap_action).\nverb "mirar", "mira", "m"\n    look\n    look noun\n    look a noun\n\n// Movement. The parser sets `way` to the chosen direction\'s property (a bare\n// direction word, or go + a direction). A room can override one direction with\n// its own `on go <direction>`, which runs first and consumes the action; this\n// default handles the rest: follow a static exit, or refuse the move.\nverb "ir", "ve", "camina", "caminar", "corre", "correr"\n    go\n\n// The direction words: each maps its vocabulary to a fixed direction property.\n// This is the English set; a language pack redeclares these with its own words\n// (direction north "norte", "n"). The property names never change.\ndirection north     "norte", "n"\ndirection south     "sur", "s"\ndirection east      "este", "e"\ndirection west      "oeste", "o"\ndirection northeast "noreste", "ne"\ndirection northwest "noroeste", "no"\ndirection southeast "sureste", "se"\ndirection southwest "suroeste", "so"\n// Subir y bajar admiten varias formas: arriba, sube, subir; abajo, baja, bajar.\ndirection up        "arriba", "sube", "subir", "ar"\ndirection down      "abajo", "baja", "bajar", "ab"\ndirection in        "dentro"\ndirection out       "fuera"\n\nverb "coger", "coge", "tomar", "toma", "agarrar", "agarra"\n    take noun\n\nverb "dejar", "deja", "soltar", "suelta"\n    drop noun\n\nverb "examinar", "examina", "x", "inspeccionar", "inspecciona"\n    examine noun\n\n// Meta verbs. These report on or steer the session rather than act in the world,\n// so each sets meta_turn: the loop then skips the per-turn pulse and the turn\n// count (a cancelled quit must not cost a turn). quit and restart confirm first.\n// Override on quit for a custom send-off, reusing confirm_quit and do_quit.\n// Cada verbo meta responde TAMBIÉN a su original inglés (quit, score, save,\n// restore, undo, again, oops, transcript): quien viene de jugar en inglés no\n// siempre acierta la palabra española a la primera, y los verbos de sesión\n// tienen que funcionar sin más.\nverb "fin", "terminar", "termina", "quit"\n    quit\n\nverb "puntuacion", "puntuación", "puntos", "score"\n    score\n\nverb "reiniciar", "recomenzar", "restart"\n    restart\n\n// Saving and restoring. do_save returns 1 when the save is written; a successful\n// restore does not return into the restore handler at all, it resumes at the\n// do_save point with result 2 (so the save handler redescribes the room after a\n// restore). The restore handler is reached only when the restore fails.\nverb "guardar", "graba", "grabar", "save"\n    save\n\nverb "recuperar", "cargar", "carga", "restaurar", "restore", "load"\n    restore\n\n// La transcripción (flujo de salida 2): TRANSCRIPCION la pone en marcha y\n// TRANSCRIPCION NO la detiene (la partícula de abajo, vía compound). El\n// intérprete es quien abre y posee el archivo. La forma con tilde funciona\n// por el pliegue de acentos (fold_accents). Inglés como respaldo:\n// TRANSCRIPT ON/OFF (las partículas de abajo) y UNSCRIPT.\nverb "transcripcion", "transcripción", "transcribir", "transcript", "script"\n    transcript\n    transcript_off\n\nverb "unscript"\n    transcript_off\n\n// Las primeras partículas del pack: "no" (o el inglés "off") tras el verbo\n// de transcripción la apaga, y "on" la enciende explícitamente. compound\n// solo las reclama para ese verbo, así que un "no" en cualquier otra orden\n// sigue siendo una palabra de más, con su rechazo.\nparticle on  "on"\nparticle off "no", "off"\n\n// undo and again are intercepted by the turn loop (run_turn) before dispatch, so\n// they need no handler here; the declarations just register the verbs and their\n// actions. again replays the previous non-meta command.\nverb "deshacer", "undo"\n    undo\n\nverb "repetir", "repite", "g", "otra", "again"\n    again\n\nverb "ups", "corregir", "oops"\n    oops\n\n// The magic word. Not a meta verb (it is a normal, if fruitless, action), so it\n// takes a turn like any other; an author can override it for a real effect.\nverb "xyzzy"\n    xyzzy\n\nverb "inventario", "i", "inv"\n    inventory\n\nverb "encender", "enciende"\n    switch_on noun\n\nverb "apagar", "apaga"\n    switch_off noun\n\nverb "ponerse", "ponte", "vestir", "viste"\n    wear noun\n\nverb "quitarse", "quitate", "quítate", "quitar", "quita"\n    take_off noun\n\nverb "poner", "pon", "colocar", "coloca", "meter", "mete"\n    put noun sobre noun\n    put noun en noun\n\nverb "introducir", "introduce", "insertar"\n    insert noun en noun\n\nverb "abrir", "abre", "destapar", "destapa"\n    open noun con noun\n    open noun\n\nverb "cerrar", "cierra", "tapar", "tapa"\n    close noun\n\n// Cerrar y abrir CON LLAVE: verbos propios (una palabra = una accion), asi\n// "trancar la puerta con la llave" la cierra con llave y "destrancarla" la abre.\nverb "trancar", "tranca"\n    lock noun con noun\n    lock noun\n\nverb "destrancar", "destranca"\n    unlock noun con noun\n    unlock noun\n\nverb "entrar", "entra", "subir", "sube"\n    enter noun\n\nverb "salir", "sal", "abandonar"\n    exit\n\nverb "dar", "da", "ofrecer", "ofrece", "entregar", "entrega"\n    give noun a noun\n\nverb "mostrar", "muestra", "ensenar", "enseñar", "ensena", "enseña"\n    show noun a noun\n\nverb "tocar", "toca", "palpar", "palpa"\n    touch noun\n\nverb "oler", "huele", "olfatear"\n    smell noun\n\nverb "probar", "prueba", "lamer", "lame", "saborear"\n    taste noun\n\nverb "escuchar", "escucha", "oir", "oír", "oye"\n    listen\n    listen noun\n\nverb "comer", "come"\n    eat noun\n\nverb "beber", "bebe", "tragar", "traga"\n    drink\n    drink noun\n\nverb "atacar", "ataca", "golpear", "golpea", "romper", "rompe", "matar", "mata", "pegar", "pega"\n    attack noun\n\nverb "besar", "besa", "abrazar", "abraza"\n    kiss noun\n\nverb "empujar", "empuja", "pulsar", "pulsa", "presionar", "presiona"\n    push noun\n\nverb "tirar", "tira", "jalar", "jala"\n    pull noun\n\nverb "girar", "gira", "rotar", "rota", "voltear", "voltea"\n    turn noun\n\nverb "escalar", "escala", "trepar", "trepa"\n    climb noun\n\nverb "leer", "lee"\n    examine noun\n\nverb "hablar", "habla", "saludar", "saluda"\n    talk noun\n\nverb "pregunta", "preguntar", "pregúntale", "preguntale", "interroga"\n    ask noun\n    ask noun sobre\n    ask noun por\n\nverb "di", "dile", "cuéntale", "cuentale", "cuenta"\n    tell noun\n    tell noun sobre\n    tell noun de\n\nverb "responde", "contesta"\n    answer noun\n\nverb "saltar", "salta", "brincar", "brinca"\n    jump\n\nverb "esperar", "espera", "z"\n    wait\n\nverb "cantar", "canta"\n    sing\n\n// ==========================================================================\n// 3. THE MESSAGES\n// Every line shown to the player, and the room and content listing.\n// ==========================================================================\n\n// Articles. The compiler lowers ${the noun} / ${a noun} to a call to one of these\n// with the object and a capitalize flag (1 for ${The} / ${A}), so the article\n// words live here in the language layer, not in the compiler. A translation\n// redefines these two blocks for its own articles. English: "the", and "a" or\n// "an" chosen by the object\'s `an` attribute (the compiler derives that from the\n// name); a `named` object (Linda, Excalibur) takes no article at all. The named\n// check folds away in a game with no named objects (any_named).\nblock art_the(obj, cap)\n    // Total, like the containment test: an unresolved noun prints\n    // as the word, never an illegal print_obj 0 (docs/02 s.12).\n    if obj is nothing\n        show("nada")\n        return\n\n    if any_named is 1\n        if obj is named\n            print_name(obj)\n            return\n    // A hand-set article wins over derivation (docs/01 section 16): las\n    // tijeras, el agua. Printed as stored, so keep it lowercase and let such\n    // objects sit mid-sentence.\n    if article_addr(obj) is not 0\n        show("${obj.article}")\n        show(" ")\n        print_name(obj)\n        return\n    // El plural (pluribus): los/las, por género. Se pliega sin objetos\n    // marcados.\n    if any_pluribus is 1\n        if obj is pluribus\n            if obj is feminine\n                if cap is 1\n                    show("Las ")\n                else\n                    show("las ")\n            else\n                if cap is 1\n                    show("Los ")\n                else\n                    show("los ")\n            print_name(obj)\n            return\n    if obj is feminine\n        if cap is 1\n            show("La ")\n        else\n            show("la ")\n    else\n        if cap is 1\n            show("El ")\n        else\n            show("el ")\n    print_name(obj)\n\nblock art_a(obj, cap)\n    // Total, like the containment test: an unresolved noun prints\n    // as the word, never an illegal print_obj 0 (docs/02 s.12).\n    if obj is nothing\n        show("nada")\n        return\n\n    if any_named is 1\n        if obj is named\n            print_name(obj)\n            return\n    // A hand-set indefinite wins over derivation: unas tijeras, some water.\n    if indefinite_addr(obj) is not 0\n        show("${obj.indefinite}")\n        show(" ")\n        print_name(obj)\n        return\n    // El plural indefinido: unos/unas (unas tijeras). Se pliega sin\n    // objetos marcados.\n    if any_pluribus is 1\n        if obj is pluribus\n            if obj is feminine\n                if cap is 1\n                    show("Unas ")\n                else\n                    show("unas ")\n            else\n                if cap is 1\n                    show("Unos ")\n                else\n                    show("unos ")\n            print_name(obj)\n            return\n    if obj is feminine\n        if cap is 1\n            show("Una ")\n        else\n            show("una ")\n    else\n        if cap is 1\n            show("Un ")\n        else\n            show("un ")\n    print_name(obj)\n\n// La cópula con número (docs/01 sección 16): ${is x} imprime "está" o\n// "están" según el atributo pluribus del objeto (estar, el verbo de estados\n// y lugares que usan los mensajes). Sin objetos marcados, la rama plural\n// se pliega.\nblock art_is(obj, cap)\n    if any_pluribus is 1\n        if obj is pluribus\n            if cap is 1\n                show("Están")\n            else\n                show("están")\n            return 0\n    if cap is 1\n        show("Está")\n    else\n        show("está")\n    return 0\n\n// Las palabras de la cabecera. El compilador arma la cabecera (título, lema,\n// autor, línea de versión), pero las palabras ENTRE las partes son del idioma:\n// line_by imprime el conector entre el lema y el autor, y banner_headline el\n// lema por defecto cuando el juego no declara ninguno.\nblock line_by()\n    show(" de ")\n\n// El sufijo de posición en el título y la barra: "Cripta (sobre el altar)",\n// "Sótano (en la caja)". Los soportes llevan "sobre", lo demás "en".\nblock line_nested(obj)\n    if obj is supporter\n        show(" (sobre ")\n    else\n        show(" (en ")\n    art_the(obj, 0)\n    show(")")\n\nblock banner_headline()\n    show("Una aventura conversacional")\n\n// The input prompt. It requests a paragraph break (one blank line before it,\n// collapsed with any the turn already pending) rather than forcing its own, so\n// responses are separated from the next prompt by exactly one blank line.\nblock prompt()\n    par\n    show(">")\n\n// What of a holder\'s contents should be listed: not hidden or concealed, and\n// either the holder shows its contents (a supporter, or an open or clear\n// container) or the player already knows the item is there (it is `seen`). That\n// last case is the memory - a closed opaque box still lists what you have seen.\nblock content_listable(holder, x)\n    // The player never lists as a holder\'s contents ("an altar (contains\n    // yourself)"); possible only where something is enterable, so it folds.\n    if any_enterable is 1\n        if x is player\n            return 0\n    // A component is part of the holder, not carried contents: the machine\n    // never lists its own levers. Folds away without components.\n    if any_components is 1\n        if x is component\n            return 0\n    if x is hidden\n        return 0\n    if x is concealed\n        return 0\n    // Anything the player can see into (a supporter, or an open, clear, or\n    // lidless container) lists all its contents; a closed opaque container lists\n    // only what the player already knows is inside (the knowledge model).\n    if see_into(holder)\n        return 1\n    if x is seen\n        return 1\n    return 0\n\n// One scenery holder\'s paragraph (constant scenery_contents = 1): what\n// sits on or in it, the knowledge model deciding per item. Prints\n// nothing when the holder holds nothing tellable.\nblock scenery_holder_line(obj)\n    if obj is not container\n        if obj is not supporter\n            return 0\n    let total = 0\n    for each x in obj\n        if content_listable(obj, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    par\n    if obj is supporter\n        show("Sobre ")\n    else\n        show("En ")\n    art_the(obj, 0)\n    show(" puedes ver ")\n    let shown = 0\n    for each x in obj\n        if content_listable(obj, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" y ")\n                else\n                    show(", ")\n            art_a(x, 0)\n            now x is seen\n            change shown to shown + 1\n    say "."\n\n// the contents the player can see or remembers and marking each as seen. Prints\n// nothing when there is nothing to show. One level deep, by design.\nblock list_contents(holder)\n    if holder is supporter\n        list_contents_run(holder)\n        return 0\n    if holder is container\n        list_contents_run(holder)\n    return 0\n\nblock list_contents_run(holder)\n    let total = 0\n    for each x in holder\n        if content_listable(holder, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    show(" (contiene ")\n    let shown = 0\n    for each x in holder\n        if content_listable(holder, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" y ")\n                else\n                    show(", ")\n            show("${a x}")\n            now x is seen\n            change shown to shown + 1\n    show(")")\n    return 0\n\n// After a container is opened, name what is revealed inside (marking it seen), so\n// opening a box shows its contents at once rather than only on the next look.\nblock reveal_contents(holder)\n    let total = 0\n    for each x in holder\n        if content_listable(holder, x)\n            change total to total + 1\n    if total is 0\n        return 0\n    show("Dentro encuentras ")\n    let shown = 0\n    for each x in holder\n        if content_listable(holder, x)\n            if shown is not 0\n                if shown is total - 1\n                    show(" y ")\n                else\n                    show(", ")\n            show("${a x}")\n            now x is seen\n            change shown to shown + 1\n    say "."\n\n// One line of a room\'s contents listing, naming a container\'s or supporter\'s\n// contents in passing.\nblock list_item(obj)\n    show("Ves ")\n    show("${a obj}")\n    // Un objeto que se puede abrir y está cerrado lo dice (sugerencia de Pablo\n    // Martínez): el único estado que el listado no revela por sí solo. El\n    // participio concuerda con el género.\n    if obj is openable\n        if obj is not open\n            if obj is feminine\n                show(" (que está cerrada)")\n            else\n                show(" (que está cerrado)")\n    show_tag(obj)\n    list_contents(obj)\n    say "."\n\n// Parser.\n// The player typed a word the story\'s dictionary does not know at\n// all: name it (spelled back from the text buffer), so a typo is\n// told apart from a real thing that is not here.\nblock msg_unknown_word()\n    show("Esta historia no conoce la palabra \\"")\n    let p = word_pos(unknown_at) - 2\n    let n = word_len(unknown_at)\n    let i = 0\n    while i < n\n        show_char(text_char(p + i))\n        change i to i + 1\n    say "\\"."\n\n// Un verbo a secas ("coge", "abre") pregunta, con el verbo tecleado como\n// eco ("¿Coge qué?"). La mayúscula solo se aplica en el rango ASCII.\nblock msg_noun_missing()\n    show("¿")\n    let p = word_pos(0) - 2\n    let n = word_len(0)\n    let i = 0\n    while i < n\n        let c = text_char(p + i)\n        if i is 0\n            if c >= 97\n                if c <= 122\n                    change c to c - 32\n        show_char(c)\n        change i to i + 1\n    say " qué?"\n\n// El rechazo de beyond (docs/01): a la vista, pero la mano no llega.\nblock msg_beyond(obj)\n    if any_pluribus is 1\n        say "${The obj} ${is obj} fuera de tu alcance."\n        return 0\n    say "${The obj} está fuera de tu alcance."\n\nblock msg_cant_see()\n    say "No ves nada de eso por aquí."\n\nblock msg_open_first()\n    say "Antes tendrás que abrir ${the shut_in}."\n\nblock msg_no_it()\n    say "Tendrás que decir a qué te refieres."\n\nblock msg_be_specific()\n    say "Tendrás que ser más concreto."\n\n// La pregunta de desambiguación (docs/02 sección 8): el marco alrededor de\n// la lista de candidatos que imprime el parser ("¿A cuál te refieres, la\n// moneda de oro o la moneda de plata?").\nblock line_which_open()\n    show("¿A cuál te refieres, ")\n\nblock line_which_or()\n    show(" o ")\n\nblock line_which_item(obj)\n    show("${the obj}")\n\nblock line_which_end()\n    say "?"\n\nblock msg_nothing_again()\n    say "No hay nada que repetir."\n\nblock msg_only_animate()\n    say "Si sigues hablándoles a los objetos, quizá toque otra sesión de terapia."\n\n// Conversation lines. The `you` and `reply` topic sugar auto-quotes and\n// attributes a line of dialogue; the compiler supplies the line\'s text and\n// calls these for the framing. The speaker label, the separator, and the\n// quotation marks all live here, so a story can restyle them and a language\n// pack can translate them (German low-high quotes, French guillemets, a\n// different speaker tag). line_reply receives the speaking person; ${The x}\n// prints a named person bare (Linda) and others with the article (The guard).\nblock line_you()\n    show("Tú: \\"")\n\nblock line_reply(speaker)\n    show("${The speaker}: \\"")\n\nblock line_end()\n    say "\\""\n\n// Append " (contains a, b and c)" to a container or supporter just named, listing\n// Conversation menu framing (the conversations granule). In the language layer so\n// a pack translates it; dropped when the game does not summon the menu.\nblock line_talk_header(who)\n    show("Habla con ${the who} de:")\n\nblock line_talk_prompt()\n    show("Elige un tema, o 0 para terminar.")\n\nblock msg_no_topics()\n    say "Ahora mismo no se te ocurre nada que merezca la pena."\n\nblock msg_talk_over()\n    say "Das la conversación por terminada."\n\n// The status line\'s score side (the statusline granule): the score and moves,\n// right-aligned, in Spanish words and widths.\nblock line_status_score(w)\n    if any_awards is 0\n        set_cursor(1, w - 9 - status_digits(turns))\n        show("Turnos: ")\n        show(turns)\n        return 0\n    if w < 54\n        set_cursor(1, w - 9 - status_digits(score) - status_digits(turns))\n        show("Puntos: ")\n        show(score)\n        show("/")\n        show(turns)\n    else\n        set_cursor(1, w - 19 - status_digits(score) - status_digits(turns))\n        show("Puntos: ")\n        show(score)\n        show("   Turnos: ")\n        show(turns)\n\n// Room and light.\nblock msg_dark_room()\n    say "Oscuridad total. Hasta tus manos han desaparecido."\n\nblock msg_too_dark()\n    say "Está demasiado oscuro para distinguir nada."\n\n// Movement.\nblock msg_cant_go()\n    say "No hay salida en esa dirección."\n\nblock msg_no_direction()\n    say "¿Hacia dónde?"\n\nblock msg_cant_enter()\n    say "No puedes meterte en ${the noun}."\n\nblock msg_already_there()\n    say "Ya estás dentro."\n\nblock msg_not_inside()\n    say "No estás dentro de nada."\n\n// Subir/bajar (soporte) y meterse/salir (contenedor), de board_report /\n// leave_report. (Para revisión de Pablo: la contracción de+el = del.)\nblock msg_get_on()\n    say "Te subes a ${the noun}."\n\nblock msg_get_in()\n    say "Te metes en ${the noun}."\n\nblock msg_get_off()\n    say "Te bajas de ${the noun}."\n\nblock msg_get_out()\n    say "Sales de ${the noun}."\n\nblock msg_cant_climb()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no son para escalar."\n            return 0\n    say "${The noun} no es para escalar."\n\n// Sensory.\n// Examinarse sin player.desc definido.\nblock msg_examine_self()\n    say "¿Vamos a admirarnos un rato más o jugamos a la aventura?"\n\nblock msg_nothing_special()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no tienen nada de particular."\n            return 0\n    say "${The noun} no tiene nada de particular."\n\nblock msg_touch()\n    say "Tocas ${the noun}. No notas nada que tus ojos no vieran ya."\n\nblock msg_smell()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} huelen más o menos como esperabas."\n            return 0\n    say "${The noun} huele más o menos como esperabas."\n\nblock msg_listen()\n    say "Escuchas. Nada responde."\n\nblock msg_taste()\n    say "Mejor no."\n\n// Carrying and giving.\nblock msg_taken()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "Cogidas."\n            else\n                say "Cogidos."\n            return 0\n    if noun is feminine\n        say "Cogida."\n    else\n        say "Cogido."\n\nblock msg_fixed()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} se quedan justo donde están."\n            return 0\n    say "${The noun} se queda justo donde está."\n\nblock msg_animate_refuses()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} tienen otros planes."\n            return 0\n    say "${The noun} tiene otros planes."\n\nblock msg_have_it()\n    say "Ya tienes ${the noun}."\n\nblock msg_take_self()\n    say "Ya te llevas contigo a todas partes."\n\n// Un componente no se separa de su conjunto. La contracción "del" se forma\n// aquí (de + el), porque art_the no conjuga preposiciones; un objeto con\n// nombre propio o femenino sigue el camino normal.\n// Leaving a named thing the player is not actually in (exit noun).\nblock msg_not_in_that()\n    say "No estás ahí."\n\nblock msg_part_of()\n    let p = parent_of(noun)\n    show("Eso es parte de")\n    if any_named is 1\n        if p is named\n            show(" ")\n            print_name(p)\n            say "."\n            return\n    if p is feminine\n        show(" la ")\n    else\n        show("l ")\n    print_name(p)\n    say "."\n\nblock msg_dropped()\n    // Anidado, la línea dice adónde: sobre el altar, en la caja.\n    if any_enterable is 1\n        if parent_of(player) is not here\n            // La forma plural es un duplicado completo bajo el pliegue: un\n            // juego sin objetos marcados conserva las cadenas originales.\n            if any_pluribus is 1\n                if noun is pluribus\n                    if parent_of(player) is supporter\n                        show("Caen sobre ")\n                    else\n                        show("Caen en ")\n                    art_the(parent_of(player), 0)\n                    say "."\n                    return 0\n            if parent_of(player) is supporter\n                show("Cae sobre ")\n            else\n                show("Cae en ")\n            art_the(parent_of(player), 0)\n            say "."\n            return 0\n    say "Al suelo."\n\nblock msg_not_holding()\n    say "No llevas ${the noun}."\n\nblock msg_done()\n    say "Hecho."\n\nblock msg_put_where()\n    say "¿Sobre qué, o dentro de qué?"\n\nblock msg_cant_put()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} no pueden contenerlo."\n            return 0\n    say "${The second} no puede contenerlo."\n\nblock msg_closed()\n    if any_pluribus is 1\n        if second is pluribus\n            if second is feminine\n                say "${The second} están cerradas."\n            else\n                say "${The second} están cerrados."\n            return 0\n    if second is feminine\n        say "${The second} está cerrada."\n    else\n        say "${The second} está cerrado."\n\nblock msg_to_whom()\n    say "¿A quién?"\n\nblock msg_give()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} no quieren ${the noun}. Qué desfachatez."\n            return 0\n    say "${The second} no quiere ${the noun}. Qué desfachatez."\n\nblock msg_show()\n    if any_pluribus is 1\n        if second is pluribus\n            say "Parece que a ${the second} no les interesa demasiado."\n            return 0\n    say "Parece que a ${the second} no le interesa demasiado."\n\n// Wearing.\nblock msg_worn()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "Puestas."\n            else\n                say "Puestos."\n            return 0\n    if noun is feminine\n        say "Puesta."\n    else\n        say "Puesto."\n\nblock msg_already_worn()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "Ya llevas puestas ${the noun}."\n            else\n                say "Ya llevas puestos ${the noun}."\n            return 0\n    say "Ya llevas puesto ${the noun}."\n\nblock msg_cant_wear()\n    say "No puedes ponerte ${the noun}."\n\nblock msg_removed()\n    say "Fuera."\n\nblock msg_not_worn()\n    say "No llevas puesto ${the noun}."\n\n// Doors, containers, locks.\nblock msg_opened()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "Abiertas."\n            else\n                say "Abiertos."\n            return 0\n    if noun is feminine\n        say "Abierta."\n    else\n        say "Abierto."\n\nblock msg_already_open()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "${The noun} ya están abiertas."\n            else\n                say "${The noun} ya están abiertos."\n            return 0\n    if noun is feminine\n        say "${The noun} ya está abierta."\n    else\n        say "${The noun} ya está abierto."\n\nblock msg_cant_open()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no se abren."\n            return 0\n    say "${The noun} no se abre."\n\nblock msg_open_locked()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "${The noun} están cerradas con llave."\n            else\n                say "${The noun} están cerrados con llave."\n            return 0\n    if noun is feminine\n        say "${The noun} está cerrada con llave."\n    else\n        say "${The noun} está cerrado con llave."\n\nblock msg_door_locked(d)\n    if any_pluribus is 1\n        if d is pluribus\n            if d is feminine\n                say "${The d} están cerradas con llave."\n            else\n                say "${The d} están cerrados con llave."\n            return 0\n    if d is feminine\n        say "${The d} está cerrada con llave."\n    else\n        say "${The d} está cerrado con llave."\n\nblock msg_door_shut(d)\n    if any_pluribus is 1\n        if d is pluribus\n            if d is feminine\n                say "${The d} están cerradas. Primero tienes que abrir ${the d}."\n            else\n                say "${The d} están cerrados. Primero tienes que abrir ${the d}."\n            return 0\n    if d is feminine\n        say "${The d} está cerrada. Primero tienes que abrir ${the d}."\n    else\n        say "${The d} está cerrado. Primero tienes que abrir ${the d}."\n\nblock msg_closed_it()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "Cerradas."\n            else\n                say "Cerrados."\n            return 0\n    if noun is feminine\n        say "Cerrada."\n    else\n        say "Cerrado."\n\nblock msg_already_shut()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "${The noun} ya están cerradas."\n            else\n                say "${The noun} ya están cerrados."\n            return 0\n    if noun is feminine\n        say "${The noun} ya está cerrada."\n    else\n        say "${The noun} ya está cerrado."\n\nblock msg_cant_close()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no se cierran."\n            return 0\n    say "${The noun} no se cierra."\n\nblock msg_locked()\n    say "Cierras con llave."\n\n// Nuevo (Cosmos 0.37): ya-cerrado y no-cerrado. Versiones funcionales; el\n// repaso de Stefan les dará el tono guasón (y el género correcto).\nblock msg_already_locked()\n    say "Ya está cerrado con llave."\n\nblock msg_not_locked()\n    say "${The noun} no está cerrado con llave, así que abres ${the noun}."\n\nblock msg_cant_lock()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no se pueden cerrar con llave."\n            return 0\n    say "${The noun} no se puede cerrar con llave."\n\nblock msg_close_first()\n    say "Antes tendrás que cerrar ${the noun}."\n\n// Sin nombrar la llave a propósito: un DESTRANCA a secas no debe\n// revelar qué llave abre una cerradura aún por descubrir.\nblock msg_no_key()\n    say "No tienes la llave adecuada."\n\nblock msg_wrong_key()\n    if any_pluribus is 1\n        if second is pluribus\n            say "${The second} no encajan."\n            return 0\n    say "${The second} no encaja."\n\nblock msg_unlocked()\n    say "Abres con llave."\n\nblock msg_cant_unlock()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no se pueden abrir con llave."\n            return 0\n    say "${The noun} no se puede abrir con llave."\n\n// Operating.\nblock msg_no_switch()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no se pueden encender."\n            return 0\n    say "${The noun} no se puede encender."\n\nblock msg_already_on()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "${The noun} ya están encendidas."\n            else\n                say "${The noun} ya están encendidos."\n            return 0\n    if noun is feminine\n        say "${The noun} ya está encendida."\n    else\n        say "${The noun} ya está encendido."\n\nblock msg_already_off()\n    if any_pluribus is 1\n        if noun is pluribus\n            if noun is feminine\n                say "${The noun} ya están apagadas."\n            else\n                say "${The noun} ya están apagados."\n            return 0\n    if noun is feminine\n        say "${The noun} ya está apagada."\n    else\n        say "${The noun} ya está apagado."\n\nblock msg_no_effect()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no se inmutan."\n            return 0\n    say "${The noun} no se inmuta."\n\n// Body, action, idle.\nblock msg_attack()\n    say "Pegar a las cosas rara vez ayuda, y esta no va a ser la excepción."\n\nblock msg_eat()\n    say "${The noun} no está en el menú."\n\nblock msg_drink()\n    say "Aquí no hay nada que apetezca beber."\n\nblock msg_jump()\n    say "Das un salto en el sitio. No pasa nada, pero sienta bien."\n\nblock msg_wait()\n    say "El tiempo pasa."\n\nblock msg_kiss()\n    say "No es precisamente el momento."\n\nblock msg_sing()\n    say "Entonas unas notas. La sala no se inmuta."\n\n// Conversation.\nblock msg_no_talk()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no parecen con ganas de conversar."\n            return 0\n    say "${The noun} no parece con ganas de conversar."\n\nblock msg_use_talk()\n    say "Para conseguir algo de ${the noun}, usa HABLA CON ${the noun}."\n\nblock msg_ask()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} no sueltan prenda sobre el tema."\n            return 0\n    say "${The noun} no suelta prenda sobre el tema."\n\nblock msg_tell()\n    if any_pluribus is 1\n        if noun is pluribus\n            say "${The noun} reciben la noticia con magnífica indiferencia."\n            return 0\n    say "${The noun} recibe la noticia con magnífica indiferencia."\n\nblock msg_answer()\n    say "Tus palabras quedan sin respuesta."\n\n// Inventory.\nblock msg_carrying()\n    say "Llevas:"\n\nblock msg_empty_handed()\n    say "No llevas absolutamente nada."\n\n// Scenery default.\nblock msg_scenery()\n    say "Solo es parte del decorado. No te preocupes por ello."\n\n// Printed when the first word names no verb or direction.\nblock msg_no_verb()\n    say "Esas palabras no tienen ningún sentido."\n\n// The verb was understood, but it cannot use the words that followed it ("jump\n// north", "look cloak"). The verb is fine; the rest is one word too many.\nblock msg_extra_words()\n    say "Me he perdido a partir de ahí."\n\n// Read a yes/no answer; returns 1 for an answer that starts with y or Y. The\n// caller prints the question first, so this is shared by every confirmation. The\n// yes test (a leading \'y\') is English, so it lives in the language layer.\nblock yes_no()\n    let term = read_input\n    let c = text_char(0)\n    if c is 115\n        return 1\n    if c is 83\n        return 1\n    return 0\n\n// Ask the player to confirm quitting; returns 1 for yes.\nblock confirm_quit()\n    show("¿Seguro que quieres salir? ")\n    return yes_no\n\n// The farewell, overridable for a custom send-off.\nblock msg_farewell()\n    say "Lo dejamos aquí."\n\nblock msg_game_over()\n    say "¿Quieres REINICIAR, CARGAR una partida guardada o TERMINAR?"\n\n// Solo tras un final `death`: el camino de vuelta está en el menú.\nblock msg_game_over_died()\n    say "¿Quieres REINICIAR, CARGAR una partida guardada, DESHACER el último turno o TERMINAR?"\n\nblock msg_game_over_unknown()\n    say "Esa no era una de las opciones."\n\n// How many things the player wears; the pure count beside list_worn, so a\n// story can guard its phrasing ("You\'re dressed in nothing at all") before\n// printing a prefix. Both cost nothing unless called (DCE).\nblock worn_count()\n    let n = 0\n    for each x in player\n        if x is worn\n            change n to n + 1\n    return n\n\n// Print what the player wears as a punctuated list, "a hat, a cloak and\n// boots", with no framing and no newline: the story writes its own prose\n// around it. Returns the count. The two-pass count-then-join shape is the\n// library\'s own listing idiom (list_contents_run).\nblock list_worn()\n    let total = worn_count\n    let shown = 0\n    for each x in player\n        if x is worn\n            if shown is not 0\n                if shown is total - 1\n                    show(" y ")\n                else\n                    show(", ")\n            show("${a x}")\n            change shown to shown + 1\n    return total\n\n// Meta verbs (the score, a restart confirmation, the xyzzy easter egg). save,\n// restore, and undo bring their own messages with the meta-verb opcodes.\nblock msg_score()\n    if any_awards is 0\n        say "Este juego no lleva puntuación."\n        return 0\n    show("Has conseguido ${score} de un total de ${max_score} puntos en ")\n    show(turns)\n    if turns is 1\n        show(" turno")\n    else\n        show(" turnos")\n    if any_ranks is 1\n        show(", lo que te otorga el rango de ")\n        print_rank\n    say "."\n\nblock msg_confirm_restart()\n    show("¿Empezar de nuevo desde el principio? ")\n\nblock msg_xyzzy()\n    say "No pasa nada, pero por un momento te sientes ingenioso."\n\nblock msg_saved()\n    say "Guardado."\n\nblock msg_save_failed()\n    say "Algo salió mal al guardar."\n\nblock msg_restore_failed()\n    say "No se pudo recuperar esa partida."\n\nblock msg_transcript_on()\n    say "Transcripción en marcha. Desde aquí queda todo registrado."\n\nblock msg_transcript_off()\n    say "Transcripción finalizada."\n\nblock msg_transcript_already()\n    say "La transcripción ya está en marcha."\n\nblock msg_transcript_not_on()\n    say "No hay ninguna transcripción en marcha."\n\nblock msg_transcript_failed()\n    say "No se ha iniciado la transcripción."\n\nblock msg_undone()\n    say "Deshecho."\n\nblock msg_cant_undo()\n    say "No hay nada que deshacer."\n\nblock msg_cant_oops()\n    say "No hay nada que corregir."\n\n// One line of an inventory listing; a worn item is tagged, a container or\n// supporter names what it holds.\nblock list_held(obj)\n    show("  ")\n    show("${a obj}")\n    if obj is worn\n        show(" (puesto)")\n    show_tag(obj)\n    list_contents(obj)\n    say ""\n',
    'statusline.granule': '// statusline.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// An opt-in status line: summon it with `summon.statusline`. A one-line bar is\n// painted across the top of the screen before every prompt, showing the current\n// room on the left and the score and move count on the right, the way most\n// Infocom games do.\n//\n// HOW IT WORKS. A status line is a screen feature, so it uses a handful of v5\n// screen intrinsics the compiler provides (each lowers straight to an opcode, so\n// they cost nothing unless a granule calls them):\n//\n//   split_window(n)        reserve n lines at the top as the "upper window"\n//   set_window(n)          draw into window 0 (main) or 1 (upper)\n//   set_cursor(line, col)  move the upper-window cursor (1-based)\n//   set_style(s)           text style: 0 normal, 1 reverse, 2 bold, 4 italic\n//   screen_width         the screen width in characters, from the header\n//\n// The redraw hook is simply prompt: Cosmos calls prompt before reading every\n// command (including the first, right after the opening room), so overriding it\n// to paint the bar first means the line is always current, with no change to the\n// turn loop and nothing added to a story that does not summon this granule.\n//\n// To restyle the bar (drop reverse video, change the wording, reformat the right\n// side), redefine draw_status / status_bar in the story (most-specific-wins;\n// the compile notes the capture, deliberate here) or fork the granule.\n\n// The input prompt, extended: paint the bar, then do the ordinary prompt (the\n// paragraph break and the ">" the core library would have shown).\nblock prompt()\n    draw_status\n    par\n    show(">")\n\n// Set up the one-row upper window and paint the bar into it. The painting itself\n// is status_bar (below), so the conversations menu can reuse it at the top of its\n// own taller window; this block owns only the window plumbing.\nblock draw_status()\n    // HOLD the pending paragraph break across the bar: the transcript\'s break\n    // belongs to the next lower-window text, so the bar\'s own prints must\n    // neither consume it nor flush it early (an early flush doubles with the\n    // prompt\'s own break). Draw unbuffered (with the word-wrap buffer on,\n    // interpreters reorder the writes around set_cursor; Inform and PunyInform\n    // do exactly this dance too).\n    let held = par_pending\n    change par_pending to 0\n    buffer_mode(0)\n    split_window(1)\n    set_window(1)\n    status_bar\n    set_window(0)\n    buffer_mode(1)\n    change par_pending to held\n\n// One row, so the conversations menu leaves room for the bar above its list.\nblock status_lines()\n    return 1\n\n// The bar names the room, so the opening description skips its title line\n// and the prose scrolls straight under the bar (loop.prelude; Stefan\'s\n// start-screen design, not Puny\'s, whose Look always prints the name).\nblock title_in_bar()\n    return 1\n\n// Paint the bar into row 1 of whatever upper window is current: reverse video\n// across the width, the room name at the left, the score and moves at the right.\n// The right side adapts to the screen width the way PunyInform does: a wide screen\n// (54 columns or more) gets the full "Score: <n>   Moves: <n>", and a narrow retro\n// screen (a 40-column C64, a 53-column Spectrum) gets the compact\n// "Score: <score>/<turns>" so it still fits. Redefine this to change the layout.\nblock status_bar()\n    let w = screen_width\n    if w is 0\n        change w to 40\n    // The status colour (zcolor.statusline), the way PunyInform\'s clr_fgstatus\n    // works: the bar draws in it, and the base font colour returns afterwards.\n    // Unset (0) on a colourless interpreter, so this costs one test there.\n    if zc_status is not 0\n        set_colour(zc_status, 0)\n    set_style(1)\n    // Fill the WHOLE row in reverse video, all w columns including the last, so\n    // the bar spans the full screen width. Filling the final column is safe on\n    // the top row (the upper window never scrolls, so the bottom-right-corner\n    // scroll quirk that makes games skip the last cell cannot happen here), and\n    // it matters under an arc_image picture, where a short bar shows a gap.\n    set_cursor(1, 1)\n    let i = 1\n    while i <= w\n        show(" ")\n        change i to i + 1\n    // Left: the current room, with the nested location when the player is\n    // in or on something ("Crypt (on the altar)"), like the title line.\n    set_cursor(1, 2)\n    print_name(here)\n    if any_enterable is 1\n        if parent_of(player) is not here\n            line_nested(parent_of(player))\n    // Right, right-aligned: measure the text (status_digits, since the digit\n    // counts vary) and start that many columns in from the edge.\n    // Right, right-aligned: the score and moves, painted by the language layer\n    // (line_status_score) so a pack sets its own labels and their widths.\n    line_status_score(w)\n    set_style(0)\n    if zc_status is not 0\n        set_colour(zc_font, 0)\n\n',
    'takeall.granule': '// takeall.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// TAKE ALL, DROP ALL, and TAKE ALL FROM <container>: summon it with\n// `summon.takeall` (docs/05). The core deliberately omits ALL, so a game only\n// pays for it when it asks; without the summon, every hook below folds away\n// to nothing (the any_allwords guard).\n//\n// Every swept item is a FULL TURN of its own: it dispatches through the\n// ordinary pipeline (an object\'s own `on take` still overrides), then daemons\n// fire and the clock moves, exactly as if the takes had been typed one by\n// one. This is a deliberate departure from Inform\'s one-turn ALL: doing\n// three things costs three turns, the same rule a chained line follows.\n// UNDO takes back the whole sweep, because the sweep is one typed command\n// and undo peels typed commands.\n//\n// English-worded like every granule: a translation forks this file and\n// redeclares the all-words and the messages (docs/05 section 6).\n\n// The words that mean "everything within reach". The parser flags them in\n// the dictionary and hands any command carrying one to run_all below.\nall "all", "everything"\n\n// The expander the turn loop hands an all-command to (the run_all stub in\n// loop.prelude). take sweeps the room, or the named source ("take all from\n// the chest"); drop sweeps the hands, keeping what is worn. Any other verb\n// with "all", and an empty sweep, refuse, so a chained line stops honestly.\nblock run_all(act)\n    if act is action_id("take")\n        if noun is not nothing\n            all_from(noun)\n            return 0\n        all_take\n        return 0\n    if act is action_id("drop")\n        all_drop\n        return 0\n    change refused to 1\n    msg_all_verb\n    fire_turn\n    tick\n    return 0\n\n// Does the object sit in this room\'s tree (not carried)? Walks the parents.\nblock rooted_here(obj)\n    let p = parent_of(obj)\n    while p is not nothing\n        if p is here\n            return 1\n        if p is player\n            return 0\n        change p to parent_of(p)\n    return 0\n\n// Is this a thing TAKE ALL should try: reachable in the room, not already\n// carried, and nothing a plain take refuses on sight (fixed, scenery, a\n// person). The take itself still runs the object\'s own handlers, so a\n// custom refusal simply prints after the item\'s name.\nblock all_takeable(obj)\n    if obj is player\n        return 0\n    if obj is hidden\n        return 0\n    if obj is concealed\n        return 0\n    if obj is scenery\n        return 0\n    if obj is fixed\n        return 0\n    if obj is animate\n        return 0\n    if rooted_here(obj) is 0\n        return 0\n    if in_scope(obj) is 0\n        return 0\n    return 1\n\n// What TAKE ALL FROM tries: the source\'s direct contents, minus the same\n// refusals. Reach was already settled by the source being open.\nblock from_takeable(obj)\n    if obj is hidden\n        return 0\n    if obj is concealed\n        return 0\n    if obj is scenery\n        return 0\n    if obj is fixed\n        return 0\n    if obj is animate\n        return 0\n    return 1\n\nblock all_take()\n    let n = object_count\n    let count = 0\n    let obj = 1\n    while obj <= n\n        if all_takeable(obj) is 1\n            change count to count + 1\n            sweep_one(obj, action_id("take"))\n        change obj to obj + 1\n    if count is 0\n        change refused to 1\n        msg_all_none\n        fire_turn\n        tick\n    return 0\n\nblock all_from(source)\n    // A shut container keeps its contents: the honest refusal, not a raid.\n    if source is container\n        if shut_holds(source)\n            change second to source\n            change refused to 1\n            msg_closed\n            fire_turn\n            tick\n            return 0\n    let n = object_count\n    let count = 0\n    let obj = 1\n    while obj <= n\n        if obj is in source\n            if from_takeable(obj) is 1\n                change count to count + 1\n                sweep_one(obj, action_id("take"))\n        change obj to obj + 1\n    if count is 0\n        change refused to 1\n        msg_all_none_in(source)\n        fire_turn\n        tick\n    return 0\n\nblock all_drop()\n    let n = object_count\n    let count = 0\n    let obj = 1\n    while obj <= n\n        if obj is in player\n            if obj is not worn\n                change count to count + 1\n                sweep_one(obj, action_id("drop"))\n        change obj to obj + 1\n    if count is 0\n        change refused to 1\n        msg_empty_handed\n        fire_turn\n        tick\n    return 0\n\n// The wording. Fork the granule to change any of these lines.\nblock msg_all_none()\n    say "There\'s nothing here worth taking."\n\nblock msg_all_none_in(source)\n    say "There\'s nothing in ${the source} worth taking."\n\nblock msg_all_verb()\n    say "One thing at a time."\n',
    'verbose_exits.granule': '// verbose_exits.granule\n// part of Arcturus, a programming language and compiler for the Infocom Z-machine.\n// Copyright (c) 2026, Stefan Vogt.\n// https://github.com/ByteProject/Arcturus\n//\n// An opt-in feature: summon it with `summon.verbose_exits`. When the player tries\n// a direction with no exit, instead of the plain "no exit that way" line, Cosmos\n// lists the room\'s currently open exits, for example "You can only go north or\n// east from here." The list is computed fresh every time, so it stays correct as\n// exits open and close during play.\n//\n// HOW IT WORKS (a small teaching example of a granule reaching one level deeper):\n// a granule is ordinary Arcturus, but this one leans on three intrinsics the\n// compiler provides for exactly this purpose. The compiler already knows which of\n// the standard directions (north, south, ...) are real properties in your game\n// and what their property numbers are, because it needs that for movement. These\n// intrinsics open a small window onto that knowledge:\n//\n//   exits_count   how many directions are properties in this game (a constant)\n//   exit_prop(i)    the property number of the i-th such direction\n//   exit_name(i)    print the i-th direction\'s name (north, south, ...)\n//\n// With those, listing a room\'s exits is just: for each direction i, read the\n// room\'s property number exit_prop(i) with the dynamic-property form here.(p); if\n// it leads somewhere, name it. The backing routines for exit_prop/exit_name are\n// emitted by the compiler ONLY when this granule is summoned, so an unsummoned\n// verbose_exits costs the story file nothing.\n//\n// To change the phrasing, redefine msg_cant_go in the story (most-specific-\n// wins: the game\'s block beats this granule\'s) or fork the granule.\n\n// Replace the standard blocked-direction reply with a live exit list. The go verb\n// calls msg_cant_go whenever the chosen direction has no exit, so overriding this\n// one block is all it takes; no extra grammar or handlers are needed.\nblock msg_cant_go()\n    let n = exits_count\n    // First pass: count the open exits, so the list can read naturally, with\n    // commas between and an "or" before the last one.\n    let total = 0\n    let i = 0\n    while i < n\n        let p = exit_prop(i)\n        if exit_dest(here, p) is not nothing\n            change total to total + 1\n        change i to i + 1\n    if total is 0\n        msg_no_exits\n        return 0\n    // Second pass: print the exits, choosing the connector by position.\n    show("You can only go ")\n    let shown = 0\n    change i to 0\n    while i < n\n        let q = exit_prop(i)\n        if exit_dest(here, q) is not nothing\n            if shown is not 0\n                if shown is total - 1\n                    show(" or ")\n                else\n                    show(", ")\n            exit_name(i)\n            change shown to shown + 1\n        change i to i + 1\n    say " from here."\n    return 0\n\n// A room with no exits at all (rare, but possible while a game is sealed off).\nblock msg_no_exits()\n    say "There\'s no way out of here at the moment."\n',
}


def _bootstrap():
    pkg = types.ModuleType("arcturus")
    pkg.__package__ = "arcturus"
    pkg.__path__ = []
    sys.modules["arcturus"] = pkg
    exec(compile(_INIT, "arcturus/__init__.py", "exec"), pkg.__dict__)
    pkg.__build__ = _BUILD_ID  # stamp the fingerprint over the source default (None)
    for name in _MODULE_ORDER:
        mod = types.ModuleType("arcturus." + name)
        mod.__package__ = "arcturus"
        sys.modules["arcturus." + name] = mod
        setattr(pkg, name, mod)
        exec(compile(_MODULES[name], "arcturus/" + name + ".py", "exec"), mod.__dict__)
    # Embed the Cosmos library so the single-file build carries it (no cosmos/
    # directory at run time).
    sys.modules["arcturus.cosmos"]._EMBEDDED = _COSMOS
    return sys.modules["arcturus.cli"]


if __name__ == "__main__":
    raise SystemExit(_bootstrap().main())
