ch_blocker(noun) is not nothing\n        change refused to 1\n        change shut_in to reach_blocker(noun)\n        msg_open_first\n        stop\n    if noun is scenery\n        change refused to 1\n        msg_scenery\n        stop\n    if noun is fixed\n        change refused to 1\n        msg_fixed\n        stop\n    if noun is animate\n        change refused to 1\n        msg_animate_refuses\n        stop\n    if player holds noun\n        msg_have_it\n        stop\n    gain(noun)\n    if any_alter is 1\n        if altered is 0\n            msg_taken\n        else\n            run_alter\n    else\n        msg_taken\n\non drop\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if not (player holds noun)\n        msg_not_holding\n        stop\n    // A drop lands where the player IS: in the crate or on the altar when\n    // nested, the room floor otherwise (parent_of(player) is `here` when\n    // not nested, so the plain game pays nothing extra in behavior; the\n    // guard folds away without enterables).\n    if any_enterable is 1\n        move noun to parent_of(player)\n    else\n        move noun to here\n    now noun is not worn\n    if any_alter is 1\n        if altered is 0\n            msg_dropped\n        else\n            run_alter\n    else\n        msg_dropped\n\non examine\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    now noun is seen\n    if desc_addr(noun) is nothing\n        // Examining yourself gets its own line: the generic "nothing special"\n        // is an object\'s message, the wrong voice for the player. A game that\n        // sets player.desc never reaches this.\n        if noun is player\n            msg_examine_self\n            stop\n        msg_nothing_special\n        stop\n    say noun.desc\n\non quit\n    change meta_turn to 1\n    if confirm_quit is 0\n        stop\n    msg_farewell\n    do_quit\n\non score\n    change meta_turn to 1\n    msg_score\n\non restart\n    change meta_turn to 1\n    msg_confirm_restart\n    if yes_no is 0\n        stop\n    do_restart\n\non save\n    change meta_turn to 1\n    let r = do_save\n    if r is 2\n        // Arriving here means a RESTORE just landed. The saved state may date\n        // from the middle of a chained line, its tail still queued; the queue\n        // dies with the rewind, exactly like undo.\n        change chain_pos to 0\n        par\n        describe_room\n        stop\n    if r is 1\n        msg_saved\n        stop\n    change refused to 1\n    msg_save_failed\n\non restore\n    change meta_turn to 1\n    let r = do_restore\n    change refused to 1\n    msg_restore_failed\n\n// The transcript (output stream 2). The interpreter owns the file: opening\n// the stream makes it prompt for one, and it reports the truth in Flags 2\n// bit 0, so a player who cancels the prompt gets an honest failure line\n// instead of a false "transcript on".\nblock transcript_active()\n    let f = peek_byte(17)\n    let h = f / 2\n    return f - h - h\n\non transcript\n    change meta_turn to 1\n    if transcript_active is 1\n        change refused to 1\n        msg_transcript_already\n        stop\n    transcript_open\n    if transcript_active is 1\n        msg_transcript_on\n        stop\n    change refused to 1\n    msg_transcript_failed\n\non transcript_off\n    change meta_turn to 1\n    if transcript_active is 0\n        change refused to 1\n        msg_transcript_not_on\n        stop\n    msg_transcript_off\n    transcript_close\n\non xyzzy\n    msg_xyzzy\n\non inventory\n    // Two shapes of the same loop, chosen at compile time (any_components):\n    // a component of the player (an apron that is part of a uniform, a\n    // prosthetic) is part of you, not luggage, so the inventory skips it\n    // the way the room listing does; a game with no components keeps the\n    // plain loop, byte-identical.\n    let carrying = 0\n    if any_components is 1\n        for each obj in player\n            if obj is not component\n                if carrying is 0\n                    msg_carrying\n                change carrying to carrying + 1\n                list_held(obj)\n    else\n        for each obj in player\n            if carrying is 0\n                msg_carrying\n            change carrying to carrying + 1\n            list_held(obj)\n    if carrying is 0\n        msg_empty_handed\n\non switch_on\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    msg_no_switch\n\non switch_off\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    change refused to 1\n    msg_no_switch\n\non wear\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if noun is not wearable\n        change refused to 1\n        msg_cant_wear\n        stop\n    if noun is worn\n        msg_already_worn\n        stop\n    move noun to player\n    now noun is worn\n    if any_alter is 1\n        if altered is 0\n            msg_worn\n        else\n            run_alter\n    else\n        msg_worn\n\non take_off\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if noun is not worn\n        msg_not_worn\n        stop\n    now noun is not worn\n    if any_alter is 1\n        if altered is 0\n            msg_removed\n        else\n            run_alter\n    else\n        msg_removed\n\non put\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if second is nothing\n        change refused to 1\n        msg_put_where\n        stop\n    // PUT moves the noun without a hold check, so it needs the noun guard\n    // too: a beyond chandelier must not ride into a sack, and a beyond\n    // player must not fish things off the ground into the saddlebag.\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n        if beyond_guard_second is 1\n            stop\n    if second is supporter\n        move noun to second\n        now noun is not worn\n        if any_alter is 1\n            if altered is 0\n                msg_done\n            else\n                run_alter\n        else\n            msg_done\n        stop\n    if second is container\n        if second is open\n            move noun to second\n            now noun is not worn\n            if any_alter is 1\n                if altered is 0\n                    msg_done\n                else\n                    run_alter\n            else\n                msg_done\n            stop\n        change refused to 1\n        msg_closed\n        stop\n    change refused to 1\n    msg_cant_put\n\non insert\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if second is nothing\n        change refused to 1\n        msg_put_where\n        stop\n    // The same mover as put: both guards, same reason.\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n        if beyond_guard_second is 1\n            stop\n    if second is container\n        if second is open\n            move noun to second\n            now noun is not worn\n            if any_alter is 1\n                if altered is 0\n                    msg_done\n                else\n                    run_alter\n            else\n                msg_done\n            stop\n        change refused to 1\n        msg_closed\n        stop\n    change refused to 1\n    msg_cant_put\n\non open\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if noun is not openable\n        change refused to 1\n        msg_cant_open\n        stop\n    if noun is locked\n        // "open X with KEY": if the player named a key (second), unlock the thing\n        // first, then fall through to open it. A locked thing with no key named is\n        // still refused. This is the common one-line "open the door with the key".\n        if second is nothing\n            change refused to 1\n            msg_open_locked\n            stop\n        if second is not noun.unseal_with\n            change refused to 1\n            msg_wrong_key\n            stop\n        if not (player holds second)\n            change refused to 1\n            msg_no_key\n            stop\n        now noun is not locked\n        if any_alter is 1\n            if altered is 0\n                msg_unlocked\n            else\n                run_alter\n        else\n            msg_unlocked\n    if noun is open\n        msg_already_open\n        stop\n    now noun is open\n    if any_alter is 1\n        if altered is 0\n            msg_opened\n        else\n            run_alter\n    else\n        msg_opened\n    reveal_contents(noun)\n\non close\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if noun is not openable\n        change refused to 1\n        msg_cant_close\n        stop\n    if noun is not open\n        msg_already_shut\n        stop\n    now noun is not open\n    if any_alter is 1\n        if altered is 0\n            msg_closed_it\n        else\n            run_alter\n    else\n        msg_closed_it\n\non lock\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if noun is not lockable\n        change refused to 1\n        msg_cant_lock\n        stop\n    if noun is locked\n        msg_already_locked\n        stop\n    if noun is open\n        change refused to 1\n        msg_close_first\n        stop\n    // The opener (unseal_with) must be HELD to lock it too. A keyless bolt\n    // has no opener to hold, so the player cannot lock it; its locked state\n    // is the story\'s to set (`now box is locked`).\n    if second is nothing\n        change second to noun.unseal_with\n    if second is nothing\n        change refused to 1\n        msg_no_key\n        stop\n    if second is not noun.unseal_with\n        change refused to 1\n        msg_wrong_key\n        stop\n    if not (player holds second)\n        change refused to 1\n        msg_no_key\n        stop\n    now noun is locked\n    if any_alter is 1\n        if altered is 0\n            msg_locked\n        else\n            run_alter\n    else\n        msg_locked\n\non unlock\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    // Nothing to unlock: the thing has no lock at all, so just open it.\n    if noun is not lockable\n        msg_cant_unlock\n        perform("open", noun)\n        stop\n    // Lockable but already unlocked: unlocking is a no-op, so open it.\n    if noun is not locked\n        msg_not_locked\n        perform("open", noun)\n        stop\n    // Locked. It needs its opener (unseal_with), and that opener must be\n    // HELD. A bare UNLOCK reaches for the lock\'s own opener. A KEYLESS lock\n    // (no unseal_with) has no opener to hold, so it refuses here rather than\n    // springing open for free (the field report); the story opens it itself,\n    // `now box is not locked`, when the crowbar comes down.\n    if second is nothing\n        change second to noun.unseal_with\n    if second is nothing\n        change refused to 1\n        msg_no_key\n        stop\n    if second is not noun.unseal_with\n        change refused to 1\n        msg_wrong_key\n        stop\n    if not (player holds second)\n        change refused to 1\n        msg_no_key\n        stop\n    now noun is not locked\n    if any_alter is 1\n        if altered is 0\n            msg_unlocked\n        else\n            run_alter\n    else\n        msg_unlocked\n\n// The success report for boarding (enter) and leaving (exit). The WORLD-MODEL\n// choice, on a supporter versus in a container, is made here; the WORDING lives\n// in the language layer (msg_get_on / msg_get_in / msg_get_off / msg_get_out).\n// An `alter` report the object registered fires instead of the default, exactly\n// as the other action reports do. `noun` is the thing boarded or left.\nblock board_report()\n    if any_alter is 1\n        if altered is not 0\n            run_alter\n            return 0\n    if noun is supporter\n        msg_get_on\n    else\n        msg_get_in\n\nblock leave_report()\n    if any_alter is 1\n        if altered is not 0\n            run_alter\n            return 0\n    if noun is supporter\n        msg_get_off\n    else\n        msg_get_out\n\non enter\n    if noun is nothing\n        change refused to 1\n        msg_noun_missing\n        stop\n    if any_beyond is 1\n        if beyond_guard is 1\n            stop\n    if player in noun\n        msg_already_there\n        stop\n    if noun is supporter\n        move player to noun\n        board_report\n        stop\n    if noun is container\n        if noun is not open\n            change refused to 1\n            msg_cant_enter\n            stop\n        move player to noun\n        board_report\n        stop\n    change refused to 1\n    msg_cant_enter\n\non exit\n    // With a noun (the author\'s `exit noun` grammar, or GET OUT OF X): leave\n    // that thing in particular, refusing when the player is not in it. The\n    // noun path folds away with nothing to be inside (any_enterable); the bare\n    // path below is the catch-all and stays, because a supporter set as an\n    // attribute or at runtime is not seen by that compile-time estimate.\n    if any_enterable is 1\n        if noun is not nothing\n   