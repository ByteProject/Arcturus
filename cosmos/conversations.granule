// conversations.granule
// part of Arcturus, a programming language and compiler for the Infocom Z-machine.
// Copyright (c) 2026, Stefan Vogt.
// https://github.com/ByteProject/Arcturus
//
// summon.conversations: the menu presentation of the `topic` model, after the
// look of PunyInform's talk menu (which is the right idea) but on Arcturus's
// topic sugar instead of its hand-managed talk arrays. TALK TO a person and a
// numbered menu of their topics in view is painted in the upper window, held
// STATIC while the conversation scrolls in the main window below. Press a number
// to ask that topic; the exchange prints below and the topic drops off the menu
// (you have discussed it), which redraws with any topics the exchange revealed.
// 0 or ENTER ends it and the menu folds away.
//
// This is the same `topic` model the extendedverbs ask/tell path walks; the two
// are mutually exclusive views of one thing (the menu wins). Every line of
// wording is an overridable block.

// Override the base talk_to seam: talking to a person opens the topic menu.
block talk_to(person)
    run_talk(person)

block run_talk(person)
    if count_visible(person) is 0
        msg_no_topics()
        return 0
    let going = 1
    while going is 1
        let count = count_visible(person)
        if count > 9
            change count to 9
        if count is 0
            close_menu()
            msg_talk_over()
            change going to 0
        else
            draw_menu(person, count)
            let pick = menu_choice(count)
            if pick is 0
                close_menu()
                msg_talk_over()
                change going to 0
            else
                set_window(0)
                run_pick(person, pick)

// Paint the numbered menu in the upper window and hold it static there, sized to
// the topics in view rather than reserving a fixed slice of the screen the way
// PunyInform's talk menu does - a small dynamic refinement on the same idea.
// Layout, top to bottom with no gaps: the status bar (only when statusline is
// summoned), the header, the topics, the prompt, and a divider rule at the bottom
// border. status_lines tells us whether a bar row is present, so without
// statusline the menu reclaims row 1 and uses the full window. The double erase,
// around the resize, keeps a shrinking menu from leaving a stale line behind: the
// first clears the old (possibly taller) window, the second the new one. Single
// keypress selection caps the list at nine, so a tenth topic waits for a discard.
block draw_menu(person, count)
    let w = screen_width()
    if w is 0
        change w to 40
    let top = status_lines()
    let h = top + count + 3
    set_window(1)
    erase_window(1)
    split_window(h)
    erase_window(1)
    if top is 1
        status_bar()
    set_cursor(top + 1, 1)
    show("Talk to ${the person} about:")
    let i = 0
    let n = 0
    while i < topics_count(person)
        if topic_visible(person, i)
            if n < count
                change n to n + 1
                set_cursor(top + 1 + n, 2)
                show(n)
                show(". ")
                topic_label(person, i)
        change i to i + 1
    set_cursor(h - 1, 1)
    show("Press a number to ask, or 0 to leave.")
    set_cursor(h, 1)
    let d = 1
    while d < w
        show("-")
        change d to d + 1
    set_window(0)

// Read keypresses until a valid one: a digit 1..count returns it; 0, ENTER, or Q
// ends the conversation (returns 0). Other keys are ignored and read again, so a
// stray key neither redraws nor exits.
block menu_choice(count)
    while true
        let key = read_key()
        if key is 13
            return 0
        if key is 48
            return 0
        if key is 81
            return 0
        if key is 113
            return 0
        let pick = key - 48
        if pick >= 1
            if pick <= count
                return pick

// Fold the menu away and return the whole screen to the conversation.
block close_menu()
    erase_window(1)
    split_window(0)
    set_window(0)

block count_visible(person)
    let i = 0
    let n = 0
    while i < topics_count(person)
        if topic_visible(person, i)
            change n to n + 1
        change i to i + 1
    return n

// Run the pick-th visible topic (counting from 1, in declaration order, as
// draw_menu numbered them), then retire it so it leaves the menu.
block run_pick(person, pick)
    let i = 0
    let n = 0
    while i < topics_count(person)
        if topic_visible(person, i)
            change n to n + 1
            if n is pick
                topic_run(person, i)
                topic_retire(person, i)
                return 0
        change i to i + 1

// Wording, all overridable.
block msg_no_topics()
    say "You can't think of anything worth raising right now."

block msg_talk_over()
    say "You let the conversation rest there."
