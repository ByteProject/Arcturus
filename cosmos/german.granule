block msg_attack()
    say "Auf Dinge einzuschlagen hilft selten, und daran wird sich auch jetzt nichts ändern."

block msg_eat()
    if any_pluribus is 1
        if noun is pluribus
            say "${The noun} stehen nicht auf dem Speiseplan."
            return 0
    say "${The noun} steht nicht auf dem Speiseplan."

block msg_drink()
