// Conversation.
block msg_no_talk()
    if any_pluribus is 1
        if noun is pluribus
            say "${The noun} scheinen nicht zum Reden aufgelegt."
            return 0
    say "${The noun} scheint nicht zum Reden aufgelegt."

block msg_use_talk()
    say "Um mit ${the:dat noun} weiterzukommen, benutze SPRICH MIT
         ${the:dat noun}."

block msg_ask()
    if any_pluribus is 1
        if noun is pluribus
            say "${The noun} lassen sich zu dem Thema nichts entlocken."
            return 0
    say "${The noun} lässt sich zu dem Thema nichts entlocken."

