block msg_cant_oops()
    say "Es gibt nichts zu korrigieren."

// One line of an inventory listing; a worn item is tagged, a container or
// supporter names what it holds. A bare list reads as nominative.
block list_held(obj)
    show("  ")
    show("${a obj}")
    if obj is worn
        show(" (getragen)")
    show_tag(obj)
    list_contents(obj)
    say ""
