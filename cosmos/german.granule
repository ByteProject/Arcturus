    if any_pluribus is 1
        say "${The noun} ${is noun} schon aus."
        return 0
    say "${The noun} ist schon aus."

block msg_no_effect()
    if any_pluribus is 1
        if noun is pluribus
            say "${The noun} rühren sich nicht."
            return 0
    say "${The noun} rührt sich nicht."

