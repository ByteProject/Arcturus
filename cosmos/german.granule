// Inventory.
block msg_carrying()
    say "Du trägst mit dir:"

block msg_empty_handed()
    say "Du hast rein gar nichts bei dir."

// Scenery default.
block msg_scenery()
    say "Das gehört nur zur Kulisse. Kümmere dich nicht darum."

// Printed when the first word names no verb or direction.
block msg_no_verb()
    say "Diese Worte ergeben keinen Sinn."

// The verb was understood, but it cannot use the words that followed it.
block msg_extra_words()
    say "Nach dem Verb konnte ich nicht mehr folgen."

// Read a yes/no answer; returns 1 for an answer that starts with j or J (ja). The
// caller prints the question first, so this is shared by every confirmation.
block yes_no()
    let term = read_input
    let c = text_char(0)
    if c is 106
        return 1
    if c is 74
        return 1
    return 0

// Ask the player to confirm quitting; returns 1 for yes.
block confirm_quit()
    show("Willst du wirklich aufhören? ")
    return yes_no

// The farewell, overridable for a custom send-off.
block msg_farewell()
    say "Dann lassen wir es für heute gut sein."

block msg_game_over()
    say "Möchtest du NEU STARTEN, einen Spielstand LADEN oder BEENDEN?"

// Nur nach einem `death`-Ende: der Weg zurück steht zur Wahl.
block msg_game_over_died()
    say "Möchtest du NEU STARTEN, einen Spielstand LADEN, den letzten Zug WIDERRUFEN oder BEENDEN?"

block msg_game_over_unknown()
    say "Das war keine der Möglichkeiten."

// How many things the player wears; the pure count beside list_worn, so a
// story can guard its phrasing ("You're dressed in nothing at all") before
// printing a prefix. Both cost nothing unless called (DCE).
block worn_count()
    let n = 0
    for each x in player
        if x is worn
            change n to n + 1
    return n

// Print what the player wears as a punctuated list, "einen Hut, einen Umhang und
// Stiefel", with no framing and no newline: the story writes its own prose
// around it. Returns the count. The two-pass count-then-join shape is the
// library's own listing idiom (list_contents_run).
block list_worn()
    let total = worn_count
    let shown = 0
    for each x in player
        if x is worn
            if shown is not 0
                if shown is total - 1
                    show(" und ")
                else
                    show(", ")
            show("${a:acc x}")
            change shown to shown + 1
    return total


// Meta verbs.
block msg_score()
    if any_awards is 0
        say "Dieses Spiel zählt keine Punkte."
        return 0
    show("Du hast ${score} von ${max_score} Punkten in ")
    show(turns)
    if turns is 1
        show(" Zug")
    else
        show(" Zügen")
    show(" erreicht")
    if any_ranks is 1
        show(". Das bringt dir den Rang: ")
        print_rank
    say "."

block msg_confirm_restart()
    show("Von vorne beginnen? ")

