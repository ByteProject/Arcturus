// Scenery default.
block msg_scenery()
    say "Just some scenery. Don't worry about it."

// Printed when the first word names no verb or direction.
block msg_no_verb()
    say "Those words don't add up to anything."

// The verb was understood, but it cannot use the words that followed it ("jump
// north", "look cloak"). The verb is fine; the rest is one word too many.
block msg_extra_words()
    say "You lost me after that."

// Read a yes/no answer; returns 1 for an answer that starts with y or Y. The
// caller prints the question first, so this is shared by every confirmation. The
// yes test (a leading 'y') is English, so it lives in the language layer.
block yes_no()
    let term = read_input()
    let c = text_char(0)
    if c is 121
        return 1
    if c is 89
        return 1
    return 0

// Ask the player to confirm quitting; returns 1 for yes.
block confirm_quit()
    show("Are you sure you want to quit? ")
    return yes_no()

// The farewell, overridable for a custom send-off.
block msg_farewell()
    say "We'll leave it there."

// Meta verbs (the score, a restart confirmation, the xyzzy easter egg). save,
// restore, and undo bring their own messages with the meta-verb opcodes.
block msg_score()
    say "You have scored ${score} of a possible ${max_score}."

block msg_confirm_restart()
    show("Start over from the very beginning? ")

block msg_xyzzy()
    say "Nothing happens, but you feel briefly clever."

block msg_saved()
    say "Saved."

block msg_save_failed()
    say "Something went wrong with that save."

block msg_restore_failed()
    say "That save couldn't be restored."

block msg_undone()
    say "Taken back."

block msg_cant_undo()
    say "There's nothing to take back."

block msg_cant_oops()
    say "There's nothing to put right."

// One line of an inventory listing; a worn item is tagged, a container or
// supporter names what it holds.
block list_held(obj)
    show("  ")
    show("${a obj}")
    if obj is worn
        show(" (worn)")
    list_contents(obj)
    say ""
